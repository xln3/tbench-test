[18.227014, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_layout_quine_split_topology_horizontal\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"Behavior-based verification of horizontal split topology via winlayout().\"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[94mwith\u001b[39;49;00m tempfile.TemporaryDirectory(\u001b[96mdir\u001b[39;49;00m=\u001b[33m\"\u001b[39;49;00m\u001b[33m/app\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m) \u001b[94mas\u001b[39;49;00m tmp_dir:\u001b[90m\u001b[39;49;00m\r\n            tmp_path = Path(tmp_dir)\u001b[90m\u001b[39;49;00m\r\n            test_file = tmp_path / \u001b[33m\"\u001b[39;49;00m\u001b[33mlayout.txt\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n"]
[18.227175, "o", "            quine_output = tmp_path / \u001b[33m\"\u001b[39;49;00m\u001b[33mquine.vim\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n            test_file.write_text(\u001b[33m\"\u001b[39;49;00m\u001b[33mx\u001b[39;49;00m\u001b[33m\\n\u001b[39;49;00m\u001b[33my\u001b[39;49;00m\u001b[33m\\n\u001b[39;49;00m\u001b[33mz\u001b[39;49;00m\u001b[33m\\n\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n            \u001b[90m# Create a layout with a horizontal split\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            setup_script = tmp_path / \u001b[33m\"\u001b[39;49;00m\u001b[33msetup.vim\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            setup_script.write_text(\u001b[90m\u001b[39;49;00m\r\n                \u001b[33mf\u001b[39;49;00m\u001b[33m\"\"\"\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33mset rtp+=/app\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33mcd \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mtmp_dir\u001b[33m}\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33msource /app/plugin/layout_quine.vim\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33medit layout.txt\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33mnormal! 1G1|\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33msplit\u001b[39;49;00m\u001b[33m\u001b[39;49;0"]
[18.227234, "o", "0m\r\n    \u001b[33mLayoutQuine \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mquine_output\u001b[33m}\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33mqall!\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m\"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            )\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n            cmd1 = [\u001b[33m\"\u001b[39;49;00m\u001b[33mvim\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33m-Es\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33m-u\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33mNONE\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33m-n\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33m-S\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[96mstr\u001b[39;49;00m(setup_script)]\u001b[90m\u001b[39;49;00m\r\n            result1 = subprocess.run(cmd1, capture_output=\u001b[94mTrue\u001b[39;49;00m, text=\u001b[94mTrue\u001b[39;49;00m, cwd=\u001b[33m\"\u001b[39;49;00m\u001b[33m/app\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n            \u001b[94massert\u001b[39;49;00m result1.returncode == \u001b[94m0\u001b[39;49;00m, \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mVim command failed: \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mresult1.stderr\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[3"]
[18.227283, "o", "9;49;00m\u001b[90m\u001b[39;49;00m\r\n            \u001b[94massert\u001b[39;49;00m quine_output.exists(), \u001b[33m\"\u001b[39;49;00m\u001b[33mLayoutQuine should create output file\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n            \u001b[90m# Minimal canonical command check for split creation\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            content = quine_output.read_text()\u001b[90m\u001b[39;49;00m\r\n            \u001b[94massert\u001b[39;49;00m \u001b[33m\"\u001b[39;49;00m\u001b[33msplit\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m \u001b[95min\u001b[39;49;00m content, (\u001b[90m\u001b[39;49;00m\r\n                \u001b[33m\"\u001b[39;49;00m\u001b[33mGenerated script should use split for horizontal splits\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            )\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n            \u001b[90m# Source the generated script and capture winlayout() summary\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n"]
[18.227325, "o", "            state_file = tmp_path / \u001b[33m\"\u001b[39;49;00m\u001b[33mlayout_state_h.txt\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            check_script = tmp_path / \u001b[33m\"\u001b[39;49;00m\u001b[33mcheck_layout_h.vim\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            check_script.write_text(\u001b[90m\u001b[39;49;00m\r\n                \u001b[33mf\u001b[39;49;00m\u001b[33m\"\"\"\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33mset rtp+=/app\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n"]
[18.227417, "o", "    \u001b[33mcd \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mtmp_dir\u001b[33m}\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33msource \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mquine_output\u001b[33m}\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33mlet l = winlayout()\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33mlet top = l[0]\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33mlet nchildren = len(l[1])\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33mcall writefile([top, string(nchildren)], \u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33m{\u001b[39;49;00mstate_file\u001b[33m}\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33m)\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33mqall!\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m\"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            )\u001b[90m\u001b[39;49;00m\r\n"]
