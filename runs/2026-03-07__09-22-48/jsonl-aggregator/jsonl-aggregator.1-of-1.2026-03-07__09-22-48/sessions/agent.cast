[4.293559, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> ```json\r\n\u001b[?2004l\r"]
[4.293693, "o", "\u001b[?2004h>   {\r\n\u001b[?2004l\r\u001b[?2004h> "]
[4.293816, "o", "    \"top_5_users_by_amount\": {\r\n\u001b[?2004l\r"]
[4.293962, "o", "\u001b[?2004h> "]
[4.29414, "o", "      \"alice\": {\"total_amount\": 15.05, \"total_items\": 5},\r\n\u001b[?2004l\r\u001b[?2004h"]
[4.294305, "o", ">       ...\r\n\u001b[?2004l\r\u001b[?2004h>     },\r\n\u001b[?2004l\r\u001b[?2004h> "]
