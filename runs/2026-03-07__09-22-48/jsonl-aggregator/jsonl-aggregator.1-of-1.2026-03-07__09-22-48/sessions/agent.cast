[4.294736, "o", "\u001b[?2004h>       \"b\": {\"count\": 5},\r\n\u001b[?2004l\r"]
[4.294854, "o", "\u001b[?2004h> "]
[4.29495, "o", "      \"c\": {\"count\": 3}\r\n\u001b[?2004l\r\u001b[?2004h>     }\r\n\u001b[?2004l\r"]
[4.295033, "o", "\u001b[?2004h>   }\r\n\u001b[?2004l\r\u001b[?2004h"]
[4.29511, "o", "> ```\r\n\u001b[?2004l\r\u001b[?2004h> "]
[4.29547, "o", "- '\"'\"'top_5_users_by_amount'\"'\"': The top 5 users by '\"'\"'amount'\"'\"' summed across all their records. \r\n\u001b[?2004l\r"]
[4.295612, "o", "\u001b[?2004h> "]
