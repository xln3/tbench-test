[11.540505, "o", "    \u001b[33m    \"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        august_schedule_path = Path(\u001b[33m\"\u001b[39;49;00m\u001b[33m/app/august_schedule.ics\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n        taylor_schedule_path = Path(\u001b[33m\"\u001b[39;49;00m\u001b[33m/app/taylor_schedule.ics\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n"]
