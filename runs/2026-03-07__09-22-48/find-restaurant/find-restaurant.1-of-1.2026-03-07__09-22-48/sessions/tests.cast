[11.541424, "o", "\r\n"]
[11.541845, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_schedule_constraints_respected\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"\u001b[39;49;00m\r\n    \u001b[33m    This test verifies that the reservation time respects both team members' schedules.\u001b[39;49;00m\r\n"]
