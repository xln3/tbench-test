[26.780553, "o", "\u001b[31m\u001b[1m__________________________________________________________________________ test_debug __________________________________________________________________________\u001b[0m\r\n\r\n"]
[26.856377, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_debug\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"Check that the debug command runs successfully and produces expected output.\"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        out = subprocess.run(\u001b[90m\u001b[39;49;00m\r\n            [\u001b[33m\"\u001b[39;49;00m\u001b[33mpython\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33m/app/src/main.py\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33m+mode=debug\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33m--cfg\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33mjob\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m],\u001b[90m\u001b[39;49;00m\r\n            stdout=subprocess.PIPE,\u001b[90m\u001b[39;49;00m\r\n        )\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n"]
[26.856569, "o", "        ref_path = Path(\u001b[33m\"\u001b[39;49;00m\u001b[33m/tests/ref_debug.yaml\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[94massert\u001b[39;49;00m out.returncode == \u001b[94m0\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33mDebug command failed\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[94massert\u001b[39;49;00m out.stdout, \u001b[33m\"\u001b[39;49;00m\u001b[33mNo output from debug command\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n>       \u001b[94massert\u001b[39;49;00m out.stdout.decode() == ref_path.read_text(), (\u001b[90m\u001b[39;49;00m\r\n            \u001b[33m\"\u001b[39;49;00m\u001b[33mOutput does not match reference\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        )\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31mE       AssertionError: Output does not match reference\u001b[0m\r\n"]
[26.856724, "o", "\u001b[1m\u001b[31mE       assert 'notes: my-ex...m_epochs: 1\\n' == 'notes: my-ex...m_epochs: 1\\n'\u001b[0m\r\n\u001b[1m\u001b[31mE         \u001b[0m\r\n\u001b[1m\u001b[31mE         \u001b[0m\u001b[90m \u001b[39;49;00m notes: my-experiment\u001b[90m\u001b[39;49;00m\u001b[0m\r\n\u001b[1m\u001b[31mE         \u001b[91m- debug: true\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\u001b[0m\r\n\u001b[1m\u001b[31mE         \u001b[92m+ debug: false\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\u001b[0m\r\n\u001b[1m\u001b[31mE         \u001b[90m \u001b[39;49;00m train:\u001b[90m\u001b[39;49;00m\u001b[0m\r\n\u001b[1m\u001b[31mE         \u001b[90m \u001b[39;49;00m   batch_size: 32\u001b[90m\u001b[39;49;00m\u001b[0m\r\n\u001b[1m\u001b[31mE         \u001b[90m \u001b[39;49;00m   learning_rate: 1.0e-05\u001b[90m\u001b[39;49;00m...\u001b[0m\r\n\u001b[1m\u001b[31mE         \u001b[0m\r\n\u001b[1m\u001b[31mE         ...Full output truncated (7 lines hidden), use '-vv' to show\u001b[0m\r\n"]
