[26.859527, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_slurm_hydra\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"Check that the SLURM hydra command runs and hydra launcher configured.\"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        out_hydra = subprocess.run(\u001b[90m\u001b[39;49;00m\r\n            [\u001b[33m\"\u001b[39;49;00m\u001b[33mpython\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33m/app/src/main.py\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33m-cn=slurm\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33m--cfg\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33mhydra\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m],\u001b[90m\u001b[39;49;00m\r\n"]
[26.859686, "o", "            stdout=subprocess.PIPE,\u001b[90m\u001b[39;49;00m\r\n        )\u001b[90m\u001b[39;49;00m\r\n        ref_path = Path(\u001b[33m\"\u001b[39;49;00m\u001b[33m/tests/ref_slurm_hydra.yaml\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[94massert\u001b[39;49;00m out_hydra.returncode == \u001b[94m0\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33mSlurm hydra command failed\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[94massert\u001b[39;49;00m out_hydra.stdout, \u001b[33m\"\u001b[39;49;00m\u001b[33mNo output from slurm hydra command\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n>       \u001b[94massert\u001b[39;49;00m out_hydra.stdout.decode() == ref_path.read_text(), (\u001b[90m\u001b[39;49;00m\r\n            \u001b[33m\"\u001b[39;49;00m\u001b[33mOutput does not match reference\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        )\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31mE       AssertionError: Output does not match reference\u001b[0m\r\n\u001b[1m\u001b[31mE       assert 'hydra:\\n  ru...bose: false\\n' == 'hydra:\\n  ru...bose: false\\n'\u001b[0m\r\n"]
