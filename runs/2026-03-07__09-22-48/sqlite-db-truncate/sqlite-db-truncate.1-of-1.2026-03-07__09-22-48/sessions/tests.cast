[52.108813, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_json_data\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Reference the directory the agent operated in (the WORKDIR in the Docker env)\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        data = json.load(\u001b[96mopen\u001b[39;49;00m(\u001b[33m\"\u001b[39;49;00m\u001b[33m/app/recover.json\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m))\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        soln_tuples = {(item[\u001b[33m\"\u001b[39;49;00m\u001b[33mword\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m], item[\u001b[33m\"\u001b[39;49;00m\u001b[33mvalue\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m]) \u001b[94mfor\u001b[39;49;00m item \u001b[95min\u001b[39;49;00m soln}\u001b[90m\u001b[39;49;00m\r\n        data_tuples = {(item[\u001b[33m\"\u001b[39;49;00m\u001b[33mword\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m], item[\u001b[33m\"\u001b[39;49;00m\u001b[33mvalue\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m]) \u001b[94mfor\u001b[39;49;00m item \u001b[95min\u001b[39;49;00m data}\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Find intersection - each item matched at most once\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        matches = soln_tuples & data_tuples\u001b[90m\u001b[39;49;00m\r\n"]
[52.109004, "o", "        score = \u001b[96mlen\u001b[39;49;00m(matches)\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n>       \u001b[94massert\u001b[39;49;00m score > \u001b[94m6\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33mDid not load data correctly\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31mE       AssertionError: Did not load data correctly\u001b[0m\r\n\u001b[1m\u001b[31mE       assert 0 > 6\u001b[0m\r\n\r\n\u001b[1m\u001b[31m/tests/test_outputs.py\u001b[0m:31: AssertionError\r\n"]
[52.10936, "o", "\u001b[36m\u001b[1m=================================================================== short test summary info ====================================================================\u001b[0m\r\n\u001b[31mFAILED\u001b[0m ../tests/test_outputs.py::\u001b[1mtest_json_data\u001b[0m - AssertionError: Did not load data correctly\r\n"]
