[17.619594, "o", "            endpoint_url=LOCALSTACK_ENDPOINT,\u001b[90m\u001b[39;49;00m\r\n            aws_access_key_id=\u001b[33m\"\u001b[39;49;00m\u001b[33mtest\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n            aws_secret_access_key=\u001b[33m\"\u001b[39;49;00m\u001b[33mtest\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n            region_name=\u001b[33m\"\u001b[39;49;00m\u001b[33mus-east-1\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n        )\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        public_access = \u001b[94mFalse\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Check bucket ACL\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mtry\u001b[39;49;00m:\u001b[90m\u001b[39;49;00m\r\n            acl = s3.get_bucket_acl(Bucket=\u001b[33m\"\u001b[39;49;00m\u001b[33msample-bucket\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n            \u001b[94mfor\u001b[39;49;00m grant \u001b[95min\u001b[39;49;00m acl.get(\u001b[33m\"\u001b[39;49;00m\u001b[33mGrants\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, []):\u001b[90m\u001b[39;49;00m\r\n                grantee = grant.get(\u001b[33m\"\u001b[39;49;00m\u001b[33mGrantee\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, {})\u001b[90m\u001b[39;49;00m\r\n"]
[17.61964, "o", "                all_users_uri = \u001b[33m\"\u001b[39;49;00m\u001b[33mhttp://acs.amazonaws.com/groups/global/AllUsers\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n                \u001b[94mif\u001b[39;49;00m (\u001b[90m\u001b[39;49;00m\r\n                    grantee.get(\u001b[33m\"\u001b[39;49;00m\u001b[33mType\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m) == \u001b[33m\"\u001b[39;49;00m\u001b[33mGroup\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n                    \u001b[95mand\u001b[39;49;00m grantee.get(\u001b[33m\"\u001b[39;49;00m\u001b[33mURI\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m) == all_users_uri\u001b[90m\u001b[39;49;00m\r\n                    \u001b[95mand\u001b[39;49;00m grant.get(\u001b[33m\"\u001b[39;49;00m\u001b[33mPermission\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m) == \u001b[33m\"\u001b[39;49;00m\u001b[33mREAD\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n                ):\u001b[90m\u001b[39;49;00m\r\n"]
[17.619685, "o", "                    public_access = \u001b[94mTrue\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n                    \u001b[94mbreak\u001b[39;49;00m\u001b[90m\u001b[39;49;00m"]
[17.619759, "o", "\r\n        \u001b[94mexcept\u001b[39;49;00m ClientError:\u001b[90m\u001b[39;49;00m\r\n            \u001b[94mpass\u001b[39;49;00m  \u001b[90m# Continue to policy check if ACL check fails\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n"]
[17.619849, "o", "        \u001b[90m# Check bucket policy if ACL check didn't confirm public access\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mif\u001b[39;49;00m \u001b[95mnot\u001b[39;49;00m public_access:\u001b[90m\u001b[39;49;00m\r\n            \u001b[94mtry\u001b[39;49;00m:\u001b[90m\u001b[39;49;00m\r\n                bucket_policy = s3.get_bucket_policy(Bucket=\u001b[33m\"\u001b[39;49;00m\u001b[33msample-bucket\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n                policy = bucket_policy.get(\u001b[33m\"\u001b[39;49;00m\u001b[33mPolicy\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n                \u001b[94mif\u001b[39;49;00m (\u001b[90m\u001b[39;49;00m\r\n                    \u001b[33m'\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mPrincipal\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m: \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m*\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m \u001b[95min\u001b[39;49;00m policy\u001b[90m\u001b[39;49;00m\r\n                    \u001b[95mand\u001b[39;49;00m \u001b[33m'\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mAction\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m: \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33ms3:GetObject\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m \u001b[9"]
[17.619912, "o", "5min\u001b[39;49;00m policy\u001b[90m\u001b[39;49;00m\r\n                    \u001b[95mand\u001b[39;49;00m \u001b[33m'\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mResource\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m: \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33marn:aws:s3:::sample-bucket/*\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m \u001b[95min\u001b[39;49;00m policy\u001b[90m\u001b[39;49;00m\r\n                ):\u001b[90m\u001b[39;49;00m\r\n                    public_access = \u001b[94mTrue\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            \u001b[94mexcept\u001b[39;49;00m ClientError:\u001b[90m\u001b[39;49;00m\r\n                \u001b[94mpass\u001b[39;49;00m  \u001b[90m# Ignore policy errors\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n>       \u001b[94massert\u001b[39;49;00m public_access, (\u001b[90m\u001b[39;49;00m\r\n            \u001b[33m\"\u001b[39;49;00m\u001b[33mBucket is not public - neither ACL nor bucket policy allows public access\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        )\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31mE       AssertionError: Bucket is not public - neither ACL nor bucket policy allows public access\u001b[0m\r\n\u001b[1m\u001b[31mE       assert False\u001b[0m\r\n\r\n"]
[17.619955, "o", "\u001b[1m\u001b[31m/tests/test_outputs.py\u001b[0m:75: AssertionError\r\n"]
