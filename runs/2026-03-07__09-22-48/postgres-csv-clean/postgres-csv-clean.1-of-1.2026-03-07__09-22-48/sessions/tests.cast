[38.695239, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_cleaned_csv_is_ordered_by_id\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"Ensure cleaned_customers.csv rows are ordered by id ascending\u001b[39;49;00m\r\n    \u001b[33m    (as task specifies).\"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n"]
[38.695277, "o", "        cleaned_csv_path = Path(\u001b[33m\"\u001b[39;49;00m\u001b[33m/app/data/cleaned_customers.csv\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n>       \u001b[94massert\u001b[39;49;00m cleaned_csv_path.exists(), \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mCSV file does not exist: \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mcleaned_csv_path\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n"]
[38.695304, "o", "\u001b[1m\u001b[31mE       AssertionError: CSV file does not exist: /app/data/cleaned_customers.csv\u001b[0m\r\n\u001b[1m\u001b[31mE       assert False\u001b[0m\r\n"]
[38.695333, "o", "\u001b[1m\u001b[31mE        +  where False = exists()\u001b[0m\r\n\u001b[1m\u001b[31mE        +    where exists = PosixPath('/app/data/cleaned_customers.csv').exists\u001b[0m\r\n"]
[38.695359, "o", "\r\n\u001b[1m\u001b[31m/tests/test_outputs.py\u001b[0m:524: AssertionError\r\n"]
[38.695513, "o", "\u001b[31m\u001b[1m____________________________________________________________ test_postgres_matches_customers_v1_csv ____________________________________________________________\u001b[0m\r\n\r\n"]
[38.697052, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_postgres_matches_customers_v1_csv\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"Verify PostgreSQL customers table matches customers_v1.csv (ground truth)\"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# --- Fetch from PostgreSQL ---\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mwith\u001b[39;49;00m psycopg2.connect(\u001b[90m\u001b[39;49;00m\r\n            host=\u001b[33m\"\u001b[39;49;00m\u001b[33mdb\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n            port=\u001b[94m5432\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n            user=\u001b[33m\"\u001b[39;49;00m\u001b[33mpostgres\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n"]
[38.697163, "o", "            password=\u001b[33m\"\u001b[39;49;00m\u001b[33mpostgres\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n            database=\u001b[33m\"\u001b[39;49;00m\u001b[33mcustomers_db\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n        ) \u001b[94mas\u001b[39;49;00m conn:\u001b[90m\u001b[39;49;00m\r\n            \u001b[94mwith\u001b[39;49;00m conn.cursor() \u001b[94mas\u001b[39;49;00m cur:\u001b[90m\u001b[39;49;00m\r\n>               cur.execute(\u001b[33m\"\u001b[39;49;00m\u001b[33mSELECT id, name, email, phone, city FROM customers;\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31mE               psycopg2.errors.UndefinedTable: relation \"customers\" does not exist\u001b[0m\r\n\u001b[1m\u001b[31mE               LINE 1: SELECT id, name, email, phone, city FROM customers;\u001b[0m\r\n\u001b[1m\u001b[31mE                                                                ^\u001b[0m\r\n\r\n"]
[38.697256, "o", "\u001b[1m\u001b[31m/tests/test_outputs.py\u001b[0m:556: UndefinedTable\r\n"]
[38.697338, "o", "============================================================================ PASSES ============================================================================\r\n"]
[38.70133, "o", "\u001b[36m\u001b[1m=================================================================== short test summary info ====================================================================\u001b[0m\r\n\u001b[32mPASSED\u001b[0m ../tests/test_outputs.py::\u001b[1mtest_psql_commands_were_used\u001b[0m\r\n\u001b[31mFAILED\u001b[0m ../tests/test_outputs.py::\u001b[1mtest_cleaned_csv_file_exists\u001b[0m - AssertionError: File /app/data/cleaned_customers.csv does not exist\r\n\u001b[31mFAILED\u001b[0m ../tests/test_outputs.py::\u001b[1mtest_cleaned_csv_has_header\u001b[0m - FileNotFoundError: [Errno 2] No such file or directory: '/app/data/cleaned_customers.csv'\r\n\u001b[31mFAILED\u001b[0m ../tests/test_outputs.py::\u001b[1mtest_cleaned_csv_content\u001b[0m - FileNotFoundError: [Errno 2] No such file or directory: '/app/data/cleaned_customers.csv'\r\n\u001b[31mFAILED\u001b[0m ../tests/test_outputs.py::\u001b[1mtest_duplicates_removed\u001b[0m - FileNotFoundError: [Errno 2] No such file or directory: '/app/data/cleaned_customers.csv'\r\n"]
[38.70147, "o", "\u001b[31mFAILED\u001b[0m ../tests/test_outputs.py::\u001b[1mtest_data_quality\u001b[0m - FileNotFoundError: [Errno 2] No such file or directory: '/app/data/cleaned_customers.csv'\r\n\u001b[31mFAILED\u001b[0m ../tests/test_outputs.py::\u001b[1mtest_phone_format\u001b[0m - FileNotFoundError: [Errno 2] No such file or directory: '/app/data/cleaned_customers.csv'\r\n\u001b[31mFAILED\u001b[0m ../tests/test_outputs.py::\u001b[1mtest_postgres_database_connection\u001b[0m - AssertionError: Cannot connect to PostgreSQL database: PostgreSQL 'customers' table does not exist - agent may have cheated\r\n\u001b[31mFAILED\u001b[0m ../tests/test_outputs.py::\u001b[1mtest_postgres_table_structure\u001b[0m - AssertionError: Error checking PostgreSQL table structure: Expected 5 columns, got 0\r\n\u001b[31mFAILED\u001b[0m ../tests/test_outputs.py::\u001b[1mtest_postgres_data_consistency\u001b[0m - psycopg2.errors.UndefinedTable: relation \"customers\" does not exist\r\n\u001b[31mFAILED\u001b[0m ../tests/test_outputs.py::\u001b[1mtest_pg_stat_statements_shows_cleaning_and_copy_queries\u001b[0m - AssertionError: Expected SQL evidence not found in pg_stat_statements: ['UPDATE ... SET phone = regexp_replace(...)', 'UPDATE ... SET email = lower(...)', ...\r\n\u001b[31mFAILED\u001b[0m ../tests/test_outputs.py::\u001b[1mtest_cleaned_csv_equals_customers_v1_csv\u001b[0m - AssertionError: CSV file does not exist: /app/data/cleaned_customers.csv\r\n\u001b[31mFAILED\u001b[0m ../tests/test_outputs.py::\u001b[1mtest_cleaned_csv_is_ordered_by_id\u001b[0m - AssertionError: CSV file does not exist: /app/data/cleaned_customers.csv\r\n\u001b[31mFAILED\u001b[0m ../tests/test_outputs.py::\u001b[1mtest_postgres_matches_customers_v1_csv\u001b[0m - psycopg2.errors.UndefinedTable: relation \"customers\" does not exist\r\n"]
