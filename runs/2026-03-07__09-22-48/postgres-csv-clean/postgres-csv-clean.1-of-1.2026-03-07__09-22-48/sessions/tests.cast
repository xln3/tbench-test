[38.681082, "o", "            host=\u001b[33m\"\u001b[39;49;00m\u001b[33mdb\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n            port=\u001b[94m5432\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n            user=\u001b[33m\"\u001b[39;49;00m\u001b[33mpostgres\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n            password=\u001b[33m\"\u001b[39;49;00m\u001b[33mpostgres\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n            database=\u001b[33m\"\u001b[39;49;00m\u001b[33mcustomers_db\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n        ) \u001b[94mas\u001b[39;49;00m conn:\u001b[90m\u001b[39;49;00m\r\n"]
[38.681175, "o", "            \u001b[94mwith\u001b[39;49;00m conn.cursor() \u001b[94mas\u001b[39;49;00m cur:\u001b[90m\u001b[39;49;00m\r\n>               cur.execute(\u001b[33m\"\u001b[39;49;00m\u001b[33mSELECT id, name, email, phone, city FROM customers;\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n"]
