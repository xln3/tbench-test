[38.670773, "o", "                user=\u001b[33m\"\u001b[39;49;00m\u001b[33mpostgres\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n                password=\u001b[33m\"\u001b[39;49;00m\u001b[33mpostgres\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n                database=\u001b[33m\"\u001b[39;49;00m\u001b[33mcustomers_db\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n            )\u001b[90m\u001b[39;49;00m\r\n            cursor = conn.cursor()\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n            \u001b[90m# Check if customers table exists\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            cursor.execute(\u001b[33m\"\"\"\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m            SELECT EXISTS (\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m                SELECT FROM information_schema.tables\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n"]
[38.670871, "o", "    \u001b[33m                WHERE table_name = \u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33mcustomers\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m            );\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m        \u001b[39;49;00m\u001b[33m\"\"\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n            result = cursor.fetchone()\u001b[90m\u001b[39;49;00m\r\n            table_exists = \u001b[96mbool\u001b[39;49;00m(result \u001b[95mand\u001b[39;49;00m result[\u001b[94m0\u001b[39;49;00m])\u001b[90m\u001b[39;49;00m\r\n            \u001b[94massert\u001b[39;49;00m table_exists, (\u001b[90m\u001b[39;49;00m\r\n                \u001b[33m\"\u001b[39;49;00m\u001b[33mPostgreSQL \u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33mcustomers\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33m table does not exist - agent may have cheated\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            )\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n            cursor.close()\u001b[90m\u001b[39;49;00m\r\n            conn.close()\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[94mexcept\u001b[39;49;00m \u001b[96mException\u001b[39;49;00m \u001b[94mas\u001b[39;49;00m e:\u001b[90m\u001b[39;49;00m\r\n>           \u001b[94massert\u001b[39;49;00m \u001b[94mFalse\u001b[39;49;00m, \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mCannot connect to PostgreSQL database: \u001b[39;49;00m\u001b[33m{\u001b[39;49;00me\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n"]
