[38.681357, "o", "\u001b[31m\u001b[1m___________________________________________________ test_pg_stat_statements_shows_cleaning_and_copy_queries ____________________________________________________\u001b[0m\r\n\r\n"]
[38.692219, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_pg_stat_statements_shows_cleaning_and_copy_queries\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"Assert that expected SQL statements were executed in Postgres\u001b[39;49;00m\r\n    \u001b[33m    (via pg_stat_statements).\"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Connect and query pg_stat_statements for our DB\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mwith\u001b[39;49;00m psycopg2.connect(\u001b[90m\u001b[39;49;00m\r\n            host=\u001b[33m\"\u001b[39;49;00m\u001b[33mdb\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n            port=\u001b[94m5432\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n            user=\u001b[33m\"\u001b[39;49;00m\u001b[33mpostgres\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n"]
[38.692367, "o", "            password=\u001b[33m\"\u001b[39;49;00m\u001b[33mpostgres\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n            database=\u001b[33m\"\u001b[39;49;00m\u001b[33mcustomers_db\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n        ) \u001b[94mas\u001b[39;49;00m conn:\u001b[90m\u001b[39;49;00m\r\n            \u001b[94mwith\u001b[39;49;00m conn.cursor() \u001b[94mas\u001b[39;49;00m cur:\u001b[90m\u001b[39;49;00m\r\n                \u001b[90m# Require pg_stat_statements to be enabled and installed\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n                cur.execute(\u001b[33m\"\u001b[39;49;00m\u001b[33mSHOW shared_preload_libraries;\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n                preload_libs_row = cur.fetchone()\u001b[90m\u001b[39;49;00m\r\n                preload_libs = (preload_libs_row[\u001b[94m0\u001b[39;49;00m] \u001b[95mor\u001b[39;49;00m \u001b[33m\"\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m) \u001b[94mif\u001b[39;49;00m preload_libs_row \u001b[94melse\u001b[39;49;00m \u001b[33m\"\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n                \u001b[94massert\u001b[39;49;00m \u001b[33m\"\u001b[39;49;00m\u001b[33mpg_stat_statements\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m \u001b[95min\u001b[39;49;00m preload_libs, (\u001b[90m\u001b[39;49;00m\r\n                    \u001b[33m\"\u001b[39;49;00m\u001b[33mpg_stat_statements not in shared_preload_libraries; \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n                    \u001b[33m\"\u001b[39;49;00m\u001b[33mensure DB starts with \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n                    \u001b[33m\"\u001b[39;49;00m\u001b[33m-c shared_preload_libraries=pg_stat_statements \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n                    \u001b[33m\"\u001b[39;49;00m\u001b[33mand recreate the data volume\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n                )\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n                cur.execute(\u001b[90m\u001b[39;49;00m\r\n                    \u001b[33m\"\u001b[39;49;00m\u001b[33mSELECT EXISTS (SELECT 1 FROM pg_extension WHERE extname=\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33mpg_stat_statements\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33m);\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n                )\u001b[90m\u001b[39;49;00m\r\n                row = cur.fetchone()\u001b[90m\u001b[39;49;00m\r\n"]
[38.69244, "o", "                has_ext = \u001b[96mbool\u001b[39;49;00m(row \u001b[95mand\u001b[39;49;00m row[\u001b[94m0\u001b[39;49;00m])\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n            \u001b[90m# Re-open cursor to read single row properly\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            \u001b[94mwith\u001b[39;49;00m conn.cursor() \u001b[94mas\u001b[39;49;00m cur2:\u001b[90m\u001b[39;49;00m\r\n                cur2.execute(\u001b[90m\u001b[39;49;00m\r\n                    \u001b[33m\"\u001b[39;49;00m\u001b[33mSELECT EXISTS (SELECT 1 FROM pg_extension WHERE extname=\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33mpg_stat_statements\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33m);\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n                )\u001b[90m\u001b[39;49;00m\r\n                row2 = cur2.fetchone()\u001b[90m\u001b[39;49;00m\r\n                has_ext = \u001b[96mbool\u001b[39;49;00m(row2 \u001b[95mand\u001b[39;49;00m row2[\u001b[94m0\u001b[39;49;00m])\u001b[90m\u001b[39;49;00m\r\n                \u001b[94massert\u001b[39;49;00m has_ext, (\u001b[90m\u001b[39;49;00m\r\n                    \u001b[33m\"\u001b[39;49;00m\u001b[33mpg_stat_statements extension is \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n"]
[38.6925, "o", "                    \u001b[33m\"\u001b[39;49;00m\u001b[33mnot installed (CREATE EXTENSION required)\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n                )\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n                \u001b[90m# Read recorded queries for current database\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n                cur2.execute(\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m                \u001b[39;49;00m\u001b[33m\"\"\"\u001b[39;49;00m\r\n    \u001b[33m                SELECT query\u001b[39;49;00m\r\n    \u001b[33m                FROM pg_stat_statements pss\u001b[39;49;00m\r\n    \u001b[33m                JOIN pg_database d ON d.oid = pss.dbid\u001b[39;49;00m\r\n"]
[38.692604, "o", "    \u001b[33m                WHERE d.datname = current_database();\u001b[39;49;00m\r\n    \u001b[33m                \"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n"]
[38.692679, "o", "                )\u001b[90m\u001b[39;49;00m\r\n                queries = \u001b[33m\"\u001b[39;49;00m\u001b[33m\\n\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m.join([row[\u001b[94m0\u001b[39;49;00m] \u001b[94mfor\u001b[39;49;00m row \u001b[95min\u001b[39;49;00m cur2.fetchall() \u001b[94mif\u001b[39;49;00m row \u001b[95mand\u001b[39;49;00m row[\u001b[94m0\u001b[39;49;00m]])\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[94mimport\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[04m\u001b[96mre\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        queries_compact = re.sub(\u001b[33mr\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m\\\u001b[39;49;00m\u001b[33ms+\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33m \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, queries.lower())\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Evidence for UPDATEs\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        has_update_phone = (\u001b[90m\u001b[39;49;00m\r\n            re.search(\u001b[90m\u001b[39;49;00m\r\n                \u001b[33mr\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mupdate\u001b[39;49;00m\u001b[33m\\\u001b[39;49;00m\u001b[33ms+.*customers.*set\u001b[39;49;00m\u001b[33m\\\u001b[39;49;00m\u001b[33ms+.*phone\u001b[39;49;00m\u001b[33m\\\u001b[39;49;00m\u001b[33ms*=\u001b[39;49;00m\u001b[33m\\\u001b[39;49;00m\u001b[33ms*regexp_replace\u001b[39;49;00m\u001b[33m\\\u001b[39;49;00m\u001b[33ms*\u001b[39;49;00m\u001b[33m\\\u001b[39;49;00m\u001b[33m(\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n                queries_compact,\u001b[90m\u001b[39;49;00m\r\n            )\u001b[90m\u001b[39;49;00m\r\n            \u001b[95mis\u001b[39;49;00m \u001b[95mnot\u001b[39;49;00m \u001b[94mNone\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        )\u001b[90m\u001b[39;49;00m\r\n        has_update_email = (\u001b[90m\u001b[39;49;00m\r\n            re.search(\u001b[90m\u001b[39;49;00m\r\n"]
[38.692739, "o", "                \u001b[33mr\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mupdate\u001b[39;49;00m\u001b[33m\\\u001b[39;49;00m\u001b[33ms+.*customers.*set\u001b[39;49;00m\u001b[33m\\\u001b[39;49;00m\u001b[33ms+.*email\u001b[39;49;00m\u001b[33m\\\u001b[39;49;00m\u001b[33ms*=\u001b[39;49;00m\u001b[33m\\\u001b[39;49;00m\u001b[33ms*lower\u001b[39;49;00m\u001b[33m\\\u001b[39;49;00m\u001b[33ms*\u001b[39;49;00m\u001b[33m\\\u001b[39;49;00m\u001b[33m(\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, queries_compact\u001b[90m\u001b[39;49;00m\r\n            )\u001b[90m\u001b[39;49;00m\r\n            \u001b[95mis\u001b[39;49;00m \u001b[95mnot\u001b[39;49;00m \u001b[94mNone\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        )\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Evidence for DELETEs (either duplicate removal USING/delete missing contact WHERE)\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        has_delete_using = (\u001b[90m\u001b[39;49;00m\r\n            re.search(\u001b[33mr\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mdelete\u001b[39;49;00m\u001b[33m\\\u001b[39;49;00m\u001b[33ms+from\u001b[39;49;00m\u001b[33m\\\u001b[39;49;00m\u001b[33ms+.*customers.*using\u001b[39;49;00m\u001b[33m\\\u001b[39;49;00m\u001b[33ms+.*customers\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, queries_compact)\u001b[90m\u001b[39;49;00m\r\n            \u001b[95mis\u001b[39;49;00m \u001b[95mnot\u001b[39;49;00m \u001b[94mNone\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        )\u001b[90m\u001b[39;49;00m\r\n        has_delete_missing = (\u001b[90m\u001b[39;49;00m\r\n"]
[38.692796, "o", "            re.search(\u001b[33mr\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mdelete\u001b[39;49;00m\u001b[33m\\\u001b[39;49;00m\u001b[33ms+from\u001b[39;49;00m\u001b[33m\\\u001b[39;49;00m\u001b[33ms+.*customers.*where.*(email|phone)\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, queries_compact)\u001b[90m\u001b[39;49;00m\r\n            \u001b[95mis\u001b[39;49;00m \u001b[95mnot\u001b[39;49;00m \u001b[94mNone\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        )\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Evidence for client-side \\COPY:\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# - Import appears on server as COPY ... FROM STDIN\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# - Export appears on server as COPY ... TO STDOUT (even if client gave a file path)\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        has_copy_from_stdin = (\u001b[90m\u001b[39;49;00m\r\n"]
[38.692855, "o", "            re.search(\u001b[33mr\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mcopy\u001b[39;49;00m\u001b[33m\\\u001b[39;49;00m\u001b[33ms+.*customers.*from\u001b[39;49;00m\u001b[33m\\\u001b[39;49;00m\u001b[33ms+stdin\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, queries_compact) \u001b[95mis\u001b[39;49;00m \u001b[95mnot\u001b[39;49;00m \u001b[94mNone\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        )\u001b[90m\u001b[39;49;00m\r\n        has_copy_to_stdout = re.search(\u001b[33mr\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mcopy\u001b[39;49;00m\u001b[33m\\\u001b[39;49;00m\u001b[33ms+.*to\u001b[39;49;00m\u001b[33m\\\u001b[39;49;00m\u001b[33ms+stdout\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, queries_compact) \u001b[95mis\u001b[39;49;00m \u001b[95mnot\u001b[39;49;00m \u001b[94mNone\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        missing = []\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mif\u001b[39;49;00m \u001b[95mnot\u001b[39;49;00m has_update_phone:\u001b[90m\u001b[39;49;00m\r\n            missing.append(\u001b[33m\"\u001b[39;49;00m\u001b[33mUPDATE ... SET phone = regexp_replace(...)\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n"]
[38.69291, "o", "        \u001b[94mif\u001b[39;49;00m \u001b[95mnot\u001b[39;49;00m has_update_email:\u001b[90m\u001b[39;49;00m\r\n            missing.append(\u001b[33m\"\u001b[39;49;00m\u001b[33mUPDATE ... SET email = lower(...)\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mif\u001b[39;49;00m \u001b[95mnot\u001b[39;49;00m (has_delete_using \u001b[95mor\u001b[39;49;00m has_delete_missing):\u001b[90m\u001b[39;49;00m\r\n            missing.append(\u001b[90m\u001b[39;49;00m\r\n                \u001b[33m\"\u001b[39;49;00m\u001b[33mDELETE ... (USING customers ...) or DELETE ... WHERE ... (missing contact)\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            )\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mif\u001b[39;49;00m \u001b[95mnot\u001b[39;49;00m has_copy_from_stdin:\u001b[90m\u001b[39;49;00m\r\n"]
[38.692976, "o", "            missing.append(\u001b[33m\"\u001b[39;49;00m\u001b[33mCOPY ... FROM STDIN (evidence of client-side \u001b[39;49;00m\u001b[33m\\\\\u001b[39;49;00m\u001b[33mCOPY import)\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mif\u001b[39;49;00m \u001b[95mnot\u001b[39;49;00m has_copy_to_stdout:\u001b[90m\u001b[39;49;00m\r\n            missing.append(\u001b[33m\"\u001b[39;49;00m\u001b[33mCOPY ... TO STDOUT (evidence of client-side \u001b[39;49;00m\u001b[33m\\\\\u001b[39;49;00m\u001b[33mCOPY export)\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n>       \u001b[94massert\u001b[39;49;00m \u001b[95mnot\u001b[39;49;00m missing, (\u001b[90m\u001b[39;49;00m\r\n            \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mExpected SQL evidence not found in pg_stat_statements: \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mmissing\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        )\u001b[90m\u001b[39;49;00m\r\n"]
[38.693032, "o", "\u001b[1m\u001b[31mE       AssertionError: Expected SQL evidence not found in pg_stat_statements: ['UPDATE ... SET phone = regexp_replace(...)', 'UPDATE ... SET email = lower(...)', 'DELETE ... (USING customers ...) or DELETE ... WHERE ... (missing contact)', 'COPY ... FROM STDIN (evidence of client-side \\\\COPY import)', 'COPY ... TO STDOUT (evidence of client-side \\\\COPY export)']\u001b[0m\r\n\u001b[1m\u001b[31mE       assert not ['UPDATE ... SET phone = regexp_replace(...)', 'UPDATE ... SET email = lower(...)', 'DELETE ... (USING customers ...) ... ... FROM STDIN (evidence of client-side \\\\COPY import)', 'COPY ... TO STDOUT (evidence of client-side \\\\COPY export)']\u001b[0m\r\n"]
[38.693091, "o", "\r\n\u001b[1m\u001b[31m/tests/test_outputs.py\u001b[0m:458: AssertionError\r\n"]
[38.693222, "o", "\u001b[31m\u001b[1m___________________________________________________________ test_cleaned_csv_equals_customers_v1_csv ___________________________________________________________\u001b[0m\r\n"]
[38.693251, "o", "\r\n"]
[38.694176, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_cleaned_csv_equals_customers_v1_csv\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"Ensure cleaned_customers.csv content is identical to customers_v1.csv\u001b[39;49;00m\r\n    \u001b[33m    (after normalization).\"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        cleaned_csv_path = Path(\u001b[33m\"\u001b[39;49;00m\u001b[33m/app/data/cleaned_customers.csv\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n"]
[38.694216, "o", "        baseline_csv_path = Path(\u001b[33m\"\u001b[39;49;00m\u001b[33m/app/data/customers_v1.csv\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n>       \u001b[94massert\u001b[39;49;00m cleaned_csv_path.exists(), \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mCSV file does not exist: \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mcleaned_csv_path\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31mE       AssertionError: CSV file does not exist: /app/data/cleaned_customers.csv\u001b[0m\r\n"]
[38.694244, "o", "\u001b[1m\u001b[31mE       assert False\u001b[0m\r\n\u001b[1m\u001b[31mE        +  where False = exists()\u001b[0m\r\n"]
[38.694271, "o", "\u001b[1m\u001b[31mE        +    where exists = PosixPath('/app/data/cleaned_customers.csv').exists\u001b[0m\r\n\r\n"]
