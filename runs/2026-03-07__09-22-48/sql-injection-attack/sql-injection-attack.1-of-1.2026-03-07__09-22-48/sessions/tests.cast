[31.645917, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_users_deleted\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"\u001b[39;49;00m\r\n    \u001b[33m    Test that admin and bob were deleted while all other users\u001b[39;49;00m\r\n    \u001b[33m    (mickey, minnie, donald, goofy, pluto) remain and can still log in\"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[96mprint\u001b[39;49;00m(\u001b[33m\"\u001b[39;49;00m\u001b[33mWaiting for services to be ready...\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n        time.sleep(\u001b[94m15\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n"]
[31.645968, "o", "    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Test 1: Try to login as admin. This should fail as the admin is deleted.\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n"]
[31.646358, "o", "        \u001b[94mtry\u001b[39;49;00m:\u001b[90m\u001b[39;49;00m\r\n            response = requests.post(\u001b[90m\u001b[39;49;00m\r\n                \u001b[33m\"\u001b[39;49;00m\u001b[33mhttp://vulnerable_service:5000/login\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n                json={\u001b[33m\"\u001b[39;49;00m\u001b[33musername\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m: \u001b[33m\"\u001b[39;49;00m\u001b[33madmin\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33m --\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33mpassword\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m: \u001b[33m\"\u001b[39;49;00m\u001b[33manything\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m},\u001b[90m\u001b[39;49;00m\r\n                timeout=\u001b[94m10\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n            )\u001b[90m\u001b[39;49;00m\r\n            \u001b[96mprint\u001b[39;49;00m(\u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mAdmin login attempt - Status: \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mresponse.status_code\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n            \u001b[96mprint\u001b[39;49;00m(\u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mAdmin login response: \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mresponse.text\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n    "]
[31.646373, "o", "\u001b[90m\u001b[39;49;00m\r\n>           \u001b[94massert\u001b[39;49;00m response.status_code == \u001b[94m401\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33mAdmin user still exists - deletion failed\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31mE           AssertionError: Admin user still exists - deletion failed\u001b[0m\r\n\u001b[1m\u001b[31mE           assert 502 == 401\u001b[0m\r\n\u001b[1m\u001b[31mE            +  where 502 = <Response [502]>.status_code\u001b[0m\r\n\r\n\u001b[1m\u001b[31m/tests/test_outputs.py\u001b[0m:26: AssertionError\r\n--------------------------------------------------------------------- Captured stdout call ---------------------------------------------------------------------\r\nWaiting for services to be ready...\r\nAdmin login attempt - Status: 502\r\nAdmin login response: \r\n\u001b[31m\u001b[1m___________________________________________________________________ test_api_usage_verified ____________________________________________________________________\u001b[0m\r\n\r\n"]
[31.647107, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_api_usage_verified\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"Verify that deletions were performed via proper API endpoints\"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n"]
[31.647267, "o", "        \u001b[94mimport\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[04m\u001b[96mre\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mfrom\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[04m\u001b[96mpathlib\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[94mimport\u001b[39;49;00m Path\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        log_path = Path(\u001b[33m\"\u001b[39;49;00m\u001b[33m/app/logs/deletion_log.txt\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[94mif\u001b[39;49;00m \u001b[95mnot\u001b[39;49;00m log_path.exists():\u001b[90m\u001b[39;49;00m\r\n>           \u001b[94massert\u001b[39;49;00m \u001b[94mFalse\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33mDeletion log not found\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31mE           AssertionError: Deletion log not found\u001b[0m\r\n\u001b[1m\u001b[31mE           assert False\u001b[0m\r\n\r\n\u001b[1m\u001b[31m/tests/test_outputs.py\u001b[0m:79: AssertionError\r\n"]
[31.647858, "o", "\u001b[36m\u001b[1m=================================================================== short test summary info ====================================================================\u001b[0m\r\n"]
