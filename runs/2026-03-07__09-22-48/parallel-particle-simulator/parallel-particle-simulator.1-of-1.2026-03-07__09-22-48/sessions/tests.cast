[35.283575, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_performance_timing_recorded\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"Verify that all implementations record execution times in summary files.\"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Read timing data from summary files\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        serial_time = \u001b[94mNone\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        openmp_time = \u001b[94mNone\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        mpi_time = \u001b[94mNone\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n"]
[35.283709, "o", "        \u001b[90m# Get serial time\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        serial_summary = Path(\u001b[33m\"\u001b[39;49;00m\u001b[33m/app/serial_summary.txt\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mif\u001b[39;49;00m serial_summary.exists():\u001b[90m\u001b[39;49;00m\r\n            content = serial_summary.read_text().strip().split()\u001b[90m\u001b[39;49;00m\r\n            serial_time = \u001b[96mfloat\u001b[39;49;00m(content[-\u001b[94m1\u001b[39;49;00m])\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Get OpenMP time (2 threads)\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        openmp_summary = Path(\u001b[33m\"\u001b[39;49;00m\u001b[33m/app/openmp_summary.txt\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mif\u001b[39;49;00m openmp_summary.exists():\u001b[90m\u001b[39;49;00m\r\n            content = openmp_summary.read_text().strip().split()\u001b[90m\u001b[39;49;00m\r\n            openmp_time = \u001b[96mfloat\u001b[39;49;00m(content[-\u001b[94m1\u001b[39;49;00m])\u001b[90m\u001b[39;49;00m\r\n            threads = \u001b[96mint\u001b[39;49;00m(content[\u001b[94m1\u001b[39;49;00m])\u001b[90m\u001b[39;49;00m\r\n            \u001b[94massert\u001b[39;49;00m threads == \u001b[94m2\u001b[39;49;00m, \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mExpected 2 threads, got \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mthreads\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n"]
