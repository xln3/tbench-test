dlines()\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n                    \u001b[90m# Parse header\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n                    header = lines[\u001b[94m0\u001b[39;49;00m].strip().split()\u001b[90m\u001b[39;49;00m\r\n                    n = \u001b[96mint\u001b[39;49;00m(header[\u001b[94m0\u001b[39;49;00m])\u001b[90m\u001b[39;49;00m\r\n                    particle_counts[impl] = n\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n"]
