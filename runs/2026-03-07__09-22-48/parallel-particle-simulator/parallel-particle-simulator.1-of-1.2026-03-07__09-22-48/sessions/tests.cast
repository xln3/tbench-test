[35.218998, "o", "=========================================================================== FAILURES ===========================================================================\r\n\u001b[31m\u001b[1m______________________________________________________________ test_particle_interactions_correct ______________________________________________________________\u001b[0m\r\n\r\n"]
[35.258331, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_particle_interactions_correct\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"Check particles interact correctly based on min/avg distances from console.\"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Run executables and check their console output directly\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        executables = [\u001b[33m\"\u001b[39;49;00m\u001b[33mserial\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33mopenmp\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33mmpi\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m]\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[94mfor\u001b[39;49;00m exe \u001b[95min\u001b[39;49;00m executables:\u001b[90m\u001b[39;49;00m\r\n            \u001b[94mif\u001b[39;49;00m exe == \u001b[33m\"\u001b[39;49;00m\u001b[33mmpi\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m:\u001b[90m\u001b[39;49;00m\r\n                result = subprocess.run(\u001b[90m\u001b[39;49;00m\r\n                    [\u001b[90m\u001b[39;49;00m\r\n                        \u001b[33m\"\u001b[39;49;00m\u001b[33mmpirun\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n                        \u001b[33m\"\u001b[39;49;00m\u001b[33m-np\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n                        \u001b[33m\"\u001b[39;49;00m\u001b[33m2\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n                        \u001b[33m\"\u001b[39;49;00m\u001b[33m--allow-run-as-root\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n                        \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m/app/\u001b[39;49;00m\u001b[33m{\u001b[39;49;00mexe\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n                        \u001b[33m\"\u001b[39;49;00m\u001b[33m-n\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n                        \u001b[33m\"\u001b[39;49;00m\u001b[33m100\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n                    ],\u001b[90m\u001b[39;49;00m\r\n                    capture_output=\u001b[94mTrue\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n                    text=\u001b[94mTrue\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n                    env={\u001b[90m\u001b[39;49;00m\r\n"]
[35.258556, "o", "                        **os.environ,\u001b[90m\u001b[39;49;00m\r\n                        \u001b[33m\"\u001b[39;49;00m\u001b[33mOMPI_ALLOW_RUN_AS_ROOT\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m: \u001b[33m\"\u001b[39;49;00m\u001b[33m1\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n                        \u001b[33m\"\u001b[39;49;00m\u001b[33mOMPI_ALLOW_RUN_AS_ROOT_CONFIRM\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m: \u001b[33m\"\u001b[39;49;00m\u001b[33m1\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n                    },\u001b[90m\u001b[39;49;00m\r\n                )\u001b[90m\u001b[39;49;00m\r\n            \u001b[94melif\u001b[39;49;00m exe == \u001b[33m\"\u001b[39;49;00m\u001b[33mopenmp\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m:\u001b[90m\u001b[39;49;00m\r\n                result = subprocess.run(\u001b[90m\u001b[39;49;00m\r\n                    [\u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m/app/\u001b[39;49;00m\u001b[33m{\u001b[39;49;00mexe\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33m-n\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33m100\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33m-p\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33m2\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m], capture_output=\u001b[94mTrue\u001b[39;49;00m, text=\u001b[94mTrue\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n                )\u001b[90m\u001b[39;49;00m\r\n            \u001b[94melse\u001b[39;49;00m:\u001b[90m\u001b[39;49;00m\r\n                result = subprocess.run(\u001b[90m\u001b[39;49;00m\r\n                    [\u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m/app/\u001b[39;49;00m\u001b[33m{\u001b[39;49;00mexe\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33m-n\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33m100\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m], capture_output=\u001b[94mTrue\u001b[39;49;00m, text=\u001b[94mTrue\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n                )\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n            \u001b[94massert\u001b[39;49;00m result.returncode == \u001b[94m0\u001b[39;49;00m, \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m{\u001b[39;49;00mexe\u001b[33m}\u001b[39;49;00m\u001b[33m failed to run\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n            \u001b[90m# Extract absmin and absavg values from stdout\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            absmin_match = re.search(\u001b[33mr\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mabsmin\u001b[39;49;00m\u001b[33m\\\u001b[39;49;00m\u001b[33ms*=\u001b[39;49;00m\u001b[33m\\\u001b[39;49;00m\u001b[33ms*([\u001b[39;49;00m\u001b[33m\\\u001b[39;49;00m\u001b[33md.]+)\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, result.stdout)\u001b[90m\u001b[39;49;00m\r\n            absavg_match = re.search(\u001b[33mr\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mabsavg\u001b[39;49;00m\u001b[33m\\\u001b[39;49;00m\u001b[33ms*=\u001b[39;49;00m\u001b[33m\\\u001b[39;49;00m\u001b[33ms*([\u001b[39;49;00m\u001b[33m\\\u001b[39;49;00m\u001b[33md.]+)\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, result.stdout)\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n            \u001b[94massert\u001b[39;49;00m absmin_match, \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mCould not find absmin value in \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mexe\u001b[33m}\u001b[39;49;00m\u001b[33m output\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            \u001b[94massert\u001b[39;49;00m absavg_match, \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mCould not find absavg value in \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mexe\u001b[33m}\u001b[39;49;00m\u001b[33m output\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n            absmin = \u001b[96mfloat\u001b[39;49;00m(absmin_match.group(\u001b[94m1\u001b[39;49;00m))\u001b[90m\u001b[39;49;00m\r\n            absavg = \u001b[96mfloat\u001b[39;49;00m(absavg_match.group(\u001b[94m1\u001b[39;49;00m))\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n            \u001b[90m# According to task requirements:\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            \u001b[90m# - absmin should be > 0.4 for correct simulation\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            \u001b[90m# - absavg should be > 0.7 for correct simulation\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n>           \u001b[94massert\u001b[39;49;00m absmin >= \u001b[94m0.4\u001b[39;49;00m, (\u001b[90m\u001b[39;49;00m\r\n                \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mMinimum distance \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mabsmin\u001b[33m}\u001b[39;49;00m\u001b[33m in \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mexe\u001b[33m}\u001b[39;49;00m\u001b[33m is too small. \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n                \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mParticles may not be interacting correctly.\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            )\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31mE           AssertionError: Minimum distance 0.1276 in openmp is too small. Particles may not be interacting correctly.\u001b[0m\r\n\u001b[1m\u001b[31mE           assert 0.1276 >= 0.4\u001b[0m\r\n\r\n\u001b[1m\u001b[31m/tests/test_outputs.py\u001b[0m:210: AssertionError\r\n"]
[35.258685, "o", "\u001b[31m\u001b[1m________________________________________________________________ test_executables_actually_run _________________________________________________________________\u001b[0m\r\n\r\n"]
[35.262941, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_executables_actually_run\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"Check that executables can be run with basic options.\"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Test serial version\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        serial_result = subprocess.run(\u001b[90m\u001b[39;49;00m\r\n            [\u001b[33m\"\u001b[39;49;00m\u001b[33m/app/serial\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33m-n\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33m10\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m], capture_output=\u001b[94mTrue\u001b[39;49;00m, text=\u001b[94mTrue\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        )\u001b[90m\u001b[39;49;00m\r\n        \u001b[94massert\u001b[39;49;00m serial_result.returncode == \u001b[94m0\u001b[39;49;00m, (\u001b[90m\u001b[39;49;00m\r\n            \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mSerial executable failed to run: \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mserial_result.stderr\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        )\u001b[90m\u001b[39;49;00m\r\n        \u001b[94massert\u001b[39;49;00m re.search(\u001b[33mr\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mn\u001b[39;49;00m\u001b[33m\\\u001b[39;49;00m\u001b[33ms*=\u001b[39;49;00m\u001b[33m\\\u001b[39;49;00m\u001b[33ms*10\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, serial_result.stdout), (\u001b[90m\u001b[39;49;00m\r\n            \u001b[33m\"\u001b[39;49;00m\u001b[33mSerial output doesn\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33mt contain expected particle count\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        )\u001b[90m\u001b[39;49;00m\r\n"]
[35.263084, "o", "        \u001b[94massert\u001b[39;49;00m \u001b[33m\"\u001b[39;49;00m\u001b[33msimulation time\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m \u001b[95min\u001b[39;49;00m serial_result.stdout, (\u001b[90m\u001b[39;49;00m\r\n            \u001b[33m\"\u001b[39;49;00m\u001b[33mSerial output doesn\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33mt contain simulation time\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        )\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Test OpenMP version\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        openmp_result = subprocess.run(\u001b[90m\u001b[39;49;00m\r\n            [\u001b[33m\"\u001b[39;49;00m\u001b[33m/app/openmp\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33m-n\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33m10\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33m-p\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33m2\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m], capture_output=\u001b[94mTrue\u001b[39;49;00m, text=\u001b[94mTrue\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        )\u001b[90m\u001b[39;49;00m\r\n        \u001b[94massert\u001b[39;49;00m openmp_result.returncode == \u001b[94m0\u001b[39;49;00m, (\u001b[90m\u001b[39;49;00m\r\n            \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mOpenMP executable failed to run: \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mopenmp_result.stderr\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        )\u001b[90m\u001b[39;49;00m\r\n        \u001b[94massert\u001b[39;49;00m re.search(\u001b[33mr\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mn\u001b[39;49;00m\u001b[33m\\\u001b[39;49;00m\u001b[33ms*=\u001b[39;49;00m\u001b[33m\\\u001b[39;49;00m\u001b[33ms*10\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, openmp_result.stdout), (\u001b[90m\u001b[39;49;00m\r\n            \u001b[33m\"\u001b[39;49;00m\u001b[33mOpenMP output doesn\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33mt contain expected particle count\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        )\u001b[90m\u001b[39;49;00m\r\n        \u001b[94massert\u001b[39;49;00m re.search(\u001b[33mr\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mthreads\u001b[39;49;00m\u001b[33m\\\u001b[39;49;00m\u001b[33ms*=\u001b[39;49;00m\u001b[33m\\\u001b[39;49;00m\u001b[33ms*2\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, openmp_result.stdout), (\u001b[90m\u001b[39;49;00m\r\n            \u001b[33m\"\u001b[39;49;00m\u001b[33mOpenMP output doesn\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33mt contain expected thread count\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        )\u001b[90m\u001b[39;49;00m\r\n"]
[35.263163, "o", "        \u001b[94massert\u001b[39;49;00m \u001b[33m\"\u001b[39;49;00m\u001b[33msimulation time\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m \u001b[95min\u001b[39;49;00m openmp_result.stdout, (\u001b[90m\u001b[39;49;00m\r\n            \u001b[33m\"\u001b[39;49;00m\u001b[33mOpenMP output doesn\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33mt contain simulation time\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        )\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Test MPI version with 2 processes\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        mpi_result = subprocess.run(\u001b[90m\u001b[39;49;00m\r\n            [\u001b[33m\"\u001b[39;49;00m\u001b[33mmpirun\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33m-np\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33m2\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33m--allow-run-as-root\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33m/app/mpi\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33m-n\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33m10\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m],\u001b[90m\u001b[39;49;00m\r\n            capture_output=\u001b[94mTrue\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n            text=\u001b[94mTrue\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n            env={\u001b[90m\u001b[39;49;00m\r\n                **os.environ,\u001b[90m\u001b[39;49;00m\r\n                \u001b[33m\"\u001b[39;49;00m\u001b[33mOMPI_ALLOW_RUN_AS_ROOT\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m: \u001b[33m\"\u001b[39;49;00m\u001b[33m1\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n                \u001b[33m\"\u001b[39;49;00m\u001b[33mOMPI_ALLOW_RUN_AS_ROOT_CONFIRM\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m: \u001b[33m\"\u001b[39;49;00m\u001b[33m1\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n            },\u001b[90m\u001b[39;49;00m\r\n        )\u001b[90m\u001b[39;49;00m\r\n>       \u001b[94massert\u001b[39;49;00m mpi_result.returncode == \u001b[94m0\u001b[39;49;00m, (\u001b[90m\u001b[39;49;00m\r\n            \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mMPI executable failed to run: \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mmpi_result.stderr\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        )\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31mE       AssertionError: MPI executable failed to run: [mpiexec@866d8d21b650] match_arg (lib/utils/args.c:166): unrecognized argument allow-run-as-root\u001b[0m\r\n\u001b[1m\u001b[31mE         [mpiexec@866d8d21b650] HYDU_parse_array (lib/utils/args.c:181): argument matching returned error\u001b[0m\r\n\u001b[1m\u001b[31mE         [mpiexec@866d8d21b650] parse_args (mpiexec/get_parameters.c:313): error parsing input array\u001b[0m\r\n\u001b[1m\u001b[31mE         [mpiexec@866d8d21b650] HYD_uii_mpx_get_parameters (mpiexec/get_parameters.c:48): unable to parse user arguments\u001b[0m\r\n\u001b[1m\u001b[31mE         [mpiexec@866d8d21b650] main (mpiexec/mpiexec.c:54): error parsing parameters\u001b[0m\r\n\u001b[1m\u001b[31mE         \u001b[0m\r\n"]
[35.263231, "o", "\u001b[1m\u001b[31mE       assert 255 == 0\u001b[0m\r\n\u001b[1m\u001b[31mE        +  where 255 = CompletedProcess(args=['mpirun', '-np', '2', '--allow-run-as-root', '/app/mpi', '-n', '10'], returncode=255, stdout=''...c:48): unable to parse user arguments\\n[mpiexec@866d8d21b650] main (mpiexec/mpiexec.c:54): error parsing parameters\\n').returncode\u001b[0m\r\n\r\n\u001b[1m\u001b[31m/tests/test_outputs.py\u001b[0m:265: AssertionError\r\n"]
[35.263348, "o", "\u001b[31m\u001b[1m__________________________________________________________________ test_command_line_options ___________________________________________________________________\u001b[0m\r\n\r\n"]
[35.271653, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_command_line_options\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"Check that executables support required command-line options.\"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mimport\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[04m\u001b[96mtempfile\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[94mwith\u001b[39;49;00m tempfile.TemporaryDirectory() \u001b[94mas\u001b[39;49;00m tmpdir:\u001b[90m\u001b[39;49;00m\r\n            \u001b[90m# Test -o option for output file\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            output_file = \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m{\u001b[39;49;00mtmpdir\u001b[33m}\u001b[39;49;00m\u001b[33m/test_output.txt\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            summary_file = \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m{\u001b[39;49;00mtmpdir\u001b[33m}\u001b[39;49;00m\u001b[33m/test_summary.txt\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n            \u001b[90m# Test serial with -o and -s options\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            result = subprocess.run(\u001b[90m\u001b[39;49;00m\r\n                [\u001b[33m\"\u001b[39;49;00m\u001b[33m/app/serial\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33m-n\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33m10\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33m-o\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, output_file, \u001b[33m\"\u001b[39;49;00m\u001b[33m-s\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, summary_file],\u001b[90m\u001b[39;49;00m\r\n                capture_output=\u001b[94mTrue\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n                text=\u001b[94mTrue\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n            )\u001b[90m\u001b[39;49;00m\r\n"]
[35.271891, "o", "            \u001b[94massert\u001b[39;49;00m result.returncode == \u001b[94m0\u001b[39;49;00m, (\u001b[90m\u001b[39;49;00m\r\n                \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mSerial failed with -o and -s options: \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mresult.stderr\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            )\u001b[90m\u001b[39;49;00m\r\n            \u001b[94massert\u001b[39;49;00m Path(output_file).exists(), (\u001b[90m\u001b[39;49;00m\r\n                \u001b[33m\"\u001b[39;49;00m\u001b[33mSerial didn\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33mt create output file with -o option\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            )\u001b[90m\u001b[39;49;00m\r\n            \u001b[94massert\u001b[39;49;00m Path(summary_file).exists(), (\u001b[90m\u001b[39;49;00m\r\n                \u001b[33m\"\u001b[39;49;00m\u001b[33mSerial didn\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33mt create summary file with -s option\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            )\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n            \u001b[90m# Verify output file format\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            \u001b[94mwith\u001b[39;49;00m \u001b[96mopen\u001b[39;49;00m(output_file, \u001b[33m\"\u001b[39;49;00m\u001b[33mr\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m) \u001b[94mas\u001b[39;49;00m f:\u001b[90m\u001b[39;49;00m\r\n                lines = f.readlines()\u001b[90m\u001b[39;49;00m\r\n                \u001b[94massert\u001b[39;49;00m \u001b[96mlen\u001b[39;49;00m(lines) > \u001b[94m1\u001b[39;49;00m, (\u001b[90m\u001b[39;49;00m\r\n                    \u001b[33m\"\u001b[39;49;00m\u001b[33mOutput file should have header and particle positions\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n                )\u001b[90m\u001b[39;49;00m\r\n                header = lines[\u001b[94m0\u001b[39;49;00m].strip().split()\u001b[90m\u001b[39;49;00m\r\n                \u001b[94massert\u001b[39;49;00m \u001b[96mlen\u001b[39;49;00m(header) == \u001b[94m2\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33mHeader should have two values (n and size)\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n                \u001b[94massert\u001b[39;49;00m header[\u001b[94m0\u001b[39;49;00m] == \u001b[33m\"\u001b[39;49;00m\u001b[33m10\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33mHeader should contain correct particle count\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n            \u001b[90m# Verify summary file format\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            \u001b[94mwith\u001b[39;49;00m \u001b[96mopen\u001b[39;49;00m(summary_file, \u001b[33m\"\u001b[39;49;00m\u001b[33mr\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m) \u001b[94mas\u001b[39;49;00m f:\u001b[90m\u001b[39;49;00m\r\n                content = f.read().strip().split()\u001b[90m\u001b[39;49;00m\r\n                \u001b[94massert\u001b[39;49;00m \u001b[96mlen\u001b[39;49;00m(content) == \u001b[94m2\u001b[39;49;00m, (\u001b[90m\u001b[39;49;00m\r\n                    \u001b[33m\"\u001b[39;49;00m\u001b[33mSerial summary should have two values (n and time)\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n                )\u001b[90m\u001b[39;49;00m\r\n                \u001b[94massert\u001b[39;49;00m content[\u001b[94m0\u001b[39;49;00m] == \u001b[33m\"\u001b[39;49;00m\u001b[33m10\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33mSummary should contain correct particle count\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n"]
[35.272018, "o", "            \u001b[90m# Test OpenMP with -o and -s options\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            openmp_output_file = \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m{\u001b[39;49;00mtmpdir\u001b[33m}\u001b[39;49;00m\u001b[33m/test_openmp_output.txt\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            openmp_summary_file = \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m{\u001b[39;49;00mtmpdir\u001b[33m}\u001b[39;49;00m\u001b[33m/test_openmp_summary.txt\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n            result = subprocess.run(\u001b[90m\u001b[39;49;00m\r\n                [\u001b[90m\u001b[39;49;00m\r\n                    \u001b[33m\"\u001b[39;49;00m\u001b[33m/app/openmp\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n                    \u001b[33m\"\u001b[39;49;00m\u001b[33m-n\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n                    \u001b[33m\"\u001b[39;49;00m\u001b[33m10\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n                    \u001b[33m\"\u001b[39;49;00m\u001b[33m-p\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n                    \u001b[33m\"\u001b[39;49;00m\u001b[33m2\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n                    \u001b[33m\"\u001b[39;49;00m\u001b[33m-o\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n                    openmp_output_file,\u001b[90m\u001b[39;49;00m\r\n                    \u001b[33m\"\u001b[39;49;00m\u001b[33m-s\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n                    openmp_summary_file,\u001b[90m\u001b[39;49;00m\r\n                ],\u001b[90m\u001b[39;49;00m\r\n                capture_output=\u001b[94mTrue\u001b[39;49;00m,\u001b[90m\u001b[