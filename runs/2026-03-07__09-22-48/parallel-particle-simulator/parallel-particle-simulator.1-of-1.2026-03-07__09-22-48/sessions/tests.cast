[35.279666, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_parallel_implementations_consistent\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"Check that all three implementations produce consistent physics results.\"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Run all implementations multiple times and collect averaged results\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        num_runs = \u001b[94m5\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        results = {\u001b[90m\u001b[39;49;00m\r\n            \u001b[33m\"\u001b[39;49;00m\u001b[33mserial\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m: {\u001b[33m\"\u001b[39;49;00m\u001b[33mabsmin\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m: [], \u001b[33m\"\u001b[39;49;00m\u001b[33mabsavg\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m: []},\u001b[90m\u001b[39;49;00m\r\n            \u001b[33m\"\u001b[39;49;00m\u001b[33mopenmp\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m: {\u001b[33m\"\u001b[39;49;00m\u001b[33mabsmin\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m: [], \u001b[33m\"\u001b[39;49;00m\u001b[33mabsavg\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m: []},\u001b[90m\u001b[39;49;00m\r\n            \u001b[33m\"\u001b[39;49;00m\u001b[33mmpi\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m: {\u001b[33m\"\u001b[39;49;00m\u001b[33mabsmin\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m: [], \u001b[33m\"\u001b[39;49;00m\u001b[33mabsavg\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m: []},\u001b[90m\u001b[39;49;00m\r\n        }\u001b[90m\u001b[39;49;00m\r\n"]
[35.279857, "o", "    \u001b[90m\u001b[39;49;00m\r\n        \u001b[94mfor\u001b[39;49;00m run \u001b[95min\u001b[39;49;00m \u001b[96mrange\u001b[39;49;00m(num_runs):\u001b[90m\u001b[39;49;00m\r\n            \u001b[90m# Run serial\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            serial_result = subprocess.run(\u001b[90m\u001b[39;49;00m\r\n                [\u001b[33m\"\u001b[39;49;00m\u001b[33m/app/serial\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33m-n\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33m100\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m], capture_output=\u001b[94mTrue\u001b[39;49;00m, text=\u001b[94mTrue\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            )\u001b[90m\u001b[39;49;00m\r\n            \u001b[94mif\u001b[39;49;00m serial_result.returncode == \u001b[94m0\u001b[39;49;00m:\u001b[90m\u001b[39;49;00m\r\n                absmin_match = re.search(\u001b[33mr\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mabsmin\u001b[39;49;00m\u001b[33m\\\u001b[39;49;00m\u001b[33ms*=\u001b[39;49;00m\u001b[33m\\\u001b[39;49;00m\u001b[33ms*([\u001b[39;49;00m\u001b[33m\\\u001b[39;49;00m\u001b[33md.]+)\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, serial_result.stdout)\u001b[90m\u001b[39;49;00m\r\n                absavg_match = re.search(\u001b[33mr\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mabsavg\u001b[39;49;00m\u001b[33m\\\u001b[39;49;00m\u001b[33ms*=\u001b[39;49;00m\u001b[33m\\\u001b[39;49;00m\u001b[33ms*([\u001b[39;49;00m\u001b[33m\\\u001b[39;49;00m\u001b[33md.]+)\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, serial_result.stdout)\u001b[90m\u001b[39;49;00m\r\n                \u001b[94mif\u001b[39;49;00m absmin_match \u001b[95mand\u001b[39;49;00m absavg_match:\u001b[90m\u001b[39;49;00m\r\n                    results[\u001b[33m\"\u001b[39;49;00m\u001b[33mserial\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m][\u001b[33m\"\u001b[39;49;00m\u001b[33mabsmin\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m].append(\u001b[96mfloat\u001b[39;49;00m(absmin_match.group(\u001b[94m1\u001b[39;49;00m)))\u001b[90m\u001b[39;49;00m\r\n                    results[\u001b[33m\"\u001b[39;49;00m\u001b[33mserial\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m][\u001b[33m\"\u001b[39;49;00m\u001b[33mabsavg\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m].append(\u001b[96mfloat\u001b[39;49;00m(absavg_match.group(\u001b[94m1\u001b[39;49;00m)))\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n            \u001b[90m# Run OpenMP\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            openmp_result = subprocess.run(\u001b[90m\u001b[39;49;00m\r\n                [\u001b[33m\"\u001b[39;49;00m\u001b[33m/app/openmp\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33m-n\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33m100\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33m-p\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33m2\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m], capture_output=\u001b[94mTrue\u001b[39;49;00m, text=\u001b[94mTrue\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            )\u001b[90m\u001b[39;49;00m\r\n            \u001b[94mif\u001b[39;49;00m openmp_result.returncode == \u001b[94m0\u001b[39;49;00m:\u001b[90m\u001b[39;49;00m\r\n"]
[35.279968, "o", "                absmin_match = re.search(\u001b[33mr\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mabsmin\u001b[39;49;00m\u001b[33m\\\u001b[39;49;00m\u001b[33ms*=\u001b[39;49;00m\u001b[33m\\\u001b[39;49;00m\u001b[33ms*([\u001b[39;49;00m\u001b[33m\\\u001b[39;49;00m\u001b[33md.]+)\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, openmp_result.stdout)\u001b[90m\u001b[39;49;00m\r\n                absavg_match = re.search(\u001b[33mr\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mabsavg\u001b[39;49;00m\u001b[33m\\\u001b[39;49;00m\u001b[33ms*=\u001b[39;49;00m\u001b[33m\\\u001b[39;49;00m\u001b[33ms*([\u001b[39;49;00m\u001b[33m\\\u001b[39;49;00m\u001b[33md.]+)\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, openmp_result.stdout)\u001b[90m\u001b[39;49;00m\r\n                \u001b[94mif\u001b[39;49;00m absmin_match \u001b[95mand\u001b[39;49;00m absavg_match:\u001b[90m\u001b[39;49;00m\r\n                    results[\u001b[33m\"\u001b[39;49;00m\u001b[33mopenmp\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m][\u001b[33m\"\u001b[39;49;00m\u001b[33mabsmin\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m].append(\u001b[96mfloat\u001b[39;49;00m(absmin_match.group(\u001b[94m1\u001b[39;49;00m)))\u001b[90m\u001b[39;49;00m\r\n                    results[\u001b[33m\"\u001b[39;49;00m\u001b[33mopenmp\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m][\u001b[33m\"\u001b[39;49;00m\u001b[33mabsavg\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m].append(\u001b[96mfloat\u001b[39;49;00m(absavg_match.group(\u001b[94m1\u001b[39;49;00m)))\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n            \u001b[90m# Run MPI\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            mpi_result = subprocess.run(\u001b[90m\u001b[39;49;00m\r\n                [\u001b[33m\"\u001b[39;49;00m\u001b[33mmpirun\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33m-np\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33m2\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33m--allow-run-as-root\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33m/app/mpi\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33m-n\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33m100\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m],\u001b[90m\u001b[39;49;00m\r\n                capture_output=\u001b[94mTrue\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n                text=\u001b[94mTrue\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n                env={\u001b[90m\u001b[39;49;00m\r\n                    **os.environ,\u001b[90m\u001b[39;49;00m\r\n                    \u001b[33m\"\u001b[39;49;00m\u001b[33mOMPI_ALLOW_RUN_AS_ROOT\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m: \u001b[33m\"\u001b[39;49;00m\u001b[33m1\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n                    \u001b[33m\"\u001b[39;49;00m\u001b[33mOMPI_ALLOW_RUN_AS_ROOT_CONFIRM\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m: \u001b[33m\"\u001b[39;49;00m\u001b[33m1\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n                },\u001b[90m\u001b[39;49;00m\r\n            )\u001b[90m\u001b[39;49;00m\r\n            \u001b[94mif\u001b[39;49;00m mpi_result.returncode == \u001b[94m0\u001b[39;49;00m:\u001b[90m\u001b[39;49;00m\r\n                absmin_match = re.search(\u001b[33mr\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mabsmin\u001b[39;49;00m\u001b[33m\\\u001b[39;49;00m\u001b[33ms*=\u001b[39;49;00m\u001b[33m\\\u001b[39;49;00m\u001b[33ms*([\u001b[39;49;00m\u001b[33m\\\u001b[39;49;00m\u001b[33md.]+)\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, mpi_result.stdout)\u001b[90m\u001b[39;49;00m\r\n                absavg_match = re.search(\u001b[33mr\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mabsavg\u001b[39;49;00m\u001b[33m\\\u001b[39;49;00m\u001b[33ms*=\u001b[39;49;00m\u001b[33m\\\u001b[39;49;00m\u001b[33ms*([\u001b[39;49;00m\u001b[33m\\\u001b[39;49;00m\u001b[33md.]+)\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, mpi_result.stdout)\u001b[90m\u001b[39;49;00m\r\n                \u001b[94mif\u001b[39;49;00m absmin_match \u001b[95mand\u001b[39;49;00m absavg_match:\u001b[90m\u001b[39;49;00m\r\n                    results[\u001b[33m\"\u001b[39;49;00m\u001b[33mmpi\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m][\u001b[33m\"\u001b[39;49;00m\u001b[33mabsmin\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m].append(\u001b[96mfloat\u001b[39;49;00m(absmin_match.group(\u001b[94m1\u001b[39;49;00m)))\u001b[90m\u001b[39;49;00m\r\n                    results[\u001b[33m\"\u001b[39;49;00m\u001b[33mmpi\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m][\u001b[33m\"\u001b[39;49;00m\u001b[33mabsavg\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m].append(\u001b[96mfloat\u001b[39;49;00m(absavg_match.group(\u001b[94m1\u001b[39;49;00m)))\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Verify we got results from all implementations for all runs\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mfor\u001b[39;49;00m impl \u001b[95min\u001b[39;49;00m [\u001b[33m\"\u001b[39;49;00m\u001b[33mserial\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33mopenmp\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33mmpi\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m]:\u001b[90m\u001b[39;49;00m\r\n>           \u001b[94massert\u001b[39;49;00m \u001b[96mlen\u001b[39;49;00m(results[impl][\u001b[33m\"\u001b[39;49;00m\u001b[33mabsmin\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m]) == num_runs, (\u001b[90m\u001b[39;49;00m\r\n                \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mCould not extract absmin results from all \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mnum_runs\u001b[33m}\u001b[39;49;00m\u001b[33m runs for \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mimpl\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            )\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31mE           AssertionError: Could not extract absmin results from all 5 runs for mpi\u001b[0m\r\n\u001b[1m\u001b[31mE           assert 0 == 5\u001b[0m\r\n\u001b[1m\u001b[31mE            +  where 0 = len([])\u001b[0m\r\n"]
