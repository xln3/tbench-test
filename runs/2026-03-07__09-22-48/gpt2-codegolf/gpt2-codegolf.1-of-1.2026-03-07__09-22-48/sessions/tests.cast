[17.029542, "o", "=========================================================================== FAILURES ===========================================================================\r\n\u001b[31m\u001b[1m___________________________________________________________________ test_gpt2_implementation ___________________________________________________________________\u001b[0m\r\n\r\n"]
[17.089061, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_gpt2_implementation\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"\u001b[39;49;00m\r\n    \u001b[33m    Test that the gpt2.c file exists and is under 5000 bytes.\u001b[39;49;00m\r\n    \u001b[33m    Also, test that the program can be compiled and run.\u001b[39;49;00m\r\n    \u001b[33m    \"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Check if gpt2.c file exists and is under 5000 bytes\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        gpt2_path = Path(\u001b[33m\"\u001b[39;49;00m\u001b[33m/app/gpt2.c\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n        \u001b[94massert\u001b[39;49;00m gpt2_path.exists(), \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mFile \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mgpt2_path\u001b[33m}\u001b[39;49;00m\u001b[33m does not exist\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[94massert\u001b[39;49;00m gpt2_path.stat().st_size < \u001b[94m5000\u001b[39;49;00m, (\u001b[90m\u001b[39;49;00m\r\n            \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mFile \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mgpt2_path\u001b[33m}\u001b[39;49;00m\u001b[33m is larger than 5000 bytes\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        )\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n"]
[17.08935, "o", "        \u001b[90m# Compile the C program with gcc -O3 -lm\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        compile_result = subprocess.run(\u001b[90m\u001b[39;49;00m\r\n            [\u001b[33m\"\u001b[39;49;00m\u001b[33mgcc\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33m-O3\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33m/app/gpt2.c\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33m-lm\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m], capture_output=\u001b[94mTrue\u001b[39;49;00m, text=\u001b[94mTrue\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        )\u001b[90m\u001b[39;49;00m\r\n        \u001b[94massert\u001b[39;49;00m compile_result.returncode == \u001b[94m0\u001b[39;49;00m, (\u001b[90m\u001b[39;49;00m\r\n            \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mCompilation failed: \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mcompile_result.stderr\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        )\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Test the program with sample input\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Run it with ./a.out gpt2-124M.ckpt vocab.bpe \"hello my name is jeff\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# For test purposes, we're expecting \"hi jeff\" in the output\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        run_result = subprocess.run(\u001b[90m\u001b[39;49;00m\r\n            [\u001b[90m\u001b[39;49;00m\r\n                \u001b[33m\"\u001b[39;49;00m\u001b[33m/app/a.out\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n                \u001b[33m\"\u001b[39;49;00m\u001b[33mgpt2-124M.ckpt\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n                \u001b[33m\"\u001b[39;49;00m\u001b[33mvocab.bpe\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n                \u001b[33m'\u001b[39;49;00m\u001b[33mTHIS SOFTWARE IS PROVIDED \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mAS IS\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m, WITHOUT\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n            ],\u001b[90m\u001b[39;49;00m\r\n            capture_output=\u001b[94mTrue\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n            text=\u001b[94mTrue\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n            timeout=\u001b[94m90\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n        )\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Check for expected output\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n>       \u001b[94massert\u001b[39;49;00m run_result.returncode == \u001b[94m0\u001b[39;49;00m, \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mProgram execution failed: \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mrun_result.stderr\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31mE       AssertionError: Program execution failed: \u001b[0m\r\n\u001b[1m\u001b[31mE       assert -11 == 0\u001b[0m\r\n\u001b[1m\u001b[31mE        +  where -11 = CompletedProcess(args=['/app/a.out', 'gpt2-124M.ckpt', 'vocab.bpe', 'THIS SOFTWARE IS PROVIDED \"AS IS\", WITHOUT'], returncode=-11, stdout='', stderr='').returncode\u001b[0m\r\n"]
