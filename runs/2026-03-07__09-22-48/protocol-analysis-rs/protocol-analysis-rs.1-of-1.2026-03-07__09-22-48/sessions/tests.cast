[333.643913, "o", "=========================================================================== FAILURES ===========================================================================\r\n\u001b[31m\u001b[1m__________________________________________________________________ test_login_makes_username ___________________________________________________________________\u001b[0m\r\n"]
[333.644009, "o", "\r\n"]
[333.718111, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_login_makes_username\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"\u001b[39;49;00m\r\n    \u001b[33m    Check that the player is able to login.\u001b[39;49;00m\r\n    \u001b[33m    The best way to do this is verify that a save file has been created\u001b[39;49;00m\r\n    \u001b[33m    for the player, which only happens after a successful login.\u001b[39;49;00m\r\n"]
[333.718173, "o", "    \u001b[33m    \"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[96mprint\u001b[39;49;00m(\u001b[33m\"\u001b[39;49;00m\u001b[33mTesting\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n        server_id = \u001b[96mstr\u001b[39;49;00m(uuid.uuid4())[:\u001b[94m8\u001b[39;49;00m]\u001b[90m\u001b[39;49;00m\r\n        username = \u001b[96mstr\u001b[39;49;00m(uuid.uuid4())[:\u001b[94m8\u001b[39;49;00m]\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Kill any existing bun processes\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        subprocess.run([\u001b[33m\"\u001b[39;49;00m\u001b[33mpkill\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33m-9\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33mbun\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m], capture_output=\u001b[94mTrue\u001b[39;49;00m, check=\u001b[94mFalse\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n        time.sleep(\u001b[94m10\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n"]
[333.718192, "o", "        \u001b[90m# Remove existing directory\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n"]
[333.718388, "o", "        subprocess.run([\u001b[33m\"\u001b[39;49;00m\u001b[33mrm\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33m-rf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33m/app/Server\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m], capture_output=\u001b[94mTrue\u001b[39;49;00m, check=\u001b[94mFalse\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n        time.sleep(\u001b[94m1\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n"]
[333.718584, "o", "        subprocess.run([\u001b[33m\"\u001b[39;49;00m\u001b[33mmkdir\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m/app/\u001b[39;49;00m\u001b[33m{\u001b[39;49;00mserver_id\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m], capture_output=\u001b[94mTrue\u001b[39;49;00m, check=\u001b[94mFalse\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Clone repository fresh so that they can't have cheated with a new server\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        result = subprocess.run(\u001b[90m\u001b[39;49;00m\r\n            [\u001b[33m\"\u001b[39;49;00m\u001b[33mgit\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33mclone\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33mhttps://github.com/LostCityRS/Server\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m],\u001b[90m\u001b[39;49;00m\r\n            cwd=\u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m/app/\u001b[39;49;00m\u001b[33m{\u001b[39;49;00mserver_id\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n            capture_output=\u001b[94mTrue\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n            text=\u001b[94mTrue\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n            check=\u001b[94mTrue\u001b[39;49;00m,\u001b[90m\u001b[39;49"]
