[17.782814, "o", "\u001b[31m\u001b[1m____________________________________________________________________ test_data_completeness ____________________________________________________________________\u001b[0m\r\n\r\n"]
[17.825348, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_data_completeness\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"Test that all books were scraped\"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        df = pd.read_csv(\u001b[33m\"\u001b[39;49;00m\u001b[33m/app/books.csv\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Should have scraped 7 books total\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n>       \u001b[94massert\u001b[39;49;00m \u001b[96mlen\u001b[39;49;00m(df) == \u001b[94m7\u001b[39;49;00m, \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mExpected 7 books, got \u001b[39;49;00m\u001b[33m{\u001b[39;49;00m\u001b[96mlen\u001b[39;49;00m(df)\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31mE       AssertionError: Expected 7 books, got 10\u001b[0m\r\n\u001b[1m\u001b[31mE       assert 10 == 7\u001b[0m\r\n"]
[17.825555, "o", "\u001b[1m\u001b[31mE        +  where 10 = len(                    title               author  year  rating  price\\n0        The Great Gatsby  F. Scott Fitzgerald  19...the Rings       J.R.R. Tolkien  1954     4.9  24.99\\n9               Jane Eyre     Charlotte Brontë  1847     4.5  11.50)\u001b[0m\r\n\r\n\u001b[1m\u001b[31m/tests/test_outputs.py\u001b[0m:35: AssertionError\r\n\u001b[31m\u001b[1m______________________________________________________________________ test_data_accuracy ______________________________________________________________________\u001b[0m\r\n\r\n"]
[17.826706, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_data_accuracy\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"Test the accuracy of scraped data\"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        df = pd.read_csv(\u001b[33m\"\u001b[39;49;00m\u001b[33m/app/books.csv\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Check specific book details\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        gatsby = df[df[\u001b[33m\"\u001b[39;49;00m\u001b[33mtitle\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m] == \u001b[33m\"\u001b[39;49;00m\u001b[33mThe Great Gatsby\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m].iloc[\u001b[94m0\u001b[39;49;00m]\u001b[90m\u001b[39;49;00m\r\n        \u001b[94massert\u001b[39;49;00m gatsby[\u001b[33m\"\u001b[39;49;00m\u001b[33mauthor\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m] == \u001b[33m\"\u001b[39;49;00m\u001b[33mF. Scott Fitzgerald\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, (\u001b[90m\u001b[39;49;00m\r\n            \u001b[33m\"\u001b[39;49;00m\u001b[33mAuthor should be F. Scott Fitzgerald\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n"]
[17.826794, "o", "        )\u001b[90m\u001b[39;49;00m\r\n        \u001b[94massert\u001b[39;49;00m gatsby[\u001b[33m\"\u001b[39;49;00m\u001b[33myear\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m] == \u001b[94m1925\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33mYear should be 1925\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n>       \u001b[94massert\u001b[39;49;00m gatsby[\u001b[33m\"\u001b[39;49;00m\u001b[33mrating\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m] == \u001b[94m4.2\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33mRating should be 4.2\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31mE       AssertionError: Rating should be 4.2\u001b[0m\r\n\u001b[1m\u001b[31mE       assert np.float64(4.5) == 4.2\u001b[0m\r\n\r\n\u001b[1m\u001b[31m/tests/test_outputs.py\u001b[0m:62: AssertionError\r\n"]
[17.826852, "o", "\u001b[31m\u001b[1m______________________________________________________________________ test_report_exists ______________________________________________________________________\u001b[0m\r\n\r\n"]
[17.827733, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_report_exists\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"Test that the summary report was created\"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        report_path = Path(\u001b[33m\"\u001b[39;49;00m\u001b[33m/app/report.txt\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n"]
[17.827819, "o", "        \u001b[94massert\u001b[39;49;00m report_path.exists(), \u001b[33m\"\u001b[39;49;00m\u001b[33mSummary report file should exist\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Read the summary report\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        report_content = report_path.read_text()\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Check for required information\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[94massert\u001b[39;49;00m \u001b[33m\"\u001b[39;49;00m\u001b[33m7\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m \u001b[95min\u001b[39;49;00m report_content, \u001b[33m\"\u001b[39;49;00m\u001b[33mReport should show correct book count\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n>       \u001b[94massert\u001b[39;49;00m \u001b[33m\"\u001b[39;49;00m\u001b[33m13.85\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m \u001b[95min\u001b[39;49;00m report_content, \u001b[33m\"\u001b[39;49;00m\u001b[33mReport should include average price\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31mE       AssertionError: Report should include average price\u001b[0m\r\n\u001b[1m\u001b[31mE       assert '13.85' in 'Bookstore Scraper Summary Report\\n============================"]
