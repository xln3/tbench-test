[?2004l[?2004h>   this.turn = function(cell) {
[?2004l[?2004h>     // Your implementation here
[?2004l[?2004h>     return "action_string"; // Must return one of: "left", "up", "right", "down", "pickup", "drop"
[?2004l[?2004h>   };
[?2004l[?2004h> }
[?2004l[?2004h> ```
[?2004l[?2004h> 
