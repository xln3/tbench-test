[24.853664, "o", "            text=\u001b[94mTrue\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n            cwd=\u001b[33m\"\u001b[39;49;00m\u001b[33m/app\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n        )\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n>       \u001b[94massert\u001b[39;49;00m result.returncode == \u001b[94m0\u001b[39;49;00m, (\u001b[90m\u001b[39;49;00m\r\n            \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mjump_analyzer.py failed with error: \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mresult.stderr\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        )\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31mE       AssertionError: jump_analyzer.py failed with error: /app/.tbench-testing/bin/python3: can't open file '/app/jump_analyzer.py': [Errno 2] No such file or directory\u001b[0m\r\n\u001b[1m\u001b[31mE         \u001b[0m\r\n"]
