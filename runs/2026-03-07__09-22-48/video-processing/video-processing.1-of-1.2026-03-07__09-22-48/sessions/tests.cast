[24.850503, "o", "        \u001b[90m# Check that the video file exists before running the test\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        video_file = Path(video_path)\u001b[90m\u001b[39;49;00m\r\n        \u001b[94massert\u001b[39;49;00m video_file.exists(), \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mVideo file \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mvideo_path\u001b[33m}\u001b[39;49;00m\u001b[33m does not exist\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Run jump_analyzer.py on the specified video\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        result = subprocess.run(\u001b[90m\u001b[39;49;00m\r\n            [sys.executable, \u001b[33m\"\u001b[39;49;00m\u001b[33m/app/jump_analyzer.py\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, video_path],\u001b[90m\u001b[39;49;00m\r\n            capture_output=\u001b[94mTrue\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n            text=\u001b[94mTrue\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n            cwd=\u001b[33m\"\u001b[39;49;00m\u001b[33m/app\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n        )\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n>       \u001b[94massert\u001b[39;49;00m result.returncode == \u001b[94m0\u001b[39;49;00m, (\u001b[90m\u001b[39;49;00m\r\n     "]
