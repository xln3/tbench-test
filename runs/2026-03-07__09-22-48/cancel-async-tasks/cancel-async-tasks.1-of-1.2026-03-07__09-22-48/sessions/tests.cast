[56.960986, "o", "\r\n=========================================================================== FAILURES ===========================================================================\r\n\u001b[31m\u001b[1m____________________________________________________________ test_tasks_cancel_above_max_concurrent ____________________________________________________________\u001b[0m\r\n\r\n"]
[57.023201, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_tasks_cancel_above_max_concurrent\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"\u001b[39;49;00m"]
[57.023596, "o", "\r\n    \u001b[33m    Test that cancellation occurs and only the first two tasks are started and\u001b[39;49;00m\r\n    \u001b[33m    cancelled.\u001b[39;49;00m\r\n    \u001b[33m\u001b[39;49;00m\r\n    \u001b[33m    This is a common gotcha in Python because asyncio.gather doesn't properly cancel\u001b[39;49;00m\r\n    \u001b[33m    existing tasks if there are still tasks in the queue.\u001b[39;49;00m\r\n    \u001b[33m    \"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        proc = subprocess.Popen(\u001b[90m\u001b[39;49;00m\r\n            [\u001b[90m\u001b[39;49;00m\r\n                \u001b[33m\"\u001b[39;49;00m\u001b[33mpython\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n                \u001b[33m\"\u001b[39;49;00m\u001b[33mtest.py\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n                \u001b[33m\"\u001b[39;49;00m\u001b[33m--n-tasks\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n                \u001b[33m\"\u001b[39;49;00m\u001b[33m3\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n                \u001b[33m\"\u001b[39;49;00m\u001b[33m--max-concurrent\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n                \u001b[33m\"\u001b[39;49;00m\u001b[33m2\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n   "]
[57.023624, "o", "         ],\u001b[90m\u001b[39;49;00m\r\n            stdout=subprocess.PIPE,\u001b[90m\u001b[39;49;00m\r\n            stderr=subprocess.PIPE,\u001b[90m\u001b[39;49;00m\r\n        )\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Wait 500ms, then send SIGINT (KeyboardInterrupt)\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        time.sleep(\u001b[94m0.5\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n        proc.send_signal(signal.SIGINT)\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[94mtry\u001b[39;49;00m:\u001b[90m\u001b[39;49;00m\r\n            stdout, stderr = proc.communicate(timeout=\u001b[94m5\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mfinally\u001b[39;49;00m:\u001b[90m\u001b[39;49;00m\r\n            proc.kill()\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        stdout = stdout.decode(\u001b[33m\"\u001b[39;49;00m\u001b[33mutf-8\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[94massert\u001b[39;49;00m stdout.count(\u001b[33m\"\u001b[39;49;00m\u001b[33mTask started.\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m) == \u001b[94m2\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n>       \u001b[94massert\u001b[39;49;00m stdout.count(\u001b[33m\"\u001b[39;49;00m\u001b[33mCleaned up.\u001b[39;49;00m\u001b"]
[57.023633, "o", "[33m\"\u001b[39;49;00m) == \u001b[94m2\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31mE       AssertionError: assert 0 == 2\u001b[0m\r\n\u001b[1m\u001b[31mE        +  where 0 = <built-in method count of str object at 0x7fd40d75a970>('Cleaned up.')\u001b[0m\r\n\u001b[1m\u001b[31mE        +    where <built-in method count of str object at 0x7fd40d75a970> = 'Task started.\\nTask started.\\n'.count\u001b[0m\r\n\r\n\u001b[1m\u001b[31m/tests/test_outputs.py\u001b[0m:172: AssertionError\r\n"]
