[234.300064, "o", "\u001b[31m\u001b[1m_________________________________________________________________ test_run_ot_script_execution _________________________________________________________________\u001b[0m\r\n\r\n"]
[234.349622, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_run_ot_script_execution\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"Test that run_ot.py executes successfully and produces valid output.\"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# ot_results.json should already exist from agent execution\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n>       \u001b[94massert\u001b[39;49;00m os.path.exists(\u001b[33m'\u001b[39;49;00m\u001b[33m/app/ot_results.json\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m), \u001b[33m\"\u001b[39;49;00m\u001b[33mot_results.json should exist from agent execution\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n"]
[234.349778, "o", "\u001b[1m\u001b[31mE       AssertionError: ot_results.json should exist from agent execution\u001b[0m\r\n\u001b[1m\u001b[31mE       assert False\u001b[0m\r\n\u001b[1m\u001b[31mE        +  where False = <function exists at 0x7f5eb7226ac0>('/app/ot_results.json')\u001b[0m\r\n\u001b[1m\u001b[31mE        +    where <function exists at 0x7f5eb7226ac0> = <module 'posixpath' (frozen)>.exists\u001b[0m\r\n\u001b[1m\u001b[31mE        +      where <module 'posixpath' (frozen)> = os.path\u001b[0m\r\n\r\n\u001b[1m\u001b[31m/tests/test_outputs.py\u001b[0m:187: AssertionError\r\n"]
[234.349868, "o", "\u001b[31m\u001b[1m_____________________________________________________________ test_run_ot_script_execution_hidden ______________________________________________________________\u001b[0m\r\n\r\n"]
[234.355729, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_run_ot_script_execution_hidden\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"Test run_ot.py with hidden_ai_data_large.json dataset.\"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Get path to hidden large dataset\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        test_dir = os.path.dirname(\u001b[91m__file__\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n        hidden_large_file = os.path.join(test_dir, \u001b[33m'\u001b[39;49;00m\u001b[33mhidden_ai_data_large.json\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n"]
[234.355879, "o", "        \u001b[90m# Test with grid method and custom output file\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        grid_output = \u001b[33m'\u001b[39;49;00m\u001b[33m/app/ot_results_hidden_grid.json\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        grid_cmd = [\u001b[90m\u001b[39;49;00m\r\n            \u001b[33m'\u001b[39;49;00m\u001b[33mpython3\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m, \u001b[33m'\u001b[39;49;00m\u001b[33m/app/run_ot.py\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n            hidden_large_file,\u001b[90m\u001b[39;49;00m\r\n            \u001b[33m'\u001b[39;49;00m\u001b[33mgrid\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m,                      \u001b[90m# method\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            \u001b[33m'\u001b[39;49;00m\u001b[33m32\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m,                       \u001b[90m# grid_size\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            \u001b[33m'\u001b[39;49;00m\u001b[33m10\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m,                      \u001b[90m# reg\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            \u001b[33m'\u001b[39;49;00m\u001b[33m1000\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m,                     \u001b[90m# max_iter\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            grid_output                 \u001b[90m# outpu"]
[234.355896, "o", "t file\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        ]\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        result = subprocess.run(grid_cmd, capture_output=\u001b[94mTrue\u001b[39;49;00m, text=\u001b[94mTrue\u001b[39;49;00m, cwd=\u001b[33m'\u001b[39;49;00m\u001b[33m/app\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n        \u001b[94massert\u001b[39;49;00m result.returncode == \u001b[94m0\u001b[39;49;00m, \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mrun_ot.py with hidden large dataset failed: \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mresult.stderr\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Load and validate result\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mwith\u001b[39;49;00m \u001b[96mopen\u001b[39;49;00m(grid_output, \u001b[33m'\u001b[39;49;00m\u001b[33mr\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m) \u001b[94mas\u001b[39;49;00m f:\u001b[90m\u001b[39;49;00m\r\n            grid_result = json.load(f)\u001b[90m\u001b[39;49;00m\r\n"]
[234.355915, "o", "    \u001b[90m\u001b[39;49;00m\r\n        expected_distance_hidden_large_grid32 = \u001b[94m16.077968\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n"]
[234.355926, "o", "    \u001b[90m\u001b[39;49;00m\r\n"]
[234.35594, "o", "        \u001b[94massert\u001b[39;49;00m grid_result[\u001b[33m'\u001b[39;49;00m\u001b[33mmethod\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m] == \u001b[33m'\u001b[39;49;00m\u001b[33mgrid\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m, \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mExpected grid method, got \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mgrid_result[\u001b[33m'\u001b[39;49;00m\u001b[33mmethod\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m]\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n"]
