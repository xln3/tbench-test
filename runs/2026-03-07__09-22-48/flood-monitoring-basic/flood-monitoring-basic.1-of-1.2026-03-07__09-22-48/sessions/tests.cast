[23.647564, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_interpolation_correctness\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"Test that interpolated values are correct within floating point tolerance.\"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Station A has missing at indices: 0, 5, 20, 36, 47\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mwith\u001b[39;49;00m \u001b[96mopen\u001b[39;49;00m(\u001b[33m\"\u001b[39;49;00m\u001b[33m/data/station_A.csv\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33mr\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, encoding=\u001b[33m\"\u001b[39;49;00m\u001b[33mutf-8\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m) \u001b[94mas\u001b[39;49;00m f:\u001b[90m\u001b[39;49;00m\r\n            reader = \u001b[96mlist\u001b[39;49;00m(csv.DictReader(f))\u001b[90m\u001b[39;49;00m\r\n            values = [\u001b[96mfloat\u001b[39;49;00m(row[\u001b[33m\"\u001b[39;49;00m\u001b[33mwater_level_m\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m]) \u001b[94mfor\u001b[39;49;00m row \u001b[95min\u001b[39;49;00m reader]\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n            \u001b[90m# Use reasonable tolerance for floating point comparison\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            \u001b[94massert\u001b[39;49;00m \u001b[96mabs\u001b[39;49;00m(values[\u001b[94m0\u001b[39;49;00m] - \u001b[94m2.3\u001b[39;49;00m) < \u001b[94m0.01\u001b[39;49;00m, (\u001b[90m\u001b[39;49;00m\r\n                \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mStation A row 0: expected 2.3, got \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mvalues[\u001b[94m0\u001b[39;49;00m]\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            )\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n>           \u001b[94massert\u001b[39;49;00m \u001b[96mabs\u001b[39;49;00m(values[\u001b[94m5\u001b[39;49;00m] - \u001b[94m3.45\u001b[39;49;00m) < \u001b[94m0.01\u001b[39;49;00m, (\u001b[90m\u001b[39;49;00m\r\n                \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mStation A row 5: expected 3.45, got \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mvalues[\u001b[94m5\u001b[39;49;00m]\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            )\u001b[90m\u001b[39;49;00m\r\n"]
