[42.254036, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_release_build_runs_without_crash\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"\u001b[39;49;00m\r\n    \u001b[33m    Test that the release build runs without crashing.\u001b[39;49;00m\r\n    \u001b[33m    This test will fail on the buggy version but pass on the fixed version.\u001b[39;49;00m\r\n    \u001b[33m    \"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        executable = compile_program(\u001b[33m\"\u001b[39;49;00m\u001b[33mrelease\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n        result = run_program(executable)\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# After the fix, release build should complete successfully\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n>       \u001b[94massert\u001b[39;49;00m (\u001b[90m\u001b[39;49;00m\r\n            result.returncode == \u001b[94m0\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        ), \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mRelease build crashed! This indicates the bug is not fixed.\u001b[39;49;00m\u001b[33m\\n\u001b[39;49;00m\u001b[33mSTDOUT:\u001b[39;49;00m\u001b[33m\\n\u001b[39;49;00m\u001b[33m{\u001b[39;49;00mresult.stdout\u001b[33m}\u001b[39;49;00m\u001b[33m\\n\u001b[39;49;00m\u001b[33mSTDERR:\u001b[39;49;00m\u001b[33m\\n\u001b[39;49;00m\u001b[33m{\u001b[39;49;00mresult.stderr\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n"]
[42.254096, "o", "\u001b[1m\u001b[31mE       AssertionError: Release build crashed! This indicates the bug is not fixed.\u001b[0m\r\n\u001b[1m\u001b[31mE         STDOUT:\u001b[0m\r\n\u001b[1m\u001b[31mE         === Monte Carlo π Estimation Application ===\u001b[0m\r\n\u001b[1m\u001b[31mE         \u001b[0m\r\n\u001b[1m\u001b[31mE         === Running Monte Carlo Simulation ===\u001b[0m\r\n\u001b[1m\u001b[31mE         \u001b[0m\r\n\u001b[1m\u001b[31mE         Estimating π using Monte Carlo method...\u001b[0m\r\n\u001b[1m\u001b[31mE         Samples: 1000000\u001b[0m\r\n\u001b[1m\u001b[31mE         Estimated π: 3.142428\u001b[0m\r\n\u001b[1m\u001b[31mE         Actual π: 3.141593\u001b[0m\r\n\u001b[1m\u001b[31mE         Error: 0.000835\u001b[0m\r\n"]
[42.254251, "o", "\u001b[1m\u001b[31mE         Accuracy: 99.97%\u001b[0m\r\n\u001b[1m\u001b[31mE         \u001b[0m\r\n\u001b[1m\u001b[31mE         === Computation completed successfully ===\u001b[0m\r\n\u001b[1m\u001b[31mE         \u001b[0m\r\n\u001b[1m\u001b[31mE         STDERR:\u001b[0m\r\n\u001b[1m\u001b[31mE         \u001b[0m\r\n\u001b[1m\u001b[31mE       assert -11 == 0\u001b[0m\r\n\u001b[1m\u001b[31mE        +  where -11 = CompletedProcess(args='/app/release', returncode=-11, stdout='=== Monte Carlo π Estimation Application ===\\n\\n=== Runn...428\\nActual π: 3.141593\\nError: 0.000835\\nAccuracy: 99.97%\\n\\n=== Computation completed successfully ===\\n', stderr='').returncode\u001b[0m\r\n\r\n\u001b[1m\u001b[31m/tests/test_outputs.py\u001b[0m:139: AssertionError\r\n"]
