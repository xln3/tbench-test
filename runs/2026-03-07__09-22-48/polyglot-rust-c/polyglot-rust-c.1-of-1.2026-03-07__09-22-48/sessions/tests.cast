[90.474008, "o", "self = <Popen: returncode: 255 args: ['/app/polyglot/main', '0']>, args = ['/app/polyglot/main', '0'], executable = b'/app/polyglot/main', preexec_fn = None\r\n"]
[90.474087, "o", "close_fds = True, pass_fds = (), cwd = None, env = None, startupinfo = None, creationflags = 0, shell = False, p2cread = -1, p2cwrite = -1, c2pread = 11\r\n"]
