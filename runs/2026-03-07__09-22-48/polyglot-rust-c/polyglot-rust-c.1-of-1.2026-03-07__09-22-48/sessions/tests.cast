[90.435091, "o", "\r\n"]
[90.472571, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_fibonacci_polyglot\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"\u001b[39;49;00m\r\n    \u001b[33m    Test that main.rs is a valid polyglot that compiles with both rustc and g++,\u001b[39;49;00m\r\n    \u001b[33m    produces correct Fibonacci numbers, and is contained in a single file.\u001b[39;49;00m\r\n    \u001b[33m    \"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Verify that only main.rs exists in /app/polyglot\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        polyglot_files = os.listdir(\u001b[33m\"\u001b[39;49;00m\u001b[33m/app/polyglot\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n        \u001b[96mprint\u001b[39;49;00m(polyglot_files)\u001b[90m\u001b[39;49;00m\r\n        \u001b[94massert\u001b[39;49;00m polyglot_files == [\u001b[33m\"\u001b[39;49;00m\u001b[33mmain.rs\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m], (\u001b[90m\u001b[39;49;00m\r\n            \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mExpected only main.rs, found: \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mpolyglot_files\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        )\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n"]
[90.472742, "o", "        \u001b[90m# Test compilation and Fibonacci computation\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        os.popen(\u001b[33m\"\u001b[39;49;00m\u001b[33mrustc /app/polyglot/main.rs -o /app/polyglot/main\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m).read()\u001b[90m\u001b[39;49;00m\r\n        os.popen(\u001b[33m\"\u001b[39;49;00m\u001b[33mg++ -x c++ /app/polyglot/main.rs -o /app/polyglot/cmain\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m).read()\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        test_cases = [(\u001b[94m0\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33m1\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m), (\u001b[94m1\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33m1\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m), (\u001b[94m2\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33m2\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m), (\u001b[94m10\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33m89\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m), (\u001b[94m42\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33m433494437\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)]\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[94mfor\u001b[39;49;00m n, expected \u001b[95min\u001b[39;49;00m test_cases:\u001b[90m\u001b[39;49;00m\r\n>           rust_result = subprocess.run(\u001b[90m\u001b[39;49;00m\r\n                [\u001b[33m\"\u001b[39;49;00m\u001b[33m/app/polyglot/main\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[96mstr\u001b[39;49;00m(n)],\u001b[90m\u001b[39;49;00m\r\n                capture_output=\u001b[94mTrue\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n                text=\u001b[94mTrue\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n                check=\u001b[94mTrue\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n            )\u001b[90m\u001b[39;49;00m\r\n\r\n\u001b[1m\u001b[31m/tests/test_outputs.py\u001b[0m:30: \r\n_ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ \r\n"]
[90.472807, "o", "\u001b[1m\u001b[31m/usr/lib/python3.12/subprocess.py\u001b[0m:548: in run\r\n"]
[90.473607, "o", "    \u001b[0m\u001b[94mwith\u001b[39;49;00m Popen(*popenargs, **kwargs) \u001b[94mas\u001b[39;49;00m process:\u001b[90m\u001b[39;49;00m\r\n         ^^^^^^^^^^^^^^^^^^^^^^^^^^^\u001b[90m\u001b[39;49;00m\r\n"]
