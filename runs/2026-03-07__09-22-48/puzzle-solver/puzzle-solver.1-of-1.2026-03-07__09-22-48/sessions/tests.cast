[52.384436, "o", "\u001b[31m\u001b[1m_____________________________________________________________________ test_path_tsv_format _____________________________________________________________________\u001b[0m\r\n\r\n"]
[52.387816, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_path_tsv_format\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"Test path.tsv has correct format with required headers and valid tile numbers\"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[94massert\u001b[39;49;00m os.path.exists(\u001b[33m'\u001b[39;49;00m\u001b[33m/app/path.tsv\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m), \u001b[33m\"\u001b[39;49;00m\u001b[33mpath.tsv not found\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mwith\u001b[39;49;00m \u001b[96mopen\u001b[39;49;00m(\u001b[33m'\u001b[39;49;00m\u001b[33m/app/path.tsv\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m, \u001b[33m'\u001b[39;49;00m\u001b[33mr\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m) \u001b[94mas\u001b[39;49;00m f:\u001b[90m\u001b[39;49;00m\r\n            reader = csv.DictReader(f, delimiter=\u001b[33m'\u001b[39;49;00m\u001b[33m\\t\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n            required_headers = {\u001b[33m'\u001b[39;49;00m\u001b[33mstep\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m, \u001b[33m'\u001b[39;49;00m\u001b[33mtile\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m, \u001b[33m'\u001b[39;49;00m\u001b[33mstate_key\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m}\u001b[90m\u001b[39;49;00m\r\n            \u001b[94massert\u001b[39;49;00m reader.fieldnames \u001b[95mand\u001b[39;49;00m \u001b[96mset\u001b[39;49;00m(reader.fieldnames) == required_headers, (\u001b[90m\u001b[39;49;00m\r\n"]
[52.387879, "o", "                \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mMissing required headers in: \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mreader.fieldnames\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            )\u001b[90m\u001b[39;49;00m\r\n            rows = \u001b[96mlist\u001b[39;49;00m(reader)\u001b[90m\u001b[39;49;00m\r\n            \u001b[90m# Empty path is valid if start == goal\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            \u001b[94mfor\u001b[39;49;00m i, row \u001b[95min\u001b[39;49;00m \u001b[96menumerate\u001b[39;49;00m(rows):\u001b[90m\u001b[39;49;00m\r\n                \u001b[94massert\u001b[39;49;00m \u001b[96mint\u001b[39;49;00m(row[\u001b[33m'\u001b[39;49;00m\u001b[33mstep\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m]) == i, \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mStep \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mi\u001b[33m}\u001b[39;49;00m\u001b[33m has wrong number: \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mrow[\u001b[33m'\u001b[39;49;00m\u001b[33mstep\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m]\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n>               \u001b[94massert\u001b[39;49;00m \u001b[94m1\u001b[39;49;00m <= \u001b[96mint\u001b[39;49;00m(row[\u001b[33m'\u001b[39;49;00m\u001b[33mtile\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m]) <= \u001b[94m8\u001b[39;49;00m, \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mInvalid tile number: \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mrow[\u001b[33m'\u001b[39;49;00m\u001b[33mtile\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m]\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n"]
[52.388042, "o", "\u001b[1m\u001b[31mE               AssertionError: Invalid tile number: -1\u001b[0m\r\n\u001b[1m\u001b[31mE               assert 1 <= -1\u001b[0m\r\n"]
[52.388081, "o", "\u001b[1m\u001b[31mE                +  where -1 = int('-1')\u001b[0m\r\n\r\n\u001b[1m\u001b[31m/tests/test_outputs.py\u001b[0m:28: AssertionError\r\n\u001b[31m\u001b[1m______________________________________________________________________ test_move_legality ______________________________________________________________________\u001b[0m\r\n"]
[52.388107, "o", "\r\n"]
[52.3951, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_move_legality\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"Test that each move in path.tsv is legal (tile was adjacent to blank)\"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mread_puzzle_as_state\u001b[39;49;00m(filename):\u001b[90m\u001b[39;49;00m\r\n            \u001b[94massert\u001b[39;49;00m os.path.exists(filename), \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m{\u001b[39;49;00mfilename\u001b[33m}\u001b[39;49;00m\u001b[33m not found\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            tiles = []\u001b[90m\u001b[39;49;00m\r\n            \u001b[94mwith\u001b[39;49;00m \u001b[96mopen\u001b[39;49;00m(filename, \u001b[33m'\u001b[39;49;00m\u001b[33mr\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m) \u001b[94mas\u001b[39;49;00m f:\u001b[90m\u001b[39;49;00m\r\n                \u001b[94mfor\u001b[39;49;00m line \u001b[95min\u001b[39;49;00m f:\u001b[90m\u001b[39;49;00m\r\n                    tiles.extend([\u001b[96mint\u001b[39;49;00m(x) \u001b[94mfor\u001b[39;49;00m x \u001b[95min\u001b[39;49;00m line.split()])\u001b[90m\u001b[39;49;00m\r\n            \u001b[94mreturn\u001b[39;49;00m \u001b[33m'\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m.join(\u001b[33mf\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33m{\u001b[39;49;00mt\u001b[33m:\u001b[39;49;00m\u001b[33m02d\u001b[39;49;00m\u001b[33m}\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m \u001b[94mfor\u001b[39;49;00m t \u001b[95min\u001b[39;49;00m tiles)\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[94massert\u001b[39;49;00m os.path.exists(\u001b[33m'\u001b[39;49;00m\u001b[33m/app/path.tsv\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m), \u001b[33m\"\u001b[39;49;00m\u001b[33mpath.tsv not found\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mwith\u001b[39;49;00m \u001b[96mopen\u001b[39;49;00m(\u001b[33m'\u001b[39;49;00m\u001b[33m/app/path.tsv\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m, \u001b[33m'\u001b[39;49;00m\u001b[33mr\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m) \u001b[94mas\u001b[39;49;00m f:\u001b[90m\u001b[39;49;00m\r\n            reader = csv.DictReader(f, delimiter=\u001b[33m'\u001b[39;49;00m\u001b[33m\\t\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n            rows = \u001b[96mlist\u001b[39;49;00m(reader)\u001b[90m\u001b[39;49;00m\r\n"]
