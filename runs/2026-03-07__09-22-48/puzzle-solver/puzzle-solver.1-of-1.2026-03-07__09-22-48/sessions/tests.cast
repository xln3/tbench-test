[52.421512, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_optimal_path_length\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"Test that path length matches BFS depth where goal appears\"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[94massert\u001b[39;49;00m os.path.exists(\u001b[33m'\u001b[39;49;00m\u001b[33m/app/path.tsv\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m), \u001b[33m\"\u001b[39;49;00m\u001b[33mpath.tsv not found\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mwith\u001b[39;49;00m \u001b[96mopen\u001b[39;49;00m(\u001b[33m'\u001b[39;49;00m\u001b[33m/app/path.tsv\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m, \u001b[33m'\u001b[39;49;00m\u001b[33mr\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m) \u001b[94mas\u001b[39;49;00m f:\u001b[90m\u001b[39;49;00m\r\n            reader = csv.DictReader(f, delimiter=\u001b[33m'\u001b[39;49;00m\u001b[33m\\t\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n            path_length = \u001b[96mlen\u001b[39;49;00m(\u001b[96mlist\u001b[39;49;00m(reader))\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mread_puzzle_as_state\u001b[39;49;00m(filename):\u001b[90m\u001b[39;49;00m\r\n            \u001b[94massert\u001b[39;49;00m os.path.exists(filename), \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m{\u001b[39;49;00mfilename\u001b[33m}\u001b[39;49;00m\u001b[33m not found\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            tiles = []\u001b[90m\u001b[39;49;00m\r\n            \u001b[94mwith\u001b[39;49;00m \u001b[96mopen\u001b[39;49;00m(filename, \u001b[33m'\u001b[39;49;00m\u001b[33mr\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m) \u001b[94mas\u001b[39;49;00m f:\u001b[90m\u001b[39;49;00m\r\n                \u001b[94mfor\u001b[39;49;00m line \u001b[95min\u001b[39;49;00m f:\u001b[90m\u001b[39;49;00m\r\n                    tiles.extend([\u001b[96mint\u001b[39;49;00m(x) \u001b[94mfor\u001b[39;49;00m x \u001b[95min\u001b[39;49;00m line.split()])\u001b[90m\u001b[39;49;00m\r\n            \u001b[94mreturn\u001b[39;49;00m \u001b[33m'\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m.join(\u001b[33mf\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33m{\u001b[39;49;00mt\u001b[33m:\u001b[39;49;00m\u001b[33m02d\u001b[39;49;00m\u001b[33m}\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m \u001b[94mfor\u001b[39;49;00m t \u001b[95min\u001b[39;49;00m tiles)\u001b[90m\u001b[39;49;00m\r\n        goal_state = read_puzzle_as_state(\u001b[33m'\u001b[39;49;00m\u001b[33m/app/goal.txt\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n        goal_depth = \u001b[94mNone\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n"]
[52.421778, "o", "        \u001b[94massert\u001b[39;49;00m os.path.exists(\u001b[33m'\u001b[39;49;00m\u001b[33m/app/layers.csv\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m), \u001b[33m\"\u001b[39;49;00m\u001b[33mlayers.csv not found\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mwith\u001b[39;49;00m \u001b[96mopen\u001b[39;49;00m(\u001b[33m'\u001b[39;49;00m\u001b[33m/app/layers.csv\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m, \u001b[33m'\u001b[39;49;00m\u001b[33mr\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m) \u001b[94mas\u001b[39;49;00m f:\u001b[90m\u001b[39;49;00m\r\n            reader = csv.DictReader(f)\u001b[90m\u001b[39;49;00m\r\n            \u001b[94mfor\u001b[39;49;00m row \u001b[95min\u001b[39;49;00m reader:\u001b[90m\u001b[39;49;00m\r\n                depth = \u001b[96mint\u001b[39;49;00m(row[\u001b[33m'\u001b[39;49;00m\u001b[33mdepth\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m])\u001b[90m\u001b[39;49;00m\r\n                layer_file = \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m/app/L\u001b[39;49;00m\u001b[33m{\u001b[39;49;00mdepth\u001b[33m}\u001b[39;49;00m\u001b[33m.txt\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n                \u001b[94massert\u001b[39;49;00m os.path.exists(layer_file), \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mLayer file \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mlayer_file\u001b[33m}\u001b[39;49;00m\u001b[33m not found\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n                \u001b[94mwith\u001b[39;49;00m \u001b[96mopen\u001b[39;49;00m(layer_file, \u001b[33m'\u001b[39;49;00m\u001b[33mr\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m) \u001b[94mas\u001b[39;49;00m lf:\u001b[90m\u001b[39;49;00m\r\n                    lines = [s \u001b[94mfor\u001b[39;49;00m s \u001b[95min\u001b[39;49;00m lf.read().split(\u001b[33m'\u001b[39;49;00m\u001b[33m\\n\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m) \u001b[94mif\u001b[39;49;00m s]\u001b[90m\u001b[39;49;00m\r\n                    states = []\u001b[90m\u001b[39;49;00m\r\n                    \u001b[94mfor\u001b[39;49;00m line \u001b[95min\u001b[39;49;00m lines:\u001b[90m\u001b[39;49;00m\r\n                        \u001b[94massert\u001b[39;49;00m line == line.strip(), \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mState line has whitespace: \u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33m{\u001b[39;49;00mline\u001b[33m}\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n                        states.append(line)\u001b[90m\u001b[39;49;00m\r\n                    \u001b[94mif\u001b[39;49;00m goal_state \u001b[95min\u001b[39;49;00m states:\u001b[90m\u001b[39;49;00m\r\n                        goal_depth = depth\u001b[90m\u001b[39;49;00m\r\n                        \u001b[94mbreak\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[94massert\u001b[39;49;00m goal_depth \u001b[95mis\u001b[39;49;00m \u001b[95mnot\u001b[39;49;00m \u001b[94mNone\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33mGoal state not found in any layer\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n>       \u001b[94massert\u001b[39;49;00m path_length == goal_depth, (\u001b[90m\u001b[39;49;00m\r\n            \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mPath length \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mpath_length\u001b[33m}\u001b[39;49;00m\u001b[33m doesn\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33mt match goal depth \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mgoal_depth\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        )\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31mE       AssertionError: Path length 31 doesn't match goal depth 30\u001b[0m\r\n\u001b[1m\u001b[31mE       assert 31 == 30\u001b[0m\r\n\r\n\u001b[1m\u001b[31m/tests/test_outputs.py\u001b[0m:354: AssertionError\r\n"]
[52.421926, "o", "\u001b[31m\u001b[1m_____________________________________________________________ test_layers_are_exact_bfs_frontiers ______________________________________________________________\u001b[0m\r\n\r\n"]
[52.435188, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_layers_are_exact_bfs_frontiers\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"Compute BFS up to max depth in layers.csv\u001b[39;49;00m\r\n    \u001b[33m    and require each L{d}.txt equals the exact frontier at depth d.\"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mread_grid\u001b[39;49;00m(filename):\u001b[90m\u001b[39;49;00m\r\n            \u001b[94massert\u001b[39;49;00m os.path.exists(filename), \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m{\u001b[39;49;00mfilename\u001b[33m}\u001b[39;49;00m\u001b[33m not found\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            tiles = []\u001b[90m\u001b[39;49;00m\r\n            \u001b[94mwith\u001b[39;49;00m \u001b[96mopen\u001b[39;49;00m(filename, \u001b[33m'\u001b[39;49;00m\u001b[33mr\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m) \u001b[94mas\u001b[39;49;00m f:\u001b[90m\u001b[39;49;00m\r\n                \u001b[94mfor\u001b[39;49;00m line \u001b[95min\u001b[39;49;00m f:\u001b[90m\u001b[39;49;00m\r\n                    tiles.extend([\u001b[96mint\u001b[39;49;00m(x) \u001b[94mfor\u001b[39;49;00m x \u001b[95min\u001b[39;49;00m line.split()])\u001b[90m\u001b[39;49;00m\r\n"]
[52.435382, "o", "            \u001b[94mreturn\u001b[39;49;00m tiles\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mkey\u001b[39;49;00m(tiles):\u001b[90m\u001b[39;49;00m\r\n            \u001b[94mreturn\u001b[39;49;00m \u001b[33m'\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m.join(\u001b[33mf\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33m{\u001b[39;49;00mt\u001b[33m:\u001b[39;49;00m\u001b[33m02d\u001b[39;49;00m\u001b[33m}\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m \u001b[94mfor\u001b[39;49;00m t \u001b[95min\u001b[39;49;00m tiles)\u001b[90m\u001b[39;49;00m\r\n        MOVES = [(-\u001b[94m1\u001b[39;49;00m,\u001b[94m0\u001b[39;49;00m),(\u001b[94m1\u001b[39;49;00m,\u001b[94m0\u001b[39;49;00m),(\u001b[94m0\u001b[39;49;00m,-\u001b[94m1\u001b[39;49;00m),(\u001b[94m0\u001b[39;49;00m,\u001b[94m1\u001b[39;49;00m)]\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mneighbors\u001b[39;49;00m(tiles):\u001b[90m\u001b[39;49;00m\r\n            b = tiles.index(\u001b[94m0\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n            r, c = \u001b[96mdivmod\u001b[39;49;00m(b, \u001b[94m3\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n            \u001b[94mfor\u001b[39;49;00m dr, dc \u001b[95min\u001b[39;49;00m MOVES:\u001b[90m\u001b[39;49;00m\r\n                nr, nc = r+dr, c+dc\u001b[90m\u001b[39;49;00m\r\n                \u001b[94mif\u001b[39;49;00m \u001b[94m0\u001b[39;49;00m <= nr < \u001b[94m3\u001b[39;49;00m \u001b[95mand\u001b[39;49;00m \u001b[94m0\u001b[39;49;00m <= nc < \u001b[94m3\u001b[39;49;00m:\u001b[90m\u001b[39;49;00m\r\n                    np = nr*\u001b[94m3\u001b[39;49;00m + nc\u001b[90m\u001b[39;49;00m\r\n                    nt = tiles[:]\u001b[90m\u001b[39;49;00m\r\n                    nt[b], nt[np] = nt[np], nt[b]\u001b[90m\u001b[39;49;00m\r\n                    \u001b[94myield\u001b[39;49;00m nt\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n"]
[52.43547, "o", "        \u001b[90m# collect depths from CSV\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mwith\u001b[39;49;00m \u001b[96mopen\u001b[39;49;00m(\u001b[33m'\u001b[39;49;00m\u001b[33m/app/layers.csv\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m, \u001b[33m'\u001b[39;49;00m\u001b[33mr\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m) \u001b[94mas\u001b[39;49;00m f:\u001b[90m\u001b[39;49;00m\r\n            rows = \u001b[96mlist\u001b[39;49;00m(csv.DictReader(f))\u001b[90m\u001b[39;49;00m\r\n        \u001b[94massert\u001b[39;49;00m \u001b[96mlen\u001b[39;49;00m(rows) > \u001b[94m0\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33mlayers.csv has no data rows\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        depths = \u001b[96msorted\u001b[39;49;00m(\u001b[96mint\u001b[39;49;00m(r[\u001b[33m'\u001b[39;49;00m\u001b[33mdepth\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m]) \u001b[94mfor\u001b[39;49;00m r \u001b[95min\u001b[39;49;00m rows)\u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# depths is guaranteed non-empty due to assertion above, but add defensive check\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[94massert\u001b[39;49;00m \u001b[96mlen\u001b[39;49;00m(depths) > \u001b[94m0\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33mNo valid depths found in layers.csv\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        max_d = \u001b[96mmax\u001b[39;49;00m(depths)\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        start = read_grid(\u001b[33m'\u001b[39;49;00m\u001b[33m/app/start.txt\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n        start_k = key(start)\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# BFS to exact frontier sets up to max_d\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        frontier = {start_k: start}\u001b[90m\u001b[39;49;00m\r\n        seen = {start_k}\u001b[90m\u001b[39;49;00m\r\n        depth_sets = {\u001b[94m0\u001b[39;49;00m: {start_k}}\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mfor\u001b[39;49;00m d \u001b[95min\u001b[39;49;00m \u001b[96mrange\u001b[39;49;00m(\u001b[94m1\u001b[39;49;00m, max_d+\u001b[94m1\u001b[39;49;00m):\u001b[90m\u001b[39;49;00m\r\n            next_frontier = {}\u001b[90m\u001b[39;49;00m\r\n            \u001b[94mfor\u001b[39;49;00m tiles \u001b[95min\u001b[39;49;00m frontier.values():\u001b[90m\u001b[39;49;00m\r\n                \u001b[94mfor\u001b[39;49;00m nt \u001b[95min\u001b[39;49;00m neighbors(tiles):\u001b[90m\u001b[39;49;00m\r\n"]
[52.435543, "o", "                    nk = key(nt)\u001b[90m\u001b[39;49;00m\r\n                    \u001b[94mif\u001b[39;49;00m nk \u001b[95mnot\u001b[39;49;00m \u001b[95min\u001b[39;49;00m seen:\u001b[90m\u001b[39;49;00m\r\n                        seen.add(nk)\u001b[90m\u001b[39;49;00m\r\n                        next_frontier[nk] = nt\u001b[90m\u001b[39;49;00m\r\n            \u001b[94mif\u001b[39;49;00m \u001b[95mnot\u001b[39;49;00m next_frontier:\u001b[90m\u001b[39;49;00m\r\n                \u001b[90m# No more reachable states - BFS exploration is complete\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n                \u001b[94mbreak\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            depth_sets[d] = \u001b[96mset\u001b[39;49;00m(next_frontier.keys())\u001b[90m\u001b[39;49;00m\r\n            frontier = next_frontier\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Compare every layer file to computed frontier set\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mfor\u001b[39;49;00m d \u001b[95min\u001b[39;49;00m depths:\u001b[90m\u001b[39;49;00m\r\n            layer_file = \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m/app/L\u001b[39;49;00m\u001b[33m{\u001b[39;49;00md\u001b[33m}\u001b[39;49;00m\u001b[33m.txt\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n"]
[52.435628, "o", "            \u001b[94massert\u001b[39;49;00m os.path.exists(layer_file), \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mLayer file \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mlayer_file\u001b[33m}\u001b[39;49;00m\u001b[33m not found\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            \u001b[94mwith\u001b[39;49;00m \u001b[96mopen\u001b[39;49;00m(layer_file, \u001b[33m\"\u001b[39;49;00m\u001b[33mr\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m) \u001b[94mas\u001b[39;49;00m f:\u001b[90m\u001b[39;49;00m\r\n                lines = [s \u001b[94mfor\u001b[39;49;00m s \u001b[95min\u001b[39;49;00m f.read().splitlines() \u001b[94mif\u001b[39;49;00m s]\u001b[90m\u001b[39;49;00m\r\n                file_states = []\u001b[90m\u001b[39;49;00m\r\n                \u001b[94mfor\u001b[39;49;00m line \u001b[95min\u001b[39;49;00m lines:\u001b[90m\u001b[39;49;00m\r\n                    \u001b[94massert\u001b[39;49;00m line == line.strip(), \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mState line has whitespace: \u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33m{\u001b[39;49;00mline\u001b[33m}\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n                    file_states.append(line)\u001b[90m\u001b[39;49;00m\r\n                file_set = \u001b[96mset\u001b[39;49;00m(file_states)\u001b[90m\u001b[39;49;00m\r\n"]
[52.435697, "o", ">           \u001b[94massert\u001b[39;49;00m file_set == depth_sets[d], (\u001b[90m\u001b[39;49;00m\r\n                \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mLayer \u001b[39;49;00m\u001b[33m{\u001b[39;49;00md\u001b[33m}\u001b[39;49;00m\u001b[33m mismatch: file has \u001b[39;49;00m\u001b[33m{\u001b[39;49;00m\u001b[96mlen\u001b[39;49;00m(file_set)\u001b[33m}\u001b[39;49;00m\u001b[33m, \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n                \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mBFS has \u001b[39;49;00m\u001b[33m{\u001b[39;49;00m\u001b[96mlen\u001b[39;49;00m(depth_sets[d])\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            )\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31mE           AssertionError: Layer 30 mismatch: file has 91, BFS has 126\u001b[0m\r\n\u001b[1m\u001b[31mE           assert {'01000702050...7060805', ...} == {'01000702050...4030807', ...}\u001b[0m\r\n"]
[52.435763, "o", "\u001b[1m\u001b[31mE             \u001b[0m\r\n\u001b[1m\u001b[31mE             Extra items in the right set:\u001b[0m\r\n\u001b[1m\u001b[31mE             \u001b[0m\u001b[33m'\u001b[39;49;00m\u001b[33m030507060200080401\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\u001b[0m\r\n\u001b[1m\u001b[31mE             \u001b[0m\u001b[33m'\u001b[39;49;00m\u001b[33m080207040600030501\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\u001b[0m\r\n\u001b[1m\u001b[31mE             \u001b[0m\u001b[33m'\u001b[39;49;00m\u001b[33m080507000604030201\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\u001b[0m\r\n\u001b[1m\u001b[31mE             \u001b[0m\u001b[33m'\u001b[39;49;00m\u001b[33m010507020400030608\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\u001b[0m\r\n"]
