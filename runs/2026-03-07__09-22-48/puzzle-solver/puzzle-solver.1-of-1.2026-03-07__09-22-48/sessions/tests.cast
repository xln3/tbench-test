[52.412849, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_path_sequence_connected\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"Test that each move in path creates a connected sequence from start to goal\"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mread_puzzle_as_state\u001b[39;49;00m(filename):\u001b[90m\u001b[39;49;00m\r\n            \u001b[94massert\u001b[39;49;00m os.path.exists(filename), \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m{\u001b[39;49;00mfilename\u001b[33m}\u001b[39;49;00m\u001b[33m not found\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            tiles = []\u001b[90m\u001b[39;49;00m\r\n            \u001b[94mwith\u001b[39;49;00m \u001b[96mopen\u001b[39;49;00m(filename, \u001b[33m'\u001b[39;49;00m\u001b[33mr\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m) \u001b[94mas\u001b[39;49;00m f:\u001b[90m\u001b[39;49;00m\r\n                \u001b[94mfor\u001b[39;49;00m line \u001b[95min\u001b[39;49;00m f:\u001b[90m\u001b[39;49;00m\r\n                    tiles.extend([\u001b[96mint\u001b[39;49;00m(x) \u001b[94mfor\u001b[39;49;00m x \u001b[95min\u001b[39;49;00m line.split()])\u001b[90m\u001b[39;49;00m\r\n"]
[52.413002, "o", "            \u001b[94mreturn\u001b[39;49;00m \u001b[33m'\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m.join(\u001b[33mf\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33m{\u001b[39;49;00mt\u001b[33m:\u001b[39;49;00m\u001b[33m02d\u001b[39;49;00m\u001b[33m}\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m \u001b[94mfor\u001b[39;49;00m t \u001b[95min\u001b[39;49;00m tiles)\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        start_state = read_puzzle_as_state(\u001b[33m'\u001b[39;49;00m\u001b[33m/app/start.txt\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n        goal_state = read_puzzle_as_state(\u001b[33m'\u001b[39;49;00m\u001b[33m/app/goal.txt\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n        \u001b[94massert\u001b[39;49;00m os.path.exists(\u001b[33m'\u001b[39;49;00m\u001b[33m/app/path.tsv\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m), \u001b[33m\"\u001b[39;49;00m\u001b[33mpath.tsv not found\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[94mwith\u001b[39;49;00m \u001b[96mopen\u001b[39;49;00m(\u001b[33m'\u001b[39;49;00m\u001b[33m/app/path.tsv\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m, \u001b[33m'\u001b[39;49;00m\u001b[33mr\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m) \u001b[94mas\u001b[39;49;00m f:\u001b[90m\u001b[39;49;00m\r\n            reader = csv.DictReader(f, delimiter=\u001b[33m'\u001b[39;49;00m\u001b[33m\\t\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n            rows = \u001b[96mlist\u001b[39;49;00m(reader)\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n            \u001b[94mif\u001b[39;49;00m \u001b[96mlen\u001b[39;49;00m(rows) == \u001b[94m0\u001b[39;49;00m:\u001b[90m\u001b[39;49;00m\r\n                \u001b[90m# Empty path is only valid if start == goal\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n                \u001b[94massert\u001b[39;49;00m start_state == goal_state, (\u001b[90m\u001b[39;49;00m\r\n                    \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mEmpty path but start \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mstart_state\u001b[33m}\u001b[39;49;00m\u001b[33m != goal \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mgoal_state\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n                )\u001b[90m\u001b[39;49;00m\r\n                \u001b[94mreturn\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n            \u001b[90m# Validate sequence connectivity: start -> path[0] -> path[1] -> ... -> goal\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n"]
[52.413093, "o", "            current_state = start_state\u001b[90m\u001b[39;49;00m\r\n            visited_states = {start_state}  \u001b[90m# Track visited states to detect cycles\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n            \u001b[94mfor\u001b[39;49;00m i, row \u001b[95min\u001b[39;49;00m \u001b[96menumerate\u001b[39;49;00m(rows):\u001b[90m\u001b[39;49;00m\r\n                next_state = row[\u001b[33m'\u001b[39;49;00m\u001b[33mstate_key\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m]\u001b[90m\u001b[39;49;00m\r\n                moved_tile = \u001b[96mint\u001b[39;49;00m(row[\u001b[33m'\u001b[39;49;00m\u001b[33mtile\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m])\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n                \u001b[90m# Check for cycle - optimal BFS path should never revisit states\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n>               \u001b[94massert\u001b[39;49;00m next_state \u001b[95mnot\u001b[39;49;00m \u001b[95min\u001b[39;49;00m visited_states, (\u001b[90m\u001b[39;49;00m\r\n                    \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mStep \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mi\u001b[33m}\u001b[39;49;00m\u001b[33m: revisiting state \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mnext_state\u001b[33m}\u001b[39;49;00m\u001b[33m (cycle detected)\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n                )\u001b[90m\u001b[39;49;00m\r\n"]
[52.413271, "o", "\u001b[1m\u001b[31mE               AssertionError: Step 0: revisiting state 010203040506070008 (cycle detected)\u001b[0m\r\n\u001b[1m\u001b[31mE               assert '010203040506070008' not in {'010203040506070008'}\u001b[0m\r\n\r\n\u001b[1m\u001b[31m/tests/test_outputs.py\u001b[0m:206: AssertionError\r\n"]
