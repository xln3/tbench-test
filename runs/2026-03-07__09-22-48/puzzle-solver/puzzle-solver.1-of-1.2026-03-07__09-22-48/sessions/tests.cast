[52.402468, "o", "            \u001b[94mif\u001b[39;49;00m \u001b[96mlen\u001b[39;49;00m(rows) == \u001b[94m0\u001b[39;49;00m:\u001b[90m\u001b[39;49;00m\r\n                \u001b[90m# Empty path is only valid if start == goal\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n                \u001b[94massert\u001b[39;49;00m start_state == goal_state, (\u001b[90m\u001b[39;49;00m\r\n                    \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mEmpty path but start \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mstart_state\u001b[33m}\u001b[39;49;00m\u001b[33m != goal \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mgoal_state\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n                )\u001b[90m\u001b[39;49;00m\r\n            \u001b[94melse\u001b[39;49;00m:\u001b[90m\u001b[39;49;00m\r\n                \u001b[90m# Non-empty path must start from start state\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n                \u001b[90m# Validate that first move creates valid transition from start state\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n                first_move_tile = \u001b[96mint\u001b[39;49;00m(rows[\u001b[94m0\u001b[39;49;00m][\u001b[33m'\u001b[39;49;00m\u001b[33mtile\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m])\u001b[90m\u001b[39;49;00m\r\n                first_move_state = rows[\u001b[94m0\u001b[39;49;00m][\u001b[33m'\u001b[39;49;00m\u001b[33mstate_key\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m]\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n                \u001b[90m# Convert start state to tiles array for validation\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n                start_tiles = [\u001b[96mint\u001b[39;49;00m(start_state[i:i+\u001b[94m2\u001b[39;49;00m]) \u001b[94mfor\u001b[39;49;00m i \u001b[95min\u001b[39;49;00m \u001b[96mrange\u001b[39;49;00m(\u001b[94m0\u001b[39;49;00m, \u001b[94m18\u001b[39;49;00m, \u001b[94m2\u001b[39;49;00m)]\u001b[90m\u001b[39;49;00m\r\n                first_tiles = [\u001b[96mint\u001b[39;49;00m(first_move_state[i:i+\u001b[94m2\u001b[39;49;00m]) \u001b[94mfor\u001b[39;49;00m i \u001b[95min\u001b[39;49;00m \u001b[96mrange\u001b[39;49;00m(\u001b[94m0\u001b[39;49;00m, \u001b[94m18\u001b[39;49;00m, \u001b[94m2\u001b[39;49;00m)]\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n                \u001b[90m# Find blank position in start state\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n                blank_pos = start_tiles.index(\u001b[94m0\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n                blank_row, blank_col = \u001b[96mdivmod\u001b[39;49;00m(blank_pos, \u001b[94m3\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n                \u001b[90m# Find tile that moved in start state\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n                \u001b[94mtry\u001b[39;49;00m:\u001b[90m\u001b[39;49;00m\r\n>                   tile_pos = start_tiles.index(first_move_tile)\u001b[90m\u001b[39;49;00m\r\n                               ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31mE                   ValueError: -1 is not in list\u001b[0m\r\n"]
