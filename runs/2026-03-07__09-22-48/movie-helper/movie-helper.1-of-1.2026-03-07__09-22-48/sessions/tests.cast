[18.821172, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_matrix_completion_success_rate\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"\u001b[39;49;00m\r\n    \u001b[33m    Makes sure that after 20 iterations\u001b[39;49;00m\r\n    \u001b[33m    X_hat matrix properly approximates\u001b[39;49;00m\r\n    \u001b[33m    original X_star matrix.\u001b[39;49;00m\r\n    \u001b[33m    \"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        required_success_rate = \u001b[94m0.90\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        success_count = []\u001b[90m\u001b[39;49;00m\r\n        n = \u001b[94m200\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[94mfor\u001b[39;49;00m i \u001b[95min\u001b[39;49;00m \u001b[96mrange\u001b[39;49;00m(\u001b[94m20\u001b[39;49;00m):\u001b[90m\u001b[39;49;00m\r\n            np.random.seed(i)\u001b[90m\u001b[39;49;00m\r\n            y = np.random.randn(n, \u001b[94m1\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n            z = np.random.rand(n, \u001b[94m1\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n            X_star = y @ z.T\u001b[90m\u001b[39;49;00m\r\n>           X_hat = np.loadtxt(\u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33msolution_\u001b[39;49;00m\u001b[33m{\u001b[39;49;00mi\u001b[33m}\u001b[39;49;00m\u001b[33m.txt\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, delimiter=\u001b[33m\"\u001b[39;49;00m\u001b[33m,\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n"]
[18.821262, "o", "                    ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\u001b[90m\u001b[39;49;00m\r\n\r\n\u001b[1m\u001b[31m/tests/test_outputs.py\u001b[0m:34: \r\n_ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ \r\n\u001b[1m\u001b[31m.tbench-testing/lib/python3.11/site-packages/numpy/lib/_npyio_impl.py\u001b[0m:1384: in loadtxt\r\n"]
[18.821752, "o", "    \u001b[0marr = _read(fname, dtype=dtype, comment=comment, delimiter=delimiter,\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31m.tbench-testing/lib/python3.11/site-packages/numpy/lib/_npyio_impl.py\u001b[0m:1011: in _read\r\n"]
[18.822903, "o", "    \u001b[0mfh = np.lib._datasource.open(fname, \u001b[33m'\u001b[39;49;00m\u001b[33mrt\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m, encoding=encoding)\u001b[90m\u001b[39;49;00m\r\n         ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31m.tbench-testing/lib/python3.11/site-packages/numpy/lib/_datasource.py\u001b[0m:192: in open\r\n"]
[18.824122, "o", "    \u001b[0m\u001b[94mreturn\u001b[39;49;00m ds.open(path, mode, encoding=encoding, newline=newline)\u001b[90m\u001b[39;49;00m\r\n           ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\u001b[90m\u001b[39;49;00m\r\n_ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ \r\n"]
[18.824237, "o", "\r\nself = <numpy.lib.npyio.DataSource object at 0x7f5e28705690>, path = 'solution_0.txt', mode = 'rt', encoding = None, newline = None\r\n\r\n"]
[18.82662, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mopen\u001b[39;49;00m(\u001b[96mself\u001b[39;49;00m, path, mode=\u001b[33m'\u001b[39;49;00m\u001b[33mr\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m, encoding=\u001b[94mNone\u001b[39;49;00m, newline=\u001b[94mNone\u001b[39;49;00m):\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"\u001b[39;49;00m\r\n    \u001b[33m    Open and return file-like object.\u001b[39;49;00m\r\n    \u001b[33m\u001b[39;49;00m\r\n    \u001b[33m    If `path` is an URL, it will be downloaded, stored in the\u001b[39;49;00m\r\n    \u001b[33m    `DataSource` directory and opened from there.\u001b[39;49;00m\r\n    \u001b[33m\u001b[39;49;00m\r\n    \u001b[33m    Parameters\u001b[39;49;00m\r\n"]
[18.82666, "o", "    \u001b[33m    ----------\u001b[39;49;00m\r\n    \u001b[33m    path : str or pathlib.Path\u001b[39;49;00m\r\n    \u001b[33m        Local file path or URL to open.\u001b[39;49;00m\r\n    \u001b[33m    mode : {'r', 'w', 'a'}, optional\u001b[39;49;00m\r\n    \u001b[33m        Mode to open `path`.  Mode 'r' for reading, 'w' for writing,\u001b[39;49;00m\r\n    \u001b[33m        'a' to append. Available modes depend on the type of object\u001b[39;49;00m\r\n    \u001b[33m        specified by `path`. Default is 'r'.\u001b[39;49;00m\r\n    \u001b[33m    encoding : {None, str}, optional\u001b[39;49;00m\r\n    \u001b[33m        Open text file with given encoding. The default encoding will be\u001b[39;49;00m\r\n"]
[18.826788, "o", "    \u001b[33m        what `open` uses.\u001b[39;49;00m\r\n    \u001b[33m    newline : {None, str}, optional\u001b[39;49;00m\r\n    \u001b[33m        Newline to use when reading text file.\u001b[39;49;00m\r\n"]
[18.826889, "o", "    \u001b[33m\u001b[39;49;00m\r\n    \u001b[33m    Returns\u001b[39;49;00m\r\n    \u001b[33m    -------\u001b[39;49;00m\r\n    \u001b[33m    out : file object\u001b[39;49;00m\r\n    \u001b[33m        File object.\u001b[39;49;00m\r\n    \u001b[33m\u001b[39;49;00m\r\n    \u001b[33m    \"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# TODO: There is no support for opening a file for writing which\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[90m#       doesn't exist yet (creating a file).  Should there be?\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# TODO: Add a ``subdir`` parameter for specifying the subdirectory\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[90m#       used to store URLs in self._destpath.\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[94mif\u001b[39;49;00m \u001b[96mself\u001b[39;49;00m._isurl(path) \u001b[95mand\u001b[39;49;00m \u001b[96mself\u001b[39;49;00m._iswritemode(mode):\u001b[90m\u001b[39;49;00m\r\n"]
[18.827025, "o", "            \u001b[94mraise\u001b[39;49;00m \u001b[96mValueError\u001b[39;49;00m(\u001b[33m\"\u001b[39;49;00m\u001b[33mURLs are not writeable\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# NOTE: _findfile will fail on a new file opened for writing.\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        found = \u001b[96mself\u001b[39;49;00m._findfile(path)\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mif\u001b[39;49;00m found:\u001b[90m\u001b[39;49;00m\r\n            _fname, ext = \u001b[96mself\u001b[39;49;00m._splitzipext(found)\u001b[90m\u001b[39;49;00m\r\n            \u001b[94mif\u001b[39;49;00m ext == \u001b[33m'\u001b[39;49;00m\u001b[33mbz2\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m:\u001b[90m\u001b[39;49;00m\r\n                mode.replace(\u001b[33m\"\u001b[39;49;00m\u001b[33m+\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n            \u001b[94mreturn\u001b[39;49;00m _file_openers[ext](found, mode=mode,\u001b[90m\u001b[39;49;00m\r\n"]
