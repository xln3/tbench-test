[63.131383, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_model_speed\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"Test that new model is faster than the reference model\"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        model_path = app_dir / \u001b[33m\"\u001b[39;49;00m\u001b[33mmodel.xml\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        model_ref_path = app_dir / \u001b[33m\"\u001b[39;49;00m\u001b[33mmodel_ref.xml\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        model = mujoco.MjModel.from_xml_path(\u001b[96mstr\u001b[39;49;00m(model_path))\u001b[90m\u001b[39;49;00m\r\n        model_ref = mujoco.MjModel.from_xml_path(\u001b[96mstr\u001b[39;49;00m(model_ref_path))\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n"]
[63.131581, "o", "        times_model = simulation_time(model, n_runs=n_runs)\u001b[90m\u001b[39;49;00m\r\n        times_model = drop_extreme_percentiles(times_model, \u001b[94m5\u001b[39;49;00m, \u001b[94m95\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n        times_model_ref = simulation_time(model_ref, n_runs=n_runs)\u001b[90m\u001b[39;49;00m\r\n        times_model_ref = drop_extreme_percentiles(times_model_ref, \u001b[94m5\u001b[39;49;00m, \u001b[94m95\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n        speedup = (times_model_ref / times_model).mean().item()\u001b[90m\u001b[39;49;00m\r\n        act_time_pctg = (times_model / times_model_ref).mean().item()\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[96mprint\u001b[39;49;00m(\u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mAvg simulation time: \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mtimes_model.mean().item()\u001b[33m:\u001b[39;49;00m\u001b[33m.4f\u001b[39;49;00m\u001b[33m}\u001b[39;49;00m\u001b[33m secs\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n        \u001b[96mprint\u001b[39;49;00m(\u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mAvg simulation time (ref): \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mtimes_model_ref.mean().item()\u001b[33m:\u001b[39;49;00m\u001b[33m.4f\u001b"]
[63.131676, "o", "[39;49;00m\u001b[33m}\u001b[39;49;00m\u001b[33m secs\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n        \u001b[96mprint\u001b[39;49;00m(\u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mSpeedup: \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mspeedup\u001b[33m:\u001b[39;49;00m\u001b[33m.2f\u001b[39;49;00m\u001b[33m}\u001b[39;49;00m\u001b[33mx\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n        \u001b[96mprint\u001b[39;49;00m(\u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mTime pctg: \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mact_time_pctg\u001b[33m:\u001b[39;49;00m\u001b[33m.2f\u001b[39;49;00m\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n>       \u001b[94massert\u001b[39;49;00m act_time_pctg <= pctg, (\u001b[90m\u001b[39;49;00m\r\n            \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mTime pctg \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mact_time_pctg\u001b[90m \u001b[39;49;00m*\u001b[90m \u001b[39;49;00m\u001b[94m100\u001b[39;49;00m\u001b[33m:\u001b[39;49;00m\u001b[33m.2f\u001b[39;49;00m\u001b[33m}\u001b[39;49;00m\u001b[33m% (need \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mpctg\u001b[90m \u001b[39;49;00m*\u001b[90m \u001b[39;49;00m\u001b[94m100\u001b[39;49;00m\u001b[33m:\u001b[39;49;00m\u001b[33m.2f\u001b[39;49;00m\u001b[33m}\u001b[39;49;00m\u001b[33m%)\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n  "]
