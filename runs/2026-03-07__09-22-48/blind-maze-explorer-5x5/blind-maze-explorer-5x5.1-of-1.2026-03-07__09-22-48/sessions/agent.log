#!/usr/bin/env python3
"""
Maze Explorer - Systematically explores and maps a blind maze using DFS with backtracking
"""

import sys
import subprocess
import time
from collections import defaultdict
from typing import Dict, Tuple, List, Set, Optional


class MazeExplorer:
    def __init__(self):
        # Map representation: (x, y) -> char ('#' for wall, ' ' for space, 'S' for start, 'E' for exit)
        self.map: Dict[Tuple[int, int], str] = {}
        
        # Current position (x, y)
        self.current_pos: Tuple[int, int] = (0, 0)
        
        # Starting position
        self.start_pos: Tuple[int, int] = (0, 0)
        
        # Visited positions (positions we've been to)
        self.visited: Set[Tuple[int, int]] = set()
        
        # Stack for DFS backtracking: stores positions to return to
        self.stack: List[Tuple[int, int]] = []
        
        # Process for the maze game
        self.process: Optional[subprocess.Popen] = None
        
        # Track known exit position
        self.exit_pos: Optional[Tuple[int, int]] = None
        
        # Track all explored positions (including walls)
        self.explored: Set[Tuple[int, int]] = set()
        
        # Direction vectors
        self.directions = {
            'N': (0, -1),
            'S': (0, 1),
            'E': (1, 0),
            'W': (-1, 0)
        }
        
        self.opposite = {'N': 'S', 'S': 'N', 'E': 'W', 'W': 'E'}
        
    def start_game(self):
        """Start the maze game process"""
        self.process = subprocess.Popen(
            ['/app/maze_game.sh'],
            stdin=subprocess.PIPE,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            text=True,
            bufsize=1
        )
        
        # Read the welcome message
        self._read_until_prompt()
        print("Maze game started")
        
    def _read_until_prompt(self) -> str:
        """Read output until we see the prompt (>)"""
        output = ""
        if self.process.stdout is None:
            return output
            
        while True:
            char = self.process.stdout.read(1)
            if not char:
                break
            output += char
            if char == '>':
                break
        return output
    
    def send_command(self, command: str) -> str:
        """Send a command to the maze game and return the response"""
        if self.process.stdin is None:
            return ""
            
        self.process.stdin.write(command + '\n')
        self.process.stdin.flush()
        
        # Read the response (should be one line ending with >)
        response = self._read_until_prompt()
        
        # Extract just the response part (between > and next >)
        lines = response.strip().split('\n')
        if len(lines) >= 2:
            return lines[1].strip()
        return ""
    
    def move(self, direction: str) -> str:
        """
        Move in a single direction.
        Returns: "moved", "hit wall", or "reached exit"
        """
        command = f"move {direction}"
        response = self.send_command(command)
        result = response.strip()
        
        next_pos = self._get_next_pos(self.current_pos, direction)
        
        print(f"  Command: '{command}', Response: '{result}', Next pos: {next_pos}, Current pos before: {self.current_pos}", flush=True)
        
        if result == "moved":
            self.current_pos = next_pos
            self.visited.add(self.current_pos)
            self.map[self.current_pos] = ' '
            print(f"  -> Moved to {self.current_pos}")
        elif result == "reached exit":
            self.current_pos = next_pos
            self.exit_pos = self.current_pos
            self.visited.add(self.current_pos)
            self.map[self.current_pos] = 'E'
            print(f"  -> Reached exit at {self.current_pos}")
        elif result == "hit wall":
            self.map[next_pos] = '#'
            print(f"  -> Hit wall at {next_pos}")
        else:
            print(f"  -> Unknown response: {result}")
        
        self.explored.add(next_pos)
        
        return result
    
    def _get_next_pos(self, pos: Tuple[int, int], direction: str) -> Tuple[int, int]:
        """Calculate new position after moving in a direction"""
        x, y = pos
        dx, dy = self.directions[direction]
        return (x + dx, y + dy)
    
    def _get_neighbors(self, pos: Tuple[int, int]) -> Dict[str, Tuple[int, int]]:
        """Get all four neighboring positions"""
        neighbors = {}
        for direction, (dx, dy) in self.directions.items():
            x, y = pos
            neighbors[direction] = (x + dx, y + dy)
        return neighbors
    
    def _is_explored(self, pos: Tuple[int, int]) -> bool:
        """Check if a position has been explored (either visited or known wall)"""
        return pos in self.map or pos in self.explored
    
    def _get_unexplored_directions(self, pos: Tuple[int, int]) -> List[str]:
        """Get directions to unexplored neighbors"""
        neighbors = self._get_neighbors(pos)
        unexplored = []
        for direction, neighbor_pos in neighbors.items():
            if not self._is_explored(neighbor_pos):
                unexplored.append(direction)
        return unexplored
    
    def explore(self):
        """Main exploration algorithm using DFS"""
        print("Starting exploration...")
        
        # Mark starting position
        self.map[self.current_pos] = 'S'
        self.start_pos = self.current_pos
        self.visited.add(self.current_pos)
        self.explored.add(self.current_pos)
        
        moves = 0
        
        iteration = 0
        max_iterations = 1000
        
        while iteration < max_iterations:
            iteration += 1
            current = self.current_pos
            
            # Get unexplored directions from current position
            unexplored_dirs = self._get_unexplored_directions(current)
            
            print(f"\n=== Iteration {iteration} ===")
            print(f"Current position: {current}")
            print(f"Unexplored directions: {unexplored_dirs}")
            print(f"Stack size: {len(self.stack)}")
            
            if unexplored_dirs:
                # Try the first unexplored direction
                direction = unexplored_dirs[0]
                result = self.move(direction)
                moves += 1
                
                if result == "moved" or result == "reached exit":
                    # Successfully moved, push current position to stack for backtracking
                    self.stack.append(current)
                    print(f"  Stack after push: {self.stack}")
                # If hit wall, we stay at current position and will try next direction next iteration
            else:
                # No unexplored neighbors from current position
                if self.stack:
                    # Backtrack to previous position
                    prev_pos = self.stack.pop()
                    print(f"\nNo unexplored. Backtracking from {current} to {prev_pos}")
                    
                    # Move back to prev_pos (should be adjacent)
                    cx, cy = self.current_pos
                    px, py = prev_pos
                    
                    if cx < px:
                        backtrack_dir = 'E'
                    elif cx > px:
                        backtrack_dir = 'W'
                    elif cy < py:
                        backtrack_dir = 'S'
                    elif cy > py:
                        backtrack_dir = 'N'
                    else:
                        print("  Warning: Already at prev_pos!")
                        continue
                    
                    print(f"  Backtrack direction: {backtrack_dir}")
                    result = self.move(backtrack_dir)
                    moves += 1
                    
                    if result not in ["moved", "reached exit"]:
                        print(f"Warning: Backtrack failed: {result}")
                else:
                    # No more places to explore, we're done
                    print("\nNo more unexplored positions and stack is empty. Exploration complete!")
                    break
        
        print(f"\nExploration complete! Total moves: {moves}, Iterations: {iteration}")
        print(f"Visited positions: {len(self.visited)}")
        print(f"Known walls: {sum(1 for v in self.map.values() if v == '#')}")
        if self.exit_pos:
            print(f"Exit found at: {self.exit_pos}")
        print(f"Total explored positions: {len(self.explored)}")
    
    def exit_game(self):
        """Exit the maze game"""
        if self.process:
            self.send_command("exit")
            try:
                self.process.wait(timeout=2)
            except:
                pass
            print("Game exited")
    
    def generate_map_file(self, filename: str):
        """Generate the maze map file"""
        if not self.map:
            print("No map data available!")
            return
        
        # Find bounds of the map
        xs = [pos[0] for pos in self.map.keys()]
        ys = [pos[1] for pos in self.map.keys()]
        
        min_x, max_x = min(xs), max(xs)
        min_y, max_y = min(ys), max(ys)
        
        print(f"\nMap bounds: x[{min_x}, {max_x}], y[{min_y}, {max_y}]")
        
        # Build the map grid
        lines = []
        for y in range(min_y, max_y + 1):
            line = []
            for x in range(min_x, max_x + 1):
                pos = (x, y)
                if pos in self.map:
                    line.append(self.map[pos])
                else:
                    # This should be a wall (unexplored boundary)
                    line.append('#')
            lines.append(''.join(line))
        
        # Write to file
        with open(filename, 'w') as f:
            for line in lines:
                f.write(line + '\n')
        
        print(f"Map written to {filename}")
        
        # Print the map for debugging
        print("\nGenerated Map:")
        for line in lines:
            print(repr(line))
    
    def run(self):
        """Run the complete exploration"""
        try:
            self.start_game()
            self.explore()
            self.exit_game()
            self.generate_map_file('/app/maze_map.txt')
        except KeyboardInterrupt:
            print("\nInterrupted by user")
            self.exit_game()
        except Exception as e:
            print(f"Error: {e}")
            import traceback
            traceback.print_exc()
            self.exit_game()
            raise


if __name__ == "__main__":
    explorer = MazeExplorer()
    explorer.run()
