[52.698178, "o", "\r\n=========================================================================== FAILURES ===========================================================================\r\n\u001b[31m\u001b[1m_______________________________________________________________ test_mag_csv_matches_scipy_stft ________________________________________________________________\u001b[0m\r\n\r\n"]
[52.757201, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_mag_csv_matches_scipy_stft\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"mag.csv equals STFT (Hann, hop=256, n_fft=1024, center=False) using scipy.\"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# load wav as float32\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        sr, data = wavfile.read(Path(\u001b[33m\"\u001b[39;49;00m\u001b[33m/app/data/clip.wav\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m))\u001b[90m\u001b[39;49;00m\r\n        x = data.astype(np.float32) / \u001b[94m32767.0\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        mag_csv = _load_mag_csv_array()\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Compute STFT using scipy\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n"]
[52.75737, "o", "        \u001b[94mfrom\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[04m\u001b[96mscipy\u001b[39;49;00m\u001b[04m\u001b[96m.\u001b[39;49;00m\u001b[04m\u001b[96msignal\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[94mimport\u001b[39;49;00m stft \u001b[94mas\u001b[39;49;00m sp_stft\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        f, t, Zxx = sp_stft(\u001b[90m\u001b[39;49;00m\r\n            x,\u001b[90m\u001b[39;49;00m\r\n            fs=sr,\u001b[90m\u001b[39;49;00m\r\n            window=\u001b[33m\"\u001b[39;49;00m\u001b[33mhann\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n            nperseg=\u001b[94m1024\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n            noverlap=\u001b[94m1024\u001b[39;49;00m - \u001b[94m256\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n            nfft=\u001b[94m1024\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n            boundary=\u001b[94mNone\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n"]
[52.757398, "o", "            padded=\u001b[94mFalse\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n            return_onesided=\u001b[94mTrue\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n        )\u001b[90m\u001b[39;49;00m\r\n        mag_ref = np.abs(Zxx)  \u001b[90m# [513, 184]\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[94massert\u001b[39;49;00m mag_csv.shape == mag_ref.shape == (\u001b[94m513\u001b[39;49;00m, \u001b[94m184\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# allow tiny CSV float round trip; should be extremely close\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n>       \u001b[94massert\u001b[39;49;00m np.allclose(mag_csv, mag_ref, rtol=\u001b[94m1e-5\u001b[39;49;00m, atol=\u001b[94m1e-6\u001b[39;49;00m), (\u001b[90m\u001b[39;49;00m\r\n            \u001b[33m\"\u001b[39;49;00m\u001b[33mmag.csv does not match Hann STFT magnitude.\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        )\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31mE       AssertionError: mag.csv does not match Hann STFT magnitude.\u001b[0m\r\n\u001b[1m\u001b[31mE       assert False\u001b[0m\r\n"]
