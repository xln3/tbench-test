[57.691057, "o", "                stdout=tmp_stdout,\u001b[90m\u001b[39;49;00m\r\n                stderr=subprocess.STDOUT,\u001b[90m\u001b[39;49;00m\r\n                text=\u001b[94mTrue\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n            )\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n            \u001b[90m# Wait for the frame.bmp file to be created\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            frame_path = Path(\u001b[33m\"\u001b[39;49;00m\u001b[33m/tmp/frame.bmp\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n            timeout = \u001b[94m30\u001b[39;49;00m  \u001b[90m# 30 seconds timeout\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            start_time = time.time()\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n            \u001b[94mwhile\u001b[39;49;00m \u001b[95mnot\u001b[39;49;00m frame_path.exists():\u001b[90m\u001b[39;49;00m\r\n                \u001b[94mif\u001b[39;49;00m time.time() - start_time > timeout:\u001b[90m\u001b[39;49;00m\r\n                    process.kill()\u001b[90m\u001b[39;49;00m\r\n>                   \u001b[94mraise\u001b[39;49;00m \u001b[96mTimeoutError\u001b[39;49;00m(\u001b[33m\"\u001b[39;49;00m\u001b[33mTimeout waiting for frame.bmp to be created\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n"]
