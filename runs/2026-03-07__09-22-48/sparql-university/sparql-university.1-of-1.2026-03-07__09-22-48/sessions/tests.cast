[38.183484, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_sparql_query_results\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"\u001b[39;49;00m\r\n    \u001b[33m    Test that the SPARQL query returns the expected professor names and countries.\u001b[39;49;00m\r\n    \u001b[33m    The order of professors and the order of countries\u001b[39;49;00m\r\n"]
[38.183601, "o", "    \u001b[33m    within the country string are ignored.\u001b[39;49;00m\r\n    \u001b[33m    \"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Load query\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        query_text = SPARQL_PATH.read_text()\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Load RDF graph\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        g = Graph()\u001b[90m\u001b[39;49;00m\r\n"]
[38.183676, "o", "        g.parse(\u001b[96mstr\u001b[39;49;00m(DATA_PATH), \u001b[96mformat\u001b[39;49;00m=\u001b[33m\"\u001b[39;49;00m\u001b[33mttl\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Execute query\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        results = g.query(query_text)\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mnormalize_countries\u001b[39;49;00m(countries_str):\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m        \u001b[39;49;00m\u001b[33m\"\"\"Sort countries alphabetically to ignore order.\"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            countries = [c.strip() \u001b[94mfor\u001b[39;49;00m c \u001b[95min\u001b[39;49;00m countries_str.split(\u001b[33m\"\u001b[39;49;00m\u001b[33m,\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)]\u001b[90m\u001b[39;49;00m\r\n            \u001b[94mreturn\u001b[39;49;00m \u001b[33m\"\u001b[39;49;00m\u001b[33m, \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m.join(\u001b[96msorted\u001b[39;49;00m(countries))\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Convert query results to comparable form\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        result_set = \u001b[96mset\u001b[39;49;00m(\u001b[90m\u001b[39;49;00m\r\n            (\u001b[96mstr\u001b[39;49;00m(row.professorName), normalize_countries(\u001b[96mstr\u001b[39;49;00m(row.countries)))\u001b[90m\u001b[39;49;00m\r\n            \u001b[94mfor\u001b[39;49;00m row \u001b[95min\u001b[39;49;00m results\u001b[90m\u001b[39;49;00m\r\n        )\u001b[90m\u001b[39;49;00m\r\n        reference_set = \u001b[96mset\u001b[39;49;00m(\u001b[90m\u001b[39;49;00m\r\n            (\u001b[96mstr\u001b[39;49;00m(name), normalize_countries(\u001b[96mstr\u001b[39;49;00m(countries)))\u001b[90m\u001b[39;49;00m\r\n"]
[38.183706, "o", "            \u001b[94mfor\u001b[39;49;00m name, countries \u001b[95min\u001b[39;49;00m REFERENCE_RESULTS\u001b[90m\u001b[39;49;00m\r\n        )\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n>       \u001b[94massert\u001b[39;49;00m result_set == reference_set, (\u001b[90m\u001b[39;49;00m\r\n            \u001b[33m\"\u001b[39;49;00m\u001b[33mQuery results do not match reference.\u001b[39;49;00m\u001b[33m\\n\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mGot: \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mresult_set\u001b[33m}\u001b[39;49;00m\u001b[33m\\n\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mExpected: \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mreference_set\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        )\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31mE       AssertionError: Query results do not match reference.\u001b[0m\r\n"]
[38.183733, "o", "\u001b[1m\u001b[31mE         Got: {('Giorgos Stamou', 'GR'), ('Aristotle Tympas', 'GR'), ('Chrysoula Zerva', 'GR')}\u001b[0m\r\n\u001b[1m\u001b[31mE         Expected: {('Alex Dimakis', 'CH, ES, US'), ('Aristotle Tympas', 'GR'), ('Giorgos Stamou', 'GR, US'), ('Chrysoula Zerva', 'GR, PT')}\u001b[0m\r\n"]
