[12.785837, "o", "            args = [args]\u001b[90m\u001b[39;49;00m\r\n        \u001b[94melse\u001b[39;49;00m:\u001b[90m\u001b[39;49;00m\r\n"]
[12.785866, "o", "            args = \u001b[96mlist\u001b[39;49;00m(args)\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n"]
[12.785891, "o", "        \u001b[94mif\u001b[39;49;00m shell:\u001b[90m\u001b[39;49;00m\r\n            \u001b[90m# On Android the default shell is at '/system/bin/sh'.\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n"]
[12.785916, "o", "            unix_shell = (\u001b[33m'\u001b[39;49;00m\u001b[33m/system/bin/sh\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m \u001b[94mif\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n"]
[12.785943, "o", "                      \u001b[96mhasattr\u001b[39;49;00m(sys, \u001b[33m'\u001b[39;49;00m\u001b[33mgetandroidapilevel\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m) \u001b[94melse\u001b[39;49;00m \u001b[33m'\u001b[39;49;00m\u001b[33m/bin/sh\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n            args = [unix_shell, \u001b[33m\"\u001b[39;49;00m\u001b[33m-c\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m] + args\u001b[90m\u001b[39;49;00m\r\n"]
