[12.76937, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_caffe_version_and_source\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"Test that Caffe version is 1.0.0 and was cloned from BVLC\"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        caffe_base = Path(\u001b[33m\"\u001b[39;49;00m\u001b[33m/app/caffe\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n        caffe_path = caffe_base / \u001b[33m\"\u001b[39;49;00m\u001b[33m.build_release/tools/caffe.bin\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Check version\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n>       result = subprocess.run(\u001b[90m\u001b[39;49;00m\r\n            [\u001b[96mstr\u001b[39;49;00m(caffe_path), \u001b[33m\"\u001b[39;49;00m\u001b[33m--version\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m], capture_output=\u001b[94mTrue\u001b[39;49;00m, text=\u001b[94mTrue\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        )\u001b[90m\u001b[39;49;00m\r\n\r\n"]
