[123.595296, "o", "\r\n=========================================================================== FAILURES ===========================================================================\r\n\u001b[31m\u001b[1m________________________________________________________________ test_apply_macros_well_formed _________________________________________________________________\u001b[0m\r\n\r\n"]
[123.667553, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_apply_macros_well_formed\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"\u001b[39;49;00m\r\n    \u001b[33m    Ensure the Vim macros script is well-formed and includes required commands and\u001b[39;49;00m\r\n    \u001b[33m    only valid commands.\u001b[39;49;00m\r\n    \u001b[33m    \"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        text = APPLY_SCRIPT.read_text(encoding=\u001b[33m\"\u001b[39;49;00m\u001b[33mutf-8\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, errors=\u001b[33m\"\u001b[39;49;00m\u001b[33mignore\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Parse the script content\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n"]
[123.667764, "o", "        lines = [\u001b[90m\u001b[39;49;00m\r\n            line.strip()\u001b[90m\u001b[39;49;00m\r\n            \u001b[94mfor\u001b[39;49;00m line \u001b[95min\u001b[39;49;00m text.split(\u001b[33m\"\u001b[39;49;00m\u001b[33m\\n\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n            \u001b[94mif\u001b[39;49;00m line.strip() \u001b[95mand\u001b[39;49;00m \u001b[95mnot\u001b[39;49;00m line.strip().startswith(\u001b[33m'\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n        ]\u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Any use of :%normal! must be exactly with @a/@b/@c\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        other_normals = re.findall(\u001b[33mr\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m^\u001b[39;49;00m\u001b[33m\\\u001b[39;49;00m\u001b[33ms*:\u001b[39;49;00m\u001b[33m%\u001b[39;49;00m\u001b[33mnormal!\u001b[39;49;00m\u001b[33m\\\u001b[39;49;00m\u001b[33ms+(\u001b[39;49;00m\u001b[33m\\\u001b[39;49;00m\u001b[33mS+)\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, text, re.MULTILINE)\u001b[90m\u001b[39;49;00m\r\n        \u001b[94massert\u001b[39;49;00m \u001b[96mall\u001b[39;49;00m(tok \u001b[95min\u001b[39;49;00m (\u001b[33m\"\u001b[39;49;00m\u001b[33m@a\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33m@b\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33m@c\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m) \u001b[94mfor\u001b[39;49;00m tok \u001b[95min\u001b[39;49;00m other_normals), (\u001b[90m\u001b[39;49;00m\r\n            \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mOnly @a/@b/@c may be used with :%normal!, found: \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mother_normals\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        )\u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Check for required components\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        has_exit = \u001b[96many\u001b[39;49;00m(line \u001b[95min\u001b[39;49;00m (\u001b[33m\"\u001b[39;49;00m\u001b[33m:wq\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33m:x\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m) \u001b[94mfor\u001b[39;49;00m line \u001b[95min\u001b[39;49;00m lines)\u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Check for setreg calls for all three registers (flexible quote matching)\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        setreg_a = \u001b[96many\u001b[39;49;00m(re.search(\u001b[33mr\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mcall setreg\u001b[39;49;00m\u001b[33m\\\u001b[39;49;00m\u001b[33m([\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33m\\\"\u001b[39;49;00m\u001b[33m]a[\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33m\\\"\u001b[39;49;00m\u001b[33m],\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, line) \u001b[94mfor\u001b[39;49;00m line \u001b[95min\u001b[39;49;00m lines)\u001b[90m\u001b[39;49;00m\r\n        setreg_b = \u001b[96many\u001b[39;49;00m(re.search(\u001b[33mr\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mcall setreg\u001b[39;49;00m\u001b[33m\\\u001b[39;49;00m\u001b[33m([\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33m\\\"\u001b[39;49;00m\u001b[33m]b[\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33m\\\"\u001b[39;49;00m\u001b[33m],\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, line) \u001b[94mfor\u001b[39;49;00m line \u001b[95min\u001b[39;49;00m lines)\u001b[90m\u001b[39;49;00m\r\n        setreg_c = \u001b[96many\u001b[39;49;00m(re.search(\u001b[33mr\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mcall setreg\u001b[39;49;00m\u001b[33m\\\u001b[39;49;00m\u001b[33m([\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33m\\\"\u001b[39;49;00m\u001b[33m]c[\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33m\\\"\u001b[39;49;00m\u001b[33m],\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, line) \u001b[94mfor\u001b[39;49;00m line \u001b[95min\u001b[39;49;00m lines)\u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Check for macro execution calls for all three registers\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        exec_a = \u001b[96many\u001b[39;49;00m(\u001b[33m\"\u001b[39;49;00m\u001b[33m:\u001b[39;49;00m\u001b[33m%\u001b[39;49;00m\u001b[33mnormal! @a\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m \u001b[95min\u001b[39;49;00m line \u001b[94mfor\u001b[39;49;00m line \u001b[95min\u001b[39;49;00m lines)\u001b[90m\u001b[39;49;00m\r\n        exec_b = \u001b[96many\u001b[39;49;00m(\u001b[33m\"\u001b[39;49;00m\u001b[33m:\u001b[39;49;00m\u001b[33m%\u001b[39;49;00m\u001b[33mnormal! @b\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m \u001b[95min\u001b[39;49;00m line \u001b[94mfor\u001b[39;49;00m line \u001b[95min\u001b[39;49;00m lines)\u001b[90m\u001b[39;49;00m\r\n        exec_c = \u001b[96many\u001b[39;49;00m(\u001b[33m\"\u001b[39;49;00m\u001b[33m:\u001b[39;49;00m\u001b[33m%\u001b[39;49;00m\u001b[33mnormal! @c\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m \u001b[95min\u001b[39;49;00m line \u001b[94mfor\u001b[39;49;00m line \u001b[95min\u001b[39;49;00m lines)\u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Validate required components\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n>       \u001b[94massert\u001b[39;49;00m has_exit, \u001b[33m\"\u001b[39;49;00m\u001b[33mMissing :wq or :x\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n"]
[123.667852, "o", "\u001b[1m\u001b[31mE       AssertionError: Missing :wq or :x\u001b[0m\r\n\u001b[1m\u001b[31mE       assert False\u001b[0m\r\n\r\n\u001b[1m\u001b[31m/tests/test_outputs.py\u001b[0m:156: AssertionError\r\n"]
[123.667983, "o", "\u001b[31m\u001b[1m______________________________________________________________ test_macros_nonempty_and_efficient ______________________________________________________________\u001b[0m\r\n\r\n"]
[123.673211, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_macros_nonempty_and_efficient\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"\u001b[39;49;00m\r\n    \u001b[33m    Verify that macros a, b, and c are non-empty, pairwise distinct, and efficient\u001b[39;49;00m\r\n    \u001b[33m    (total keystrokes < 200).\u001b[39;49;00m\r\n    \u001b[33m    \"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        tmp_script = Path(\u001b[33m\"\u001b[39;49;00m\u001b[33m/app/_defs_only.vim\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n        _write_defs_only_script(APPLY_SCRIPT, tmp_script)\u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Run Vim headlessly to source only the defs and emit counts/contents\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        res = _run([\u001b[33m\"\u001b[39;49;00m\u001b[33mvim\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33m-Nu\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33mNONE\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33m-n\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33m-Es\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33m-S\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[96mstr\u001b[39;49;00m(tmp_script)])\u001b[90m\u001b[39;49;00m\r\n        \u001b[94massert\u001b[39;49;00m res.returncode == \u001b[94m0\u001b[39;49;00m, \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mVim exited with code \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mres.returncode\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n"]
[123.673407, "o", "        ks_out = Path(\u001b[33m\"\u001b[39;49;00m\u001b[33m/app/vim_keystrokes.out\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n        regs_out = Path(\u001b[33m\"\u001b[39;49;00m\u001b[33m/app/vim_regs.out\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n        \u001b[94massert\u001b[39;49;00m ks_out.exists(), \u001b[33m\"\u001b[39;49;00m\u001b[33mExpected keystroke output file was not created\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[94massert\u001b[39;49;00m regs_out.exists(), \u001b[33m\"\u001b[39;49;00m\u001b[33mExpected registers output file was not created\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Parse keystroke counts\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        line = ks_out.read_text(encoding=\u001b[33m\"\u001b[39;49;00m\u001b[33mutf-8\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, errors=\u001b[33m\"\u001b[39;49;00m\u001b[33mignore\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m).strip()\u001b[90m\u001b[39;49;00m\r\n        m = re.match(\u001b[33mr\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m^KEYSTROKES a=(\u001b[39;49;00m\u001b[33m\\\u001b[39;49;00m\u001b[33md+) b=(\u001b[39;49;00m\u001b[33m\\\u001b[39;49;00m\u001b[33md+) c=(\u001b[39;49;00m\u001b[33m\\\u001b[39;49;00m\u001b[33md+) total=(\u001b[39;49;00m\u001b[33m\\\u001b[39;49;00m\u001b[33md+)$\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, line)\u001b[90m\u001b[39;49;00m\r\n        \u001b[94massert\u001b[39;49;00m m, \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mCould not parse keystrokes line: \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mline\u001b[33m!r}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        a, b, c, total = \u001b[96mmap\u001b[39;49;00m(\u001b[96mint\u001b[39;49;00m, m.groups())\u001b[90m\u001b[39;49;00m\r\n>       \u001b[94massert\u001b[39;49;00m a > \u001b[94m0\u001b[39;49;00m \u001b[95mand\u001b[39;49;00m b > \u001b[94m0\u001b[39;49;00m \u001b[95mand\u001b[39;49;00m c > \u001b[94m0\u001b[39;49;00m, \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mMacros must be non-empty: a=\u001b[39;49;00m\u001b[33m{\u001b[39;49;00ma\u001b[33m}\u001b[39;49;00m\u001b[33m b=\u001b[39;49;00m\u001b[33m{\u001b[39;49;00mb\u001b[33m}\u001b[39;49;00m\u001b[33m c=\u001b[39;49;00m\u001b[33m{\u001b[39;49;00mc\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31mE       AssertionError: Macros must be non-empty: a=9 b=46 c=0\u001b[0m\r\n\u001b[1m\u001b[31mE       assert (9 > 0 and 46 > 0 and 0 > 0)\u001b[0m\r\n\r\n\u001b[1m\u001b[31m/tests/test_outputs.py\u001b[0m:213: AssertionError\r\n"]
