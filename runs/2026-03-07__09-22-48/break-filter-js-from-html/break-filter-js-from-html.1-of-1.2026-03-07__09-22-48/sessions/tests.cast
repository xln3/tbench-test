[26.22302, "o", "\u001b[31m\u001b[1m________________________________________________________________ test_out_html_bypasses_filter _________________________________________________________________\u001b[0m\r\n\r\n"]
[26.335058, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_out_html_bypasses_filter\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"Test that out.html still triggers an alert after being filtered.\"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mimport\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[04m\u001b[96msubprocess\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n"]
[26.335242, "o", "        out_path = Path(\u001b[33m\"\u001b[39;49;00m\u001b[33m/app/out.html\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# First check the file exists\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[94massert\u001b[39;49;00m out_path.exists(), \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mFile \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mout_path\u001b[33m}\u001b[39;49;00m\u001b[33m does not exist\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Create a temporary copy of the file to filter\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mwith\u001b[39;49;00m tempfile.NamedTemporaryFile(mode=\u001b[33m\"\u001b[39;49;00m\u001b[33mw\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, suffix=\u001b[33m\"\u001b[39;49;00m\u001b[33m.html\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, delete=\u001b[94mFalse\u001b[39;49;00m) \u001b[94mas\u001b[39;49;00m f:\u001b[90m\u001b[39;49;00m\r\n"]
[26.335429, "o", "            \u001b[90m# Copy the original content to temp file\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            f.write(out_path.read_text())\u001b[90m\u001b[39;49;00m\r\n            filtered_path = Path(f.name)\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Apply the filter using command-line interface (modifies file in-place)\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        result = subprocess.run(\u001b[90m\u001b[39;49;00m\r\n            [\u001b[33m\"\u001b[39;49;00m\u001b[33mpython\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33m/tests/filter.py\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[96mstr\u001b[39;49;00m(filtered_path)],\u001b[90m\u001b[39;49;00m\r\n            capture_output=\u001b[94mTrue\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n            text=\u001b[94mTrue\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n        )\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Check if filter ran successfully\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n"]
[26.335503, "o", "        \u001b[94massert\u001b[39;49;00m result.returncode == \u001b[94m0\u001b[39;49;00m, \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mFilter failed with error: \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mresult.stderr\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Setup Chrome options for headless mode\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        chrome_options = Options()\u001b[90m\u001b[39;49;00m\r\n        chrome_options.add_argument(\u001b[33m\"\u001b[39;49;00m\u001b[33m--headless\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n        chrome_options.add_argument(\u001b[33m\"\u001b[39;49;00m\u001b[33m--no-sandbox\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n        chrome_options.add_argument(\u001b[33m\"\u001b[39;49;00m\u001b[33m--disable-dev-shm-usage\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n        chrome_options.add_argument(\u001b[33m\"\u001b[39;49;00m\u001b[33m--disable-gpu\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n        chrome_options.add_argument(\u001b[33m\"\u001b[39;49;00m\u001b[33m--window-size=1920,1080\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[9"]
[26.335634, "o", "0m# Use Chromium as Chrome\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        chrome_options.binary_location = \u001b[33m\"\u001b[39;49;00m\u001b[33m/usr/bin/chromium\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Initialize the Chrome driver with explicit service\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        driver = \u001b[94mNone\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        alert_detected = \u001b[94mFalse\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        alert_text = \u001b[94mNone\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[94mtry\u001b[39;49;00m:\u001b[90m\u001b[39;49;00m\r\n"]
[26.335704, "o", "            service = Service(executable_path=\u001b[33m\"\u001b[39;49;00m\u001b[33m/usr/bin/chromedriver\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n            driver = webdriver.Chrome(service=service, options=chrome_options)\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n            \u001b[90m# Load the FILTERED HTML file (already filtered in-place)\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            file_url = \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mfile://\u001b[39;49;00m\u001b[33m{\u001b[39;49;00mfiltered_path.absolute()\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            driver.get(file_url)\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n            \u001b[90m# Wait for potential alert (5 second timeout)\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            \u001b[94mtry\u001b[39;49;00m:\u001b[90m\u001b[39;49;00m\r\n                WebDriverWait(driver, \u001b[94m5\u001b[39;49;00m).until(EC.alert_is_present())\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n                \u001b[90m# Switch to alert and get text\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n"]
[26.335773, "o", "                alert = driver.switch_to.alert\u001b[90m\u001b[39;49;00m\r\n                alert_text = alert.text\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n                \u001b[90m# Accept the alert to close it\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n                alert.accept()\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n"]
[26.335836, "o", "                alert_detected = \u001b[94mTrue\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n            \u001b[94mexcept\u001b[39;49;00m TimeoutException:\u001b[90m\u001b[39;49;00m\r\n                \u001b[90m# No alert appeared within timeout\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n                alert_detected = \u001b[94mFalse\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n"]
[26.335894, "o", "    \u001b[90m\u001b[39;49;00m\r\n        \u001b[94mfinally\u001b[39;49;00m:\u001b[90m\u001b[39;49;00m\r\n            \u001b[94mif\u001b[39;49;00m driver:\u001b[90m\u001b[39;49;00m\r\n                driver.quit()\u001b[90m\u001b[39;49;00m\r\n            \u001b[90m# Clean up temp file\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            filtered_path.unlink(missing_ok=\u001b[94mTrue\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n"]
