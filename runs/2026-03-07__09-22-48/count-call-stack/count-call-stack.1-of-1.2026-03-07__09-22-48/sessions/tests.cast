[55.013506, "o", "            content = f.read().strip()\u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Check if the content matches the expected output\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mwith\u001b[39;49;00m \u001b[96mopen\u001b[39;49;00m(\u001b[33m\"\u001b[39;49;00m\u001b[33m/tests/expected_output.txt\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33mr\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m) \u001b[94mas\u001b[39;49;00m f:\u001b[90m\u001b[39;49;00m\r\n            expected_output = f.read().strip()\u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Compare content line-by-line to enforce output format.\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        expected_lines = [line.rstrip() \u001b[94mfor\u001b[39;49;00m line \u001b[95min\u001b[39;49;00m expected_output.splitlines()]\u001b[90m\u001b[39;49;00m\r\n        content_lines = [line.rstrip() \u001b[94mfor\u001b[39;49;00m line \u001b[95min\u001b[39;49;00m content.splitlines()]\u001b[90m\u001b[39;49;00m\r\n>       \u001b[94massert\u001b[39;49;00m content_lines == expected_lines, (\u001b[90m\u001b[39;49;00m\r\n            \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mContent of \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mlog_path\u001b[33m}\u001b[39;49;00m\u001b[33m does not match expected output\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        )\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31mE       AssertionError: Content of /app/output.txt does not match expected output\u001b[0m\r\n\u001b[1m\u001b[31mE       assert ['Found 646 s...es:', '', ...] == ['Found 646 s...es:', '', ...]\u001b[0m\r\n\u001b[1m\u001b[31mE         \u001b[0m\r\n"]
