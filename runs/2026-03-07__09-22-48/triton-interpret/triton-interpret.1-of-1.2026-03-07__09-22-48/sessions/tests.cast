[119.076624, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_gate_triton_equivalence\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"Test that gate_triton produces equivalent results\u001b[39;49;00m\r\n    \u001b[33m    to PyTorch reference implementation\u001b[39;49;00m\r\n    \u001b[33m    \"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        os.environ[\u001b[33m\"\u001b[39;49;00m\u001b[33mTRITON_INTERPRET\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m] = \u001b[33m\"\u001b[39;49;00m\u001b[33m1\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Load agent solution\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        sol_file = \u001b[33m\"\u001b[39;49;00m\u001b[33m/app/triton_agent_sol.py\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        spec = importlib.util.spec_from_file_location(\u001b[33m\"\u001b[39;49;00m\u001b[33mtriton_agent_sol\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, sol_file)\u001b[90m\u001b[39;49;00m\r\n"]
[119.076807, "o", "        module = importlib.util.module_from_spec(spec)\u001b[90m\u001b[39;49;00m\r\n        spec.loader.exec_module(module)\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        gate_triton = module.gate_triton\u001b[90m\u001b[39;49;00m\r\n        Gated = load_pytorch_reference()\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Test case 1\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        torch.manual_seed(\u001b[94m0\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n        B, S, D, width = \u001b[94m2\u001b[39;49;00m, \u001b[94m4\u001b[39;49;00m, \u001b[94m16\u001b[39;49;00m, \u001b[94m4\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        device = \u001b[33m\"\u001b[39;49;00m\u001b[33mcpu\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        mod = Gated(D, width=width, eps=\u001b[94m1e-6\u001b[39;49;00m).to(device).eval()\u001b[90m\u001b[39;49;00m\r\n        xin = torch.randn(B, S, D, device=device, dtype=torch.float32)\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[94mwith\u001b[39;49;00m torch.no_grad():\u001b[90m\u001b[39;49;00m\r\n            y_reference = mod(xin)\u001b[90m\u001b[39;49;00m\r\n        y_agent = gate_triton(xin, mod.weight, mod.alpha, mod.rmsnorm.weight, eps=\u001b[94m1e-"]
