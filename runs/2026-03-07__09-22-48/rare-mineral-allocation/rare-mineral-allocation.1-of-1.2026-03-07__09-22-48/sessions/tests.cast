[16.75931, "o", "    \u001b[33m        specified by `path`. Default is 'r'.\u001b[39;49;00m\r\n    \u001b[33m    encoding : {None, str}, optional\u001b[39;49;00m\r\n    \u001b[33m        Open text file with given encoding. The default encoding will be\u001b[39;49;00m\r\n    \u001b[33m        what `open` uses.\u001b[39;49;00m\r\n    \u001b[33m    newline : {None, str}, optional\u001b[39;49;00m\r\n    \u001b[33m        Newline to use when reading text file.\u001b[39;49;00m\r\n    \u001b[33m\u001b[39;49;00m\r\n    \u001b[33m    Returns\u001b[39;49;00m\r\n    \u001b[33m    -------\u001b[39;49;00m\r\n    \u001b[33m    out : file object\u001b[39;49;00m\r\n    \u001b[33m        File object.\u001b[39;49;00m\r\n    \u001b[33m\u001b[39;49;00m\r\n    \u001b[33m    \"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# TODO: There is no support for opening a file for writing which\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[90m#       doesn't exist yet (creating a file).  Should there be?\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# TODO: Add a ``subdir`` parameter for specifying the subdirectory\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[90m#       used to store URLs in self._destpath.\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[94mif\u001b[39;49;00m \u001b[96mself\u001b[39;49;00m._isurl(path) \u001b[95mand\u001b[39;49;00m \u001b[96mself\u001b[39;49;00m._iswritemode(mode):\u001b[90m\u001b[39;49;00m\r\n            \u001b[94mraise\u001b[39;49;00m \u001b[96mValueError\u001b[39;49;00m(\u001b[33m\"\u001b[39;49;00m\u001b[33mURLs are not writeable\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n"]
