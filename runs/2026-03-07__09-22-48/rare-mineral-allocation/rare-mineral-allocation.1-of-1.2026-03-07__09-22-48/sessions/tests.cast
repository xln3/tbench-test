[16.75358, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mopen\u001b[39;49;00m(\u001b[96mself\u001b[39;49;00m, path, mode=\u001b[33m'\u001b[39;49;00m\u001b[33mr\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m, encoding=\u001b[94mNone\u001b[39;49;00m, newline=\u001b[94mNone\u001b[39;49;00m):\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"\u001b[39;49;00m\r\n    \u001b[33m    Open and return file-like object.\u001b[39;49;00m\r\n    \u001b[33m\u001b[39;49;00m\r\n    \u001b[33m    If `path` is an URL, it will be downloaded, stored in the\u001b[39;49;00m\r\n    \u001b[33m    `DataSource` directory and opened from there.\u001b[39;49;00m\r\n    \u001b[33m\u001b[39;49;00m\r\n    \u001b[33m    Parameters\u001b[39;49;00m\r\n    \u001b[33m    ----------\u001b[39;49;00m\r\n    \u001b[33m    path : str or pathlib.Path\u001b[39;49;00m\r\n"]
[16.753623, "o", "    \u001b[33m        Local file path or URL to open.\u001b[39;49;00m\r\n    \u001b[33m    mode : {'r', 'w', 'a'}, optional\u001b[39;49;00m\r\n    \u001b[33m        Mode to open `path`.  Mode 'r' for reading, 'w' for writing,\u001b[39;49;00m\r\n    \u001b[33m        'a' to append. Available modes depend on the type of object\u001b[39;49;00m\r\n    \u001b[33m        specified by `path`. Default is 'r'.\u001b[39;49;00m\r\n    \u001b[33m    encoding : {None, str}, optional\u001b[39;49;00m\r\n    \u001b[33m        Open text file with given encoding. The default encoding will be\u001b[39;49;00m\r\n    \u001b[33m        what `open` uses.\u001b[39;49;00m\r\n    \u001b[33m    newline : {None, str}, optional\u001b[39;49;00m\r\n"]
[16.753775, "o", "    \u001b[33m        Newline to use when reading text file.\u001b[39;49;00m\r\n    \u001b[33m\u001b[39;49;00m\r\n    \u001b[33m    Returns\u001b[39;49;00m\r\n    \u001b[33m    -------\u001b[39;49;00m\r\n    \u001b[33m    out : file object\u001b[39;49;00m\r\n"]
[16.753962, "o", "    \u001b[33m        File object.\u001b[39;49;00m\r\n    \u001b[33m\u001b[39;49;00m\r\n    \u001b[33m    \"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# TODO: There is no support for opening a file for writing which\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[90m#       doesn't exist yet (creating a file).  Should there be?\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# TODO: Add a ``subdir`` parameter for specifying the subdirectory\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[90m#       used to store URLs in self._destpath.\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[94mif\u001b[39;49;00m \u001b[96mself\u001b[39;49;00m._isurl(path) \u001b[95mand\u001b[39;49;00m \u001b[96mself\u001b[39;49;00m._iswritemode(mode):\u001b[90m\u001b[39;49;00m\r\n            \u001b[94mraise\u001b[39;49;00m \u001b[96mValueError\u001b[39;49;00m(\u001b[33m\"\u001b[39;49;00m\u001b[33mURLs are not writeable\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# NOTE: _findfile will fail on a new file opened for writing.\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        found = \u001b[96mself\u001b[39;49;00m._findfile(path)\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mif\u001b[39;49;00m found:\u001b[90m\u001b[39;49;00m\r\n            _fname, ext = \u001b[96mself\u001b[39;49;00m._splitzipext(found)\u001b[90m\u001b[39;49;00m\r\n            \u001b[94mif\u001b[39;49;00m ext == \u001b[33m'\u001b[39;49;00m\u001b[33mbz2\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m:\u001b[90m\u001b[39;49;00m\r\n                mode.replace(\u001b[33m\"\u001b[39;49;00m\u001b[33m+\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n            \u001b[94mreturn\u001b[39;49;00m _file_openers[ext](found, mode=mode,\u001b[90m\u001b[39;49;00m\r\n                                      encoding=encoding, newline=newline)\u001b[90m\u001b[39;49;00m\r\n        \u001b[94melse\u001b[39;49;00m:\u001b[90m\u001b[39;49;00m\r\n>           \u001b[94mraise\u001b[39;49;00m \u001b[96mFileNotFoundError\u001b[39;49;00m(\u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m{\u001b[39;49;00mpath\u001b[33m}\u001b[39;49;00m\u001b[33m not found.\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31mE           FileNotFoundError: /app/solution.txt not found.\u001b[0m\r\n\r\n"]
