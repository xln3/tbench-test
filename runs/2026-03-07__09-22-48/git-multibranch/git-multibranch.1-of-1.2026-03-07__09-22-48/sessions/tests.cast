[47.241612, "o", "    \u001b[33mspawn bash -c \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mcd project-test && git push -u origin main\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33mexpect \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mpassword:\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33msend \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mpassword\u001b[39;49;00m\u001b[33m\\\\\u001b[39;49;00m\u001b[33mr\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33mexpect eof\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m\u001b[39;49;00m\r\n    \u001b[33m# dev branch\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33mspawn bash -c \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mcd project-test && \u001b[39;49;00m\u001b[33m\\\u001b[39;49;00m\r\n    \u001b[33m               git checkout -b dev && \u001b[39;49;00m\u001b[33m\\\u001b[39;49;00m\r\n    \u001b[33m               echo \u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33mdev branch content\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33m > index.html && \u001b[39;49;00m\u001b[33m\\\u001b[39;49;00m\r\n    \u001b[33m               git add index.html && \u001b[39;49;00m\u001b[33m\\\u001b[39;49;00m\r\n    \u001b[33m               git commit -m \u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33mdev commit\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33mexpect eof\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m\u001b[39;49;00m\r\n    \u001b[33mspawn bash -c \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mcd project-test && git push -u origin dev\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33mexpect \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mpassword:\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n 