[47.241225, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_multi_branch_https_deploy\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n        \u001b[96mopen\u001b[39;49;00m(\u001b[33m\"\u001b[39;49;00m\u001b[33mverify.sh\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33mw\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m).write(\u001b[33m\"\"\"\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m#!/bin/bash\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33mset -e\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m\u001b[39;49;00m\r\n    \u001b[33mapt-get update\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33mDEBIAN_FRONTEND=noninteractive apt-get install -y curl expect git openssh-client\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m\u001b[39;49;00m\r\n    \u001b[33mmkdir -p ~/.ssh\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33mecho \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mHost localhost\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m    StrictHostKeyChecking no\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m    UserKnownHostsFile=/dev/null\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m > ~/.ssh/config\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33mchmod 600 ~/.ssh/config\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m\u001b[39;49;00m\r\n    \u001b[33m# Expect script to push both branches\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33mcat > git_push.exp << \u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33mEOF\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m#!/usr/bin/expect -f\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33mset timeout 20\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n"]
[47.241443, "o", "    \u001b[33m\u001b[39;49;00m\r\n    \u001b[33mspawn git clone git@localhost:/git/project project-test\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33mexpect \u001b[39;49;00m\u001b[33m{\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m    \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33myes/no\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m \u001b[39;49;00m\u001b[33m{\u001b[39;49;00m\u001b[33m send \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33myes\u001b[39;49;00m\u001b[33m\\\\\u001b[39;49;00m\u001b[33mr\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m; exp_continue }\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m    \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mpassword:\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m \u001b[39;49;00m\u001b[33m{\u001b[39;49;00m\u001b[33m send \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mpassword\u001b[39;49;00m\u001b[33m\\\\\u001b[39;49;00m\u001b[33mr\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m }\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m}\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33mexpect eof\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m\u001b[39;49;00m\r\n    \u001b[33m# main branch\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33mspawn bash -c \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mcd project-test && \u001b[39;49;00m\u001b[33m\\\u001b[39;49;00m\r\n    \u001b[33m                git config user.email \u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33mmain@example.com\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33m && \u001b[39;49;00m\u001b[33m\\\u001b[39;49;00m\r\n    \u001b[33m                git config user.name \u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33mMain Dev\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33m && \u001b[39;49;00m\u001b[33m\\\u001b[39;49;00m\r\n    \u001b[33m                git checkout -B main && \u001b[39;49;00m\