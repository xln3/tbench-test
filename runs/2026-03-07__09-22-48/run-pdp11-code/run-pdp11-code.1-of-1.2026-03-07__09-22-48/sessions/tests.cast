[18.858294, "o", "    \u001b[33m    Open the file pointed to by this path and return a file object, as\u001b[39;49;00m\r\n    \u001b[33m    the built-in open() function does.\u001b[39;49;00m\r\n    \u001b[33m    \"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mif\u001b[39;49;00m \u001b[33m\"\u001b[39;49;00m\u001b[33mb\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m \u001b[95mnot\u001b[39;49;00m \u001b[95min\u001b[39;49;00m mode:\u001b[90m\u001b[39;49;00m\r\n"]
[18.858331, "o", "            encoding = io.text_encoding(encoding)\u001b[90m\u001b[39;49;00m\r\n>       \u001b[94mreturn\u001b[39;49;00m io.open(\u001b[96mself\u001b[39;49;00m, mode, buffering, encoding, errors, newline)\u001b[90m\u001b[39;49;00m\r\n               ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31mE       FileNotFoundError: [Errno 2] No such file or directory: '/app/out.txt'\u001b[0m\r\n\r\n\u001b[1m\u001b[31m/usr/local/lib/python3.13/pathlib/_local.py\u001b[0m:537: FileNotFoundError\r\n"]
