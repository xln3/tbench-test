[73.3915, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mset_backward\u001b[39;49;00m(Z1, A1, Z2, A2, W1, W2, X, one_hot_Y):\u001b[90m\u001b[39;49;00m\r\n        m = X.shape[\u001b[94m1\u001b[39;49;00m]\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Compute gradient of loss with respect to Z2 (softmax output)\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# For cross-entropy loss with softmax: dZ2 = A2 - Y\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        dZ2 = A2 - one_hot_Y\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n"]
[73.391685, "o", "        \u001b[90m# Gradient of W2 and b2\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n>       dW2 = np.dot(dZ2, A1.T) / m\u001b[90m\u001b[39;49;00m\r\n              ^^\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31mE       NameError: name 'np' is not defined\u001b[0m\r\n\r\n\u001b[1m\u001b[31mfix.py\u001b[0m:58: NameError\r\n"]
