[75.103589, "o", "\u001b[31m\u001b[1m______________________________________________________________ test_summary_structure_and_counts _______________________________________________________________\u001b[0m\r\n\r\n"]
[75.105668, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_summary_structure_and_counts\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"Validate CSV structure and check if counts match expected hard-coded values.\"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mwith\u001b[39;49;00m OUTPUT_FILE.open(\u001b[33m\"\u001b[39;49;00m\u001b[33mr\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, newline=\u001b[33m\"\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m) \u001b[94mas\u001b[39;49;00m f:\u001b[90m\u001b[39;49;00m\r\n            reader = \u001b[96mlist\u001b[39;49;00m(csv.reader(f))\u001b[90m\u001b[39;49;00m\r\n        \u001b[94massert\u001b[39;49;00m reader, \u001b[33m\"\u001b[39;49;00m\u001b[33mCSV file is empty\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n"]
[75.105812, "o", "        \u001b[90m# Header check\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        header = reader[\u001b[94m0\u001b[39;49;00m]\u001b[90m\u001b[39;49;00m\r\n        \u001b[94massert\u001b[39;49;00m header == [\u001b[33m\"\u001b[39;49;00m\u001b[33mperiod\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33mseverity\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33mcount\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m], \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mUnexpected header: \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mheader\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Row count check\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[94massert\u001b[39;49;00m \u001b[96mlen\u001b[39;49;00m(reader) - \u001b[94m1\u001b[39;49;00m == \u001b[96mlen\u001b[39;49;00m(EXPECTED_ROWS), (\u001b[90m\u001b[39;49;00m\r\n            \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mExpected \u001b[39;49;00m\u001b[33m{\u001b[39;49;00m\u001b[96mlen\u001b[39;49;00m(EXPECTED_ROWS)\u001b[33m}\u001b[39;49;00m\u001b[33m rows, got \u001b[39;49;00m\u001b[33m{\u001b[39;49;00m\u001b[96mlen\u001b[39;49;00m(reader)\u001b[90m \u001b[39;49;00m-\u001b[90m \u001b[39;49;00m\u001b[94m1\u001b[39;49;00m\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        )\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n"]
[75.105883, "o", "        \u001b[90m# Content check\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mfor\u001b[39;49;00m expected_row, actual_row \u001b[95min\u001b[39;49;00m \u001b[96mzip\u001b[39;49;00m(EXPECTED_ROWS, reader[\u001b[94m1\u001b[39;49;00m:]):\u001b[90m\u001b[39;49;00m\r\n>           \u001b[94massert\u001b[39;49;00m actual_row == expected_row, (\u001b[90m\u001b[39;49;00m\r\n                \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mExpected row \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mexpected_row\u001b[33m}\u001b[39;49;00m\u001b[33m, got \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mactual_row\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            )\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31mE           AssertionError: Expected row ['today', 'ERROR', '370'], got ['today', 'ERROR', '414']\u001b[0m\r\n\u001b[1m\u001b[31mE           assert ['today', 'ERROR', '414'] == ['today', 'ERROR', '370']\u001b[0m\r\n\u001b[1m\u001b[31mE             \u001b[0m\r\n\u001b[1m\u001b[31mE             At index 2 diff: \u001b[0m\u001b[33m'\u001b[39;49;00m\u001b[33m414\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[90m\u001b[39;49;00m != \u001b[0m\u001b[33m'\u001b[39;49;00m\u001b[33m370\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\u001b[0m\r\n\u001b[1m\u001b[31mE             Use -v to get more diff\u001b[0m\r\n\r\n\u001b[1m\u001b[31m/tests/test_outputs.py\u001b[0m:49: AssertionError\r\n"]
