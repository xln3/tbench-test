[14.873677, "o", "\u001b[31m\u001b[1m_________________________________________________________________________ test_attack __________________________________________________________________________\u001b[0m\r\n\r\n"]
[14.918926, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_attack\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"\u001b[39;49;00m\r\n    \u001b[33m    Test that the linear cryptanalysis attack correctly decrypts all ciphertexts.\u001b[39;49;00m\r\n    \u001b[33m\u001b[39;49;00m\r\n    \u001b[33m    This test verifies that:\u001b[39;49;00m\r\n    \u001b[33m    1. The attack successfully performs linear cryptanalysis on FEAL cipher\u001b[39;49;00m\r\n    \u001b[33m    2. All ciphertexts from ciphertexts.txt are correctly decrypted\u001b[39;49;00m\r\n    \u001b[33m    3. The resulting plaintexts match the expected decrypted values\u001b[39;49;00m\r\n    \u001b[33m\u001b[39;49;00m\r\n    \u001b[33m    The test checks that each of the 100 expected plaintext values\u001b[39;49;00m\r\n    \u001b[33m    (representing the decrypted results of the ciphertexts) appears\u001b[39;49;00m\r\n"]
[14.919122, "o", "    \u001b[33m    in the generated plaintexts.txt file, confirming successful\u001b[39;49;00m\r\n    \u001b[33m    key recovery and decryption through linear cryptanalysis.\u001b[39;49;00m\r\n    \u001b[33m    \"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        data = \u001b[96mopen\u001b[39;49;00m(\u001b[33m\"\u001b[39;49;00m\u001b[33m/app/plaintexts.txt\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m).read()\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mfor\u001b[39;49;00m c \u001b[95min\u001b[39;49;00m soln.split():\u001b[90m\u001b[39;49;00m\r\n>           \u001b[94massert\u001b[39;49;00m c \u001b[95min\u001b[39;49;00m data\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31mE           AssertionError: assert '1050628112036199672' in '9898663263359686056\\n13683862062260152874\\n17683229563807792899\\n16657263748157227888\\n10025468544559693474\\n8666296045063847869\\n5021351496645425661\\n1834352881518798490\\n6759671285668538027\\n6070298848770285387\\n8593917571168212345\\n1445422310473910483\\n10699421934448127678\\n8501796707391647792\\n3175876781057850474\\n17480391260064645993\\n416208125131187250\\n15453409907389722830\\n11945257763538880337\\n523363543039973628\\n16585327664743322562\\n5310"]
