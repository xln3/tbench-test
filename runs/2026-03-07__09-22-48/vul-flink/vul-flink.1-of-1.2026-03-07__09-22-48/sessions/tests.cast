[90.820965, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92m_wait_for_flink_rest\u001b[39;49;00m(max_retries: \u001b[96mint\u001b[39;49;00m = \u001b[94m60\u001b[39;49;00m, retry_delay_sec: \u001b[96mfloat\u001b[39;49;00m = \u001b[94m1.0\u001b[39;49;00m) -> \u001b[94mNone\u001b[39;49;00m:\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"Verify Flink REST is reachable before proceeding.\"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        last_status = \u001b[94mNone\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        last_error = \u001b[94mNone\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mfor\u001b[39;49;00m _ \u001b[95min\u001b[39;49;00m \u001b[96mrange\u001b[39;49;00m(max_retries):\u001b[90m\u001b[39;49;00m\r\n            \u001b[94mtry\u001b[39;49;00m:\u001b[90m\u001b[39;49;00m\r\n                conn = http.client.HTTPConnection(\u001b[33m\"\u001b[39;49;00m\u001b[33mlocalhost\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[94m8081\u001b[39;49;00m, timeout=\u001b[94m5\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n                conn.request(\u001b[33m\"\u001b[39;49;00m\u001b[33mGET\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33m/jars\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n                resp = conn.getresponse()\u001b[90m\u001b[39;49;00m\r\n                last_status = resp.status\u001b[90m\u001b[39;49;00m\r\n                _ = resp.read()\u001b[90m\u001b[39;49;00m\r\n                conn.close()\u001b[90m\u001b[39;49;00m\r\n                \u001b[94mif\u001b[39;49;00m \u001b[94m200\u001b[39;49;00m <= last_status < \u001b[94m300\u001b[39;49;00m:\u001b[90m\u001b[39;49;00m\r\n                    \u001b[94mreturn\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            \u001b[94mexcept\u001b[39;49;00m (\u001b[96mConnectionRefusedError\u001b[39;49;00m, \u001b[96mTimeoutError\u001b[39;49;00m, socket.timeout, \u001b[96mOSError\u001b[39;49;00m) \u001b[94mas\u001b[39;49;00m exc:\u001b[90m\u001b[39;49;00m\r\n                last_error = exc\u001b[90m\u001b[39;49;00m\r\n            time.sleep(retry_delay_sec)\u001b[90m\u001b[39;49;00m\r\n"]
[90.821276, "o", "    \u001b[90m\u001b[39;49;00m\r\n        \u001b[94mif\u001b[39;49;00m last_error \u001b[95mis\u001b[39;49;00m \u001b[95mnot\u001b[39;49;00m \u001b[94mNone\u001b[39;49;00m:\u001b[90m\u001b[39;49;00m\r\n            msg = \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mFlink REST not reachable on localhost:8081; last error: \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mlast_error\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n>           \u001b[94mraise\u001b[39;49;00m \u001b[96mAssertionError\u001b[39;49;00m(msg)\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31mE           AssertionError: Flink REST not reachable on localhost:8081; last error: [Errno 111] Connection refused\u001b[0m\r\n\r\n\u001b[1m\u001b[31m/tests/test_outputs.py\u001b[0m:33: AssertionError\r\n"]
