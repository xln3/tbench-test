[17.714567, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_if_strategy_escapes_enemy\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"Runs the compiled game and checks and sees if it ends in an exit code of 13\"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Run the provided command and check exit code\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        result = subprocess.run(\u001b[90m\u001b[39;49;00m\r\n            [\u001b[33m\"\u001b[39;49;00m\u001b[33mpython3\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33mrun_game.cpython-313.pyc\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m], capture_output=\u001b[94mTrue\u001b[39;49;00m, text=\u001b[94mTrue\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n"]
[17.71474, "o", "        )\u001b[90m\u001b[39;49;00m\r\n>       \u001b[94massert\u001b[39;49;00m result.returncode == \u001b[94m13\u001b[39;49;00m, (\u001b[90m\u001b[39;49;00m\r\n            \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mrun_game.cpython-313.pyc exited with code \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mresult.returncode\u001b[33m}\u001b[39;49;00m\u001b[33m \u001b[39;49;00m\u001b[33m\\\u001b[39;49;00m\r\n    \u001b[33m            Stdout: \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mresult.stdout\u001b[33m}\u001b[39;49;00m\u001b[33m Stderr: \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mresult.stderr\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        )\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31mE       AssertionError: run_game.cpython-313.pyc exited with code 1             Stdout: Starting grid server...\u001b[0m\r\n\u001b[1m\u001b[31mE         Grid game server started on localhost:8080\u001b[0m\r\n\u001b[1m\u001b[31mE         Available commands:\u001b[0m\r\n\u001b[1m\u001b[31mE         - get_user_pos\u001b[0m\r\n\u001b[1m\u001b[31mE         - get_enemy_pos\u001b[0m\r\n\u001b[1m\u001b[31mE         - move <direction> (0=up, 1=right, 2=down, 3=left)\u001b[0m\r\n\u001b[1m\u001b[31mE         Server started successfully!\u001b[0m\r\n\u001b[1m\u001b[31mE         Starting survival loop...\u001b[0m\r\n"]
[17.714829, "o", "\u001b[1m\u001b[31mE         Strategy will handle all game logic\u001b[0m\r\n\u001b[1m\u001b[31mE         Press Ctrl+C to stop\u001b[0m\r\n\u001b[1m\u001b[31mE         \u001b[0m\r\n\u001b[1m\u001b[31mE         --- Iteration 0 ---\u001b[0m\r\n\u001b[1m\u001b[31mE         Client connected from ('127.0.0.1', 44788)\u001b[0m\r\n\u001b[1m\u001b[31mE         \u001b[0m\r\n\u001b[1m\u001b[31mE         --- Iteration 1 ---\u001b[0m\r\n\u001b[1m\u001b[31mE         \u001b[0m\r\n\u001b[1m\u001b[31mE         --- Iteration 2 ---\u001b[0m\r\n"]
