[21.304536, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_environment_yml_modified\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"Test that the environment.yml file was modified to fix the conflicts.\"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mwith\u001b[39;49;00m \u001b[96mopen\u001b[39;49;00m(\u001b[33m\"\u001b[39;49;00m\u001b[33m/app/project/environment.yml\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33mr\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m) \u001b[94mas\u001b[39;49;00m f:\u001b[90m\u001b[39;49;00m\r\n            content = f.read()\u001b[90m\u001b[39;49;00m\r\n"]
[21.304598, "o", "    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Check that the numpy version is compatible with scipy\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        numpy_match = re.search(\u001b[33mr\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mnumpy=([0-9.]+)\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, content)\u001b[90m\u001b[39;49;00m\r\n        scipy_match = re.search(\u001b[33mr\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mscipy=([0-9.]+)\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, content)\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[94mif\u001b[39;49;00m numpy_match \u001b[95mand\u001b[39;49;00m scipy_match:\u001b[90m\u001b[39;49;00m\r\n"]
[21.304703, "o", "            numpy_version = numpy_match.group(\u001b[94m1\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n            scipy_version = scipy_match.group(\u001b[94m1\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n"]
