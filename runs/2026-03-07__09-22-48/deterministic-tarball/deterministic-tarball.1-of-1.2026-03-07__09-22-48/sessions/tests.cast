[27.157108, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_source_date_epoch\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"Test that SOURCE_DATE_EPOCH is respected\"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        env = os.environ.copy()\u001b[90m\u001b[39;49;00m\r\n        env[\u001b[33m\"\u001b[39;49;00m\u001b[33mSOURCE_DATE_EPOCH\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m] = \u001b[33m\"\u001b[39;49;00m\u001b[33m1500000000\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n>       sh(\u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mcd /app && \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mBUILD_SCRIPT\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, env=env)\u001b[90m\u001b[39;49;00m\r\n"]
