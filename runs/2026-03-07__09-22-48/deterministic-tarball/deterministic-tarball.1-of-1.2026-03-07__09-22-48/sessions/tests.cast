[27.12408, "o", "input = None, capture_output = True, timeout = None, check = True, popenargs = ('cd /app && /app/build.sh',)\r\nkwargs = {'shell': True, 'stderr': -1, 'stdout': -1, 'text': True}, process = <Popen: returncode: 1 args: 'cd /app && /app/build.sh'>\r\nstdout = 'Step 1: Copying source tree with exclusions...\\nskipping non-regular file \"src/README\"\\nskipping non-regular file \"sr...rmalizing permissions...\\nStep 6: Setting deterministic timestamps...\\nStep 7: Creating deterministic tar archive...\\n'\r\n"]
