[37.274578, "o", "\u001b[31m\u001b[1m_________________________________________________________________________ test_primers _________________________________________________________________________\u001b[0m\r\n\r\n"]
[37.3164, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_primers\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"Test that the generated primers will successfully amplify the input DNA and\u001b[39;49;00m\r\n    \u001b[33m    contain the required overhangs that will result in the output sequence.\u001b[39;49;00m\r\n    \u001b[33m    \"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        primers_path = Path(\u001b[33m\"\u001b[39;49;00m\u001b[33m/app/primers.fasta\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n        \u001b[94massert\u001b[39;49;00m primers_path.exists(), \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mFile \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mprimers_path\u001b[33m}\u001b[39;49;00m\u001b[33m does not exist.\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[94mwith\u001b[39;49;00m \u001b[96mopen\u001b[39;49;00m(primers_path, \u001b[33m\"\u001b[39;49;00m\u001b[33mr\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m) \u001b[94mas\u001b[39;49;00m f:\u001b[90m\u001b[39;49;00m\r\n            lines = [line.rstrip() \u001b[94mfor\u001b[39;49;00m line \u001b[95min\u001b[39;49;00m f]\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# This task needs one primer pair per insert/vector to solve each primer takes up\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# two lines so the fasta file should have 16 lines in total.\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[94massert\u001b[39;49;00m \u001b[96mlen\u001b[39;49;00m(lines) == \u001b[94m16\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33mInvalid number of lines in primers.fasta.\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        primers = {}\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mfor\u001b[39;49;00m i \u001b[95min\u001b[39;49;00m \u001b[96mrange\u001b[39;49;00m(\u001b[94m0\u001b[39;49;00m, \u001b[96mlen\u001b[39;49;00m(lines), \u001b[94m2\u001b[39;49;00m):\u001b[90m\u001b[39;49;00m\r\n            primer = lines[i + \u001b[94m1\u001b[39;49;00m].lower()\u001b[90m\u001b[39;49;00m\r\n            \u001b[90m# Check that the header and primer are formatted correctly.\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            \u001b[94massert\u001b[39;49;00m lines[i].startswith(\u001b[33m\"\u001b[39;49;00m\u001b[33m>\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m), \u001b[33m\"\u001b[39;49;00m\u001b[33mHeaders must start with >.\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            \u001b[94massert\u001b[39;49;00m re.fullmatch(\u001b[33mr\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m[atcg]+\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, primer), \u001b[33m\"\u001b[39;49;00m\u001b[33mPrimer must contain only A, T, C, G.\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            primers[lines[i][\u001b[94m1\u001b[39;49;00m:]] = lines[i + \u001b[94m1\u001b[39;49;00m].lower()\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n"]
[37.316586, "o", "        \u001b[90m# Check that all required primers are present.\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[94massert\u001b[39;49;00m \u001b[96mall\u001b[39;49;00m(\u001b[90m\u001b[39;49;00m\r\n            k \u001b[95min\u001b[39;49;00m primers\u001b[90m\u001b[39;49;00m\r\n            \u001b[94mfor\u001b[39;49;00m k \u001b[95min\u001b[39;49;00m [\u001b[90m\u001b[39;49;00m\r\n                \u001b[33m\"\u001b[39;49;00m\u001b[33minput_fwd\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n                \u001b[33m\"\u001b[39;49;00m\u001b[33minput_rev\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n                \u001b[33m\"\u001b[39;49;00m\u001b[33megfp_fwd\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n                \u001b[33m\"\u001b[39;49;00m\u001b[33megfp_rev\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n                \u001b[33m\"\u001b[39;49;00m\u001b[33mflag_fwd\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n                \u001b[33m\"\u001b[39;49;00m\u001b[33mflag_rev\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n                \u001b[33m\"\u001b[39;49;00m\u001b[33msnap_fwd\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n                \u001b[33m\"\u001b[39;49;00m\u001b[33msnap_rev\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n            ]\u001b[90m\u001b[39;49;00m\r\n        ), \u001b[33m\"\u001b[39;49;00m\u001b[33mprimers.fasta file is missing a primer for a valid solution.\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n>       vector_left, vector_internal, vector_right = make_fragment(\u001b[90m\u001b[39;49;00m\r\n            vector, primers[\u001b[33m\"\u001b[39;49;00m\u001b[33minput_fwd\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m], primers[\u001b[33m\"\u001b[39;49;00m\u001b[33minput_rev\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m], circular=\u001b[94mTrue\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        )\u001b[90m\u001b[39;49;00m\r\n"]
[37.316618, "o", "\r\n\u001b[1m\u001b[31m/tests/test_outputs.py\u001b[0m:163: \r\n_ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ \r\n\u001b[1m\u001b[31m/tests/test_outputs.py\u001b[0m:61: in make_fragment\r\n"]
[37.317579, "o", "    \u001b[0mf_oh, f_bind = parse_bsai_primer(fwd_primer)\u001b[90m\u001b[39;49;00m\r\n                   ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\u001b[90m\u001b[39;49;00m\r\n_ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ \r\n\r\n"]
[37.317635, "o", "primer = 'ggtctcggagactcttcctttttcaatattattgaagca'\r\n\r\n"]
[37.318363, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mparse_bsai_primer\u001b[39;49;00m(primer):\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"Primer (5'‚Üí3'): [clamp] ggtctc [oooo] [binding]\"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        site = \u001b[33m\"\u001b[39;49;00m\u001b[33mggtctc\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        i = primer.find(site)\u001b[90m\u001b[39;49;00m\r\n"]
[37.318393, "o", "        \u001b[94massert\u001b[39;49;00m i != -\u001b[94m1\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33mBsaI site ggtctc not found in primer\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n>       \u001b[94massert\u001b[39;49;00m i >= \u001b[94m1\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33mPrimer must have clamp of at least 1 nucleotide before BsaI site.\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31mE       AssertionError: Primer must have clamp of at least 1 nucleotide before BsaI site.\u001b[0m\r\n"]
