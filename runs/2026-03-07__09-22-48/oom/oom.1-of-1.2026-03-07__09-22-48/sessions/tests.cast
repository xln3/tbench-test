[17.659983, "o", "    \u001b[0mfile = cached_files(path_or_repo_id=path_or_repo_id, filenames=[filename], **kwargs)\u001b[90m\u001b[39;49;00m\r\n           ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\u001b[90m\u001b[39;49;00m\r\n"]
