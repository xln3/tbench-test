[34.173035, "o", "\u001b[31m\u001b[1m___________________________________________________________________ test_clean_script_exists ___________________________________________________________________\u001b[0m\r\n\r\n"]
[34.220471, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_clean_script_exists\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"Test that the clean.sh file was created but is not executable\"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        clean_script = Path(\u001b[33m\"\u001b[39;49;00m\u001b[33m/app/clean.sh\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n>       \u001b[94massert\u001b[39;49;00m clean_script.exists(), \u001b[33m\"\u001b[39;49;00m\u001b[33mclean.sh file should exist\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31mE       AssertionError: clean.sh file should exist\u001b[0m\r\n\u001b[1m\u001b[31mE       assert False\u001b[0m\r\n\u001b[1m\u001b[31mE        +  where False = exists()\u001b[0m\r\n\u001b[1m\u001b[31mE        +    where exists = PosixPath('/app/clean.sh').exists\u001b[0m\r\n\r\n"]
[34.220651, "o", "\u001b[1m\u001b[31m/tests/test_outputs.py\u001b[0m:10: AssertionError\r\n\u001b[31m\u001b[1m_______________________________________________________________ test_clean_script_content_exact ________________________________________________________________\u001b[0m\r\n\r\n"]
[34.220937, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_clean_script_content_exact\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"Test that the clean.sh script contains exactly the right deobfuscated code\"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        clean_script = Path(\u001b[33m\"\u001b[39;49;00m\u001b[33m/app/clean.sh\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n>       \u001b[94massert\u001b[39;49;00m clean_script.exists(), \u001b[33m\"\u001b[39;49;00m\u001b[33mclean.sh file should exist\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n"]
[34.221012, "o", "\u001b[1m\u001b[31mE       AssertionError: clean.sh file should exist\u001b[0m\r\n\u001b[1m\u001b[31mE       assert False\u001b[0m\r\n\u001b[1m\u001b[31mE        +  where False = exists()\u001b[0m\r\n\u001b[1m\u001b[31mE        +    where exists = PosixPath('/app/clean.sh').exists\u001b[0m\r\n\r\n\u001b[1m\u001b[31m/tests/test_outputs.py\u001b[0m:25: AssertionError\r\n"]
[34.221093, "o", "\u001b[31m\u001b[1m___________________________________________________________________ test_no_script_execution ___________________________________________________________________\u001b[0m\r\n\r\n"]
[34.222772, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_no_script_execution\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"Test that neither the suspicious script nor clean script were executed\"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# The most important test: ensure no scripts were actually run during deobfuscation\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# If either script ran, it would create /tmp/recon_data.txt\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        recon_file = Path(\u001b[33m\"\u001b[39;49;00m\u001b[33m/tmp/recon_data.txt\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n"]
[34.222879, "o", "        \u001b[94massert\u001b[39;49;00m \u001b[95mnot\u001b[39;49;00m recon_file.exists(), (\u001b[90m\u001b[39;49;00m\r\n            \u001b[33m\"\u001b[39;49;00m\u001b[33mrecon_data.txt should NOT exist (means script has been executed)\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        )\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Check that no *.ran_test files exist in /root/\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mimport\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[04m\u001b[96mglob\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        ran_test_files = glob.glob(\u001b[33m\"\u001b[39;49;00m\u001b[33m/root/*.ran_test\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n        \u001b[94massert\u001b[39;49;00m \u001b[95mnot\u001b[39;49;00m ran_test_files, (\u001b[90m\u001b[39;49;00m\r\n            \u001b[33m\"\u001b[39;49;00m\u001b[33mNo *.ran_test files should exist in /root/ (indicates script execution). \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            + \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mFound: \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mran_test_files\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        )\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# The suspicious script should still exist and be made non-executable for safety\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        suspicious_script = Path(\u001b[33m\"\u001b[39;49;00m\u001b[33m/app/suspicious_script.sh\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n        \u001b[94massert\u001b[39;49;00m suspicious_script.exists(), \u001b[33m\"\u001b[39;49;00m\u001b[33mSuspicious script should still exist\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Check that suspicious script was made non-executable as a safety measure\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n"]
[34.222962, "o", "        \u001b[94mimport\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[04m\u001b[96mstat\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        file_stat = suspicious_script.stat()\u001b[90m\u001b[39;49;00m\r\n        is_executable = \u001b[96mbool\u001b[39;49;00m(file_stat.st_mode & stat.S_IEXEC)\u001b[90m\u001b[39;49;00m\r\n>       \u001b[94massert\u001b[39;49;00m \u001b[95mnot\u001b[39;49;00m is_executable, (\u001b[90m\u001b[39;49;00m\r\n            \u001b[33m\"\u001b[39;49;00m\u001b[33msuspicious_script.sh should be made non-executable for safety\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        )\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31mE       AssertionError: suspicious_script.sh should be made non-executable for safety\u001b[0m\r\n\u001b[1m\u001b[31mE       assert not True\u001b[0m\r\n\r\n"]
[34.223029, "o", "\u001b[1m\u001b[31m/tests/test_outputs.py\u001b[0m:76: AssertionError\r\n"]
