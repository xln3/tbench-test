[4.448244, "o", "\u001b[?2004h> "]
[4.448309, "o", "**API Usage Examples:**\r\n\u001b[?2004l\r"]
[4.44838, "o", "\u001b[?2004h> ```bash\r\n\u001b[?2004l\r"]
[4.448471, "o", "\u001b[?2004h> # Get maze size\r\n\u001b[?2004l\r"]
[4.448522, "o", "\u001b[?2004h> "]
[4.448633, "o", "curl -X GET http://maze:8088/maze_size\r\n\u001b[?2004l\r"]
[4.448693, "o", "\u001b[?2004h> "]
[4.448748, "o", "# Response: {\"maze_size\": 12}\r\n\u001b[?2004l\r"]
[4.448793, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[4.448865, "o", "\u001b[?2004h> "]
[4.44896, "o", "# Check current position connectivity\r\n\u001b[?2004l\r"]
[4.449123, "o", "\u001b[?2004h> curl -X GET http://maze:8088/sense\r\n\u001b[?2004l\r\u001b[?2004h> "]
[4.449267, "o", "# Response: {\"connectivity\": [1,0,0,1]}\r\n\u001b[?2004l\r"]
[4.449401, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[4.449445, "o", "# Move right (direction 3)\r\n\u001b[?2004l\r\u001b[?2004h> "]
[4.449788, "o", "curl -X POST http://maze:8088/move -H \"Content-Type: application/json\" -d '\"'\"'{\"direction\": 3}'\"'\"'\r\n\u001b[?2004l\r"]
[4.44987, "o", "\u001b[?2004h"]
[4.449924, "o", "> # Response: {\"status\": \"moved\"}\r\n\u001b[?2004l\r"]
[4.449966, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r"]
[4.450012, "o", "\u001b[?2004h> "]
[4.450183, "o", "# After game over, all endpoints return game over signals\r\n\u001b[?2004l\r"]
[4.450248, "o", "\u001b[?2004h> "]
[4.450326, "o", "curl -X GET http://maze:8088/sense\r\n\u001b[?2004l\r"]
[4.450374, "o", "\u001b[?2004h> "]
[4.450535, "o", "# Response: {\"connectivity\": [0,0,0,0]}\r\n\u001b[?2004l\r\u001b[?2004h> \r\n\u001b[?2004l\r"]
[4.450596, "o", "\u001b[?2004h> "]
[4.45071, "o", "# Successful completion (when at the exit)\r\n\u001b[?2004l\r"]
[4.450788, "o", "\u001b[?2004h> "]
[4.451018, "o", "curl -X POST http://maze:8088/finish -H \"Content-Type: application/json\" -d '\"'\"'{}'\"'\"'\r\n\u001b[?2004l\r"]
[4.451081, "o", "\u001b[?2004h> "]
[4.451267, "o", "# Response: {\"status\": \"Congratulations, destination reached\"}\r\n\u001b[?2004l\r"]
[4.451286, "o", "\u001b[?2004h"]
[4.451405, "o", "> \r\n\u001b[?2004l\r\u001b[?2004h> "]
[4.45148, "o", "# Premature finish (triggers game over)\r\n\u001b[?2004l\r"]
[4.451548, "o", "\u001b[?2004h> "]
[4.451796, "o", "curl -X POST http://maze:8088/finish -H \"Content-Type: application/json\" -d '\"'\"'{}'\"'\"'\r\n\u001b[?2004l\r"]
[4.451847, "o", "\u001b[?2004h> "]
[4.452089, "o", "# Response: {\"status\": \"illegal\", \"message\": \"Not at destination, game over\"}\r\n\u001b[?2004l\r"]
[4.45214, "o", "\u001b[?2004h> "]
[4.452203, "o", "```'; tmux wait -S done\r\n\u001b[?2004l\r"]
