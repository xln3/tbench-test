[15.356449, "o", "\r\n"]
[15.460107, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_game_success_detection\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"\u001b[39;49;00m\r\n    \u001b[33m    Test that detects game success\u001b[39;49;00m\r\n    \u001b[33m    and raises an exception if game was not successful.\u001b[39;49;00m\r\n"]
[15.460317, "o", "    \u001b[33m    \"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Query maze game status interface (hidden endpoint only tests know about)\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        success_response = requests.get(\u001b[33m\"\u001b[39;49;00m\u001b[33mhttp://maze:8088/_test/success_check\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, timeout=\u001b[94m10\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n"]
[15.460397, "o", ">       \u001b[94massert\u001b[39;49;00m success_response.status_code == \u001b[94m200\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33mSuccess check endpoint should work\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31mE       AssertionError: Success check endpoint should work\u001b[0m\r\n\u001b[1m\u001b[31mE       assert 502 == 200\u001b[0m\r\n\u001b[1m\u001b[31mE        +  where 502 = <Response [502]>.status_code\u001b[0m\r\n\r\n\u001b[1m\u001b[31m/tests/test_outputs.py\u001b[0m:27: AssertionError\r\n"]
[15.460521, "o", "============================================================================ PASSES ============================================================================\r\n"]
