[14.410921, "o", "\r\n=========================================================================== FAILURES ===========================================================================\r\n\u001b[31m\u001b[1m___________________________________________________________________ test_warrior_performance ___________________________________________________________________\u001b[0m\r\n\r\n"]
[14.470407, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_warrior_performance\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"Test that my_warrior meets win rate thresholds against all opponents.\"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        warriors_and_thresholds = {\u001b[90m\u001b[39;49;00m\r\n            \u001b[33m\"\u001b[39;49;00m\u001b[33mstone.red\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m: \u001b[94m75\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n            \u001b[33m\"\u001b[39;49;00m\u001b[33mvampire.red\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m: \u001b[94m75\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n            \u001b[33m\"\u001b[39;49;00m\u001b[33mpaper.red\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m: \u001b[94m75\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n            \u001b[33m\"\u001b[39;49;00m\u001b[33msnake.red\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m: \u001b[94m33\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n            \u001b[33m\"\u001b[39;49;00m\u001b[33mg2-clear.red\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m: \u001b[94m33\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n        }\u001b[90m\u001b[39;49;00m\r\n"]
[14.470468, "o", "    \u001b[90m\u001b[39;49;00m\r\n        results = {}\u001b[90m\u001b[39;49;00m\r\n        total_passes = \u001b[94m0\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        total_tests = \u001b[96mlen\u001b[39;49;00m(warriors_and_thresholds)\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[94mfor\u001b[39;49;00m warrior, min_win_rate \u001b[95min\u001b[39;49;00m warriors_and_thresholds.items():\u001b[90m\u001b[39;49;00m\r\n            result = subprocess.run(\u001b[90m\u001b[39;49;00m\r\n                [\u001b[90m\u001b[39;49;00m\r\n                    \u001b[33m\"\u001b[39;49;00m\u001b[33mpmars\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n"]
[14.470926, "o", "                    \u001b[33m\"\u001b[39;49;00m\u001b[33m-b\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n                    \u001b[33m\"\u001b[39;49;00m\u001b[33m-r\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n                    \u001b[33m\"\u001b[39;49;00m\u001b[33m100\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n                    \u001b[33m\"\u001b[39;49;00m\u001b[33m-f\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n                    \u001b[33m\"\u001b[39;49;00m\u001b[33m/app/my_warrior.red\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n                    \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m/app/warriors/\u001b[39;49;00m\u001b[33m{\u001b[39;49;00mwarrior\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n                ],\u001b[90m\u001b[39;49;00m\r\n                capture_output=\u001b[94mTrue\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n                text=\u001b[94mTrue\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n            )\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n            \u001b[94massert\u001b[39;49;00m result.returncode == \u001b[94m0\u001b[39;49;00m, (\u001b[90m\u001b[39;49;00m\r\n                \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mpmars failed against \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mwarrior\u001b[33m}\u001b[39;49;00m\u001b[33m: \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mresult.stderr\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            )\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n            wins = \u001b[96mint\u001b[39;49;00m(result.stdout.strip().split(\u001b[33m\"\u001b[39;49;00m\u001b[33m\\n\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)[-\u001b[94m1\u001b[39;49;00m].split()[\u001b[94m1\u001b[