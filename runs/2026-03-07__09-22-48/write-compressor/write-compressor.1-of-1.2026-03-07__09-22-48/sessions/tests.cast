[42.161989, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_decompression_produces_original\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"Test that decompressing the compressed file produces the file content.\"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        setup()\u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Paths\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        compressed_path = Path(\u001b[33m\"\u001b[39;49;00m\u001b[33m/app/data.comp\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n        decompressor_path = Path(\u001b[33m\"\u001b[39;49;00m\u001b[33m/app/decomp2\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n        original_path = Path(\u001b[33m\"\u001b[39;49;00m\u001b[33m/app/data.txt\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Check that all required files exist\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[94massert\u001b[39;49;00m compressed_path.exists(), \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mCompressed file \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mcompressed_path\u001b[33m}\u001b[39;49;00m\u001b[33m does not exist\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[94massert\u001b[39;49;00m decompressor_path.exists(), (\u001b[90m\u001b[39;49;00m\r\n            \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mDecompressor \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mdecompressor_path\u001b[33m}\u001b[39;49;00m\u001b[33m does not exist\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        )\u001b[90m\u001b[39;49;00m\r\n        \u001b[94massert\u001b[39;49;00m original_path.exists(), \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mOriginal file \u001b[39;49;00m\u001b[33m{\u001b[39;49;00moriginal_path\u001b[33m}\u001b[39;49;00m\u001b[33m does not exist\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Get original content\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        original_content = original_path.read_text()\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Run decompression and capture output\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        result = subprocess.run(\u001b[90m\u001b[39;49;00m\r\n            \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mcat \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mcompressed_path\u001b[33m}\u001b[39;49;00m\u001b[33m | \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mdecompressor_path\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n            shell=\u001b[94mTrue\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n            capture_output=\u001b[94mTrue\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n            text=\u001b[94mTrue\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n        )\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Check if decompression was successful\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[94massert\u001b[39;49;00m result.returncode == \u001b[94m0\u001b[39;49;00m, \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mDecompression failed with error: \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mresult.stderr\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Compare decompressed content with original\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n>       \u001b[94massert\u001b[39;49;00m result.stdout == original_content, (\u001b[90m\u001b[39;49;00m\r\n            \u001b[33m\"\u001b[39;49;00m\u001b[33mDecompressed content does not match original content\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        )\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31mE       AssertionError: Decompressed content does not match original content\u001b[0m\r\n\u001b[1m\u001b[31mE       assert '' == 'In informati...nt.[12][13]\\n'\u001b[0m\r\n"]
[42.162223, "o", "\u001b[1m\u001b[31mE         \u001b[0m\r\n\u001b[1m\u001b[31mE         \u001b[0m\u001b[91m- In information theory, data compression, source coding,[1] or bit-rate reduction is the process of encoding information using fewer bits than the original representation.[2] Any particular compression is either lossy or lossless. Lossless compression reduces bits by identifying and eliminating statistical redundancy. No information is lost in lossless compression. Lossy compression reduces bits by removing unnecessary or less important information.[3] Typically, a device that performs data compression is referred to as an encoder, and one that performs the reversal of the process (decom...\u001b[0m\r\n\u001b[1m\u001b[31mE         \u001b[0m\r\n\u001b[1m\u001b[31mE         ...Full output truncated (15 lines hidden), use '-vv' to show\u001b[0m\r\n\r\n\u001b[1m\u001b[31m/tests/test_outputs.py\u001b[0m:55: AssertionError\r\n\u001b[31m\u001b[1m____________________________________________________________________ test_compression_size _____________________________________________________________________\u001b[0m\r\n\r\n"]
[42.163094, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_compression_size\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"Test that the compressed file size meets requirements.\"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        setup()\u001b[90m\u001b[39;49;00m\r\n        max_size_bytes = \u001b[94m2500\u001b[39;49;00m  \u001b[90m# As specified in task.yaml\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        compressed_path = Path(\u001b[33m\"\u001b[39;49;00m\u001b[33m/app/data.comp\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n        \u001b[94massert\u001b[39;49;00m compressed_path.exists(), \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mCompressed file \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mcompressed_path\u001b[33m}\u001b[39;49;00m\u001b[33m does not exist\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n"]
[42.163218, "o", "        \u001b[90m# Check file size\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        file_size = compressed_path.stat().st_size\u001b[90m\u001b[39;49;00m\r\n>       \u001b[94massert\u001b[39;49;00m file_size <= max_size_bytes, (\u001b[90m\u001b[39;49;00m\r\n            \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mCompressed file size (\u001b[39;49;00m\u001b[33m{\u001b[39;49;00mfile_size\u001b[33m}\u001b[39;49;00m\u001b[33m bytes) exceeds \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mmaximum allowed size (\u001b[39;49;00m\u001b[33m{\u001b[39;49;00mmax_size_bytes\u001b[33m}\u001b[39;49;00m\u001b[33m bytes)\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        )\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31mE       AssertionError: Compressed file size (3779 bytes) exceeds maximum allowed size (2500 bytes)\u001b[0m\r\n\u001b[1m\u001b[31mE       assert 3779 <= 2500\u001b[0m\r\n\r\n\u001b[1m\u001b[31m/tests/test_outputs.py\u001b[0m:70: AssertionError\r\n============================================================================ PASSES ============================================================================\r\n"]
