CONNECT:\u001b[39;49;00m\u001b[33m{\u001b[39;49;00mmonitor_socket\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n                ], \u001b[96minput\u001b[39;49;00m=\u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m{\u001b[39;49;00mcmd\u001b[33m}\u001b[39;49;00m\u001b[33m\\n\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, capture_output=\u001b[94mTrue\u001b[39;49;00m, text=\u001b[94mTrue\u001b[39;49;00m, timeout=\u001b[94m5\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n                \u001b[94massert\u001b[39;49;00m res.returncode == \u001b[94m0\u001b[39;49;00m, \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mFailed to send \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mdescription\u001b[33m}\u001b[39;49;00m\u001b[33m via monitor\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n                time.sleep(\u001b[94m2\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n                \u001b[90m# After screenshot\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n                screenshot_name = \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mafter_key_\u001b[39;49;00m\u001b[33m{\u001b[39;49;00mi\u001b[33m}\u001b[39;49;00m\u001b[33m.png\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n                \u001b[94massert\u001b[39;49;00m subprocess.run([\u001b[90m\u001b[39;49;00m\r\n                    \u001b[33m\"\u001b[39;49;00m\u001b[33mvncsnapshot\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33m-allowblank\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33mlocalhost:1\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, screenshot"]
[62.171499, "o", "_name\u001b[90m\u001b[39;49;00m\r\n                ], capture_output=\u001b[94mTrue\u001b[39;49;00m, timeout=\u001b[94m10\u001b[39;49;00m).returncode == \u001b[94m0\u001b[39;49;00m, \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mFailed screenshot after \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mdescription\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n                after_img = cv2.imread(screenshot_name, cv2.IMREAD_GRAYSCALE)\u001b[90m\u001b[39;49;00m\r\n                \u001b[94massert\u001b[39;49;00m after_img \u001b[95mis\u001b[39;49;00m \u001b[95mnot\u001b[39;49;00m \u001b[94mNone\u001b[39;49;00m, \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mInvalid screenshot after \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mdescription\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n                \u001b[90m# Percentage of different pixels\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n                diff_pct = (np.count_nonzero(baseline_img != after_img) / baseline_img.size) * \u001b[94m100.0\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n                \u001b[94mif\u001b[39;49;00m diff_pct >= threshold_pct:\u001b[90m\u001b[39;49;00m\r\n                    baseline_path.unlink(missing_ok=\u001b[94mTrue\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n                    \u001b[94mreturn\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n            \u001b[90m# If none exceeded threshold\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            baseline_path.unlink(missing_ok=\u001b[94mTrue\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n            \u001b[94massert\u001b[39;49;00m \u001b[94mFalse\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33mNo key caused >=10\u001b[39;49;00m\u001b[33m% i\u001b[39;49;00m\u001b[33mmage