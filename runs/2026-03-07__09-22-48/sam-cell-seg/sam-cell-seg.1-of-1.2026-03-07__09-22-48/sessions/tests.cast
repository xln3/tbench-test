[581.9651, "o", "\r\n"]
[581.965237, "o", "\r\n"]
[582.027246, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_mask_alignment\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m"]
[582.027402, "o", "\r\n"]
[582.02756, "o", "    \u001b[90m    \u001b[39;49;00m\u001b[33m'''Test that the predicted masks align reasonably with the masks generated\u001b[39;49;00m"]
[582.027664, "o", "\r\n"]
[582.027778, "o", "    \u001b[33m     by solution.sh '''\u001b[39;49;00m\u001b[90m\u001b[39;49;00m"]
[582.027842, "o", "\r\n"]
[582.027943, "o", "        out_df = _read_polylines_csv(\u001b[33m\"\u001b[39;49;00m\u001b[33m/app/test_output.csv\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m"]
[582.028005, "o", "\r\n"]
[582.028113, "o", "        correct_df = _read_polylines_csv(\u001b[33m\"\u001b[39;49;00m\u001b[33m/app/correct_output.csv\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m"]
[582.028183, "o", "\r\n"]
[582.028316, "o", "        \u001b[94mfor\u001b[39;49;00m (_, row_out), (_, row_correct) \u001b[95min\u001b[39;49;00m \u001b[96mzip\u001b[39;49;00m(out_df.iterrows(), correct_df.iterrows()):\u001b[90m\u001b[39;49;00m"]
[582.028391, "o", "\r\n"]
[582.028528, "o", "            points_out = \u001b[96mlist\u001b[39;49;00m(\u001b[96mzip\u001b[39;49;00m(row_out[\u001b[33m'\u001b[39;49;00m\u001b[33mcoords_x\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m], row_out[\u001b[33m'\u001b[39;49;00m\u001b[33mcoords_y\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m]))\u001b[90m\u001b[39;49;00m"]
[582.028631, "o", "\r\n"]
[582.028779, "o", "            points_correct = \u001b[96mlist\u001b[39;49;00m(\u001b[96mzip\u001b[39;49;00m(row_correct[\u001b[33m'\u001b[39;49;00m\u001b[33mcoords_x\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m], row_correct[\u001b[33m'\u001b[39;49;00m\u001b[33mcoords_y\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m]))\u001b[90m\u001b[39;49;00m"]
[582.028871, "o", "\r\n"]
[582.028999, "o", "            iou = calculate_iou(np.array(points_out), np.array(points_correct))\u001b[90m\u001b[39;49;00m"]
[582.02909, "o", "\r\n"]
[582.029226, "o", ">           \u001b[94massert\u001b[39;49;00m iou >= \u001b[94m0.5\u001b[39;49;00m, \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mIoU is too low: \u001b[39;49;00m\u001b[33m{\u001b[39;49;00miou\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m"]
[582.029319, "o", "\r\n"]
[582.029473, "o", "\u001b[1m\u001b[31mE           AssertionError: IoU is too low: 0.038496104366733105\u001b[0m"]
[582.029599, "o", "\r\n"]
[582.030182, "o", "\u001b[1m\u001b[31mE           assert 0.038496104366733105 >= 0.5\u001b[0m\r\n\r\n\u001b[1m\u001b[31m/tests/test_outputs.py\u001b[0m:221: AssertionError\r\n\u001b[31m\u001b[1m__________________________________________________________________ test_no_polyline_overlaps ___________________________________________________________________\u001b[0m\r\n\r\n"]
[582.033694, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_no_polyline_overlaps\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"\u001b[39;49;00m\r\n    \u001b[33m    Checks that there are no significant overlaps between any of the predicted masks.\u001b[39;49;00m\r\n    \u001b[33m    \"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        df = _read_polylines_csv(\u001b[33m\"\u001b[39;49;00m\u001b[33m/app/test_output.csv\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n        polygons = []\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mfor\u001b[39;49;00m index, row \u001b[95min\u001b[39;49;00m df.iterrows():\u001b[90m\u001b[39;49;00m\r\n            points = \u001b[96mlist\u001b[39;49;00m(\u001b[96mzip\u001b[39;49;00m(row[\u001b[33m'\u001b[39;49;00m\u001b[33mcoords_x\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m], row[\u001b[33m'\u001b[39;49;00m\u001b[33mcoords_y\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m]))\u001b[90m\u001b[39;49;00m\r\n            poly = _as_polygon(points)\u001b[90m\u001b[39;49;00m\r\n"]
[582.033754, "o", "            \u001b[94mif\u001b[39;49;00m poly:\u001b[90m\u001b[39;49;00m\r\n                polygons.append(poly)\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Check for overlaps between all pairs of polygons\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mfor\u001b[39;49;00m poly1, poly2 \u001b[95min\u001b[39;49;00m itertools.combinations(polygons, \u001b[94m2\u001b[39;49;00m):\u001b[90m\u001b[39;49;00m\r\n"]
[582.033779, "o", "            \u001b[94mif\u001b[39;49;00m poly1.intersects(poly2):\u001b[90m\u001b[39;49;00m\r\n                intersection_area = poly1.intersection(poly2).area\u001b[90m\u001b[39;49;00m"]
[582.033802, "o", "\r\n                \u001b[90m# Fail if intersection area is more than a tiny fraction of either polygon's\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n"]
[582.033824, "o", "                \u001b[90m# area this avoids failures due to simple touching boundaries\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n"]
[582.034138, "o", ">               \u001b[94massert\u001b[39;49;00m intersection_area / poly1.area < \u001b[94m1e-3\u001b[39;49;00m, (\u001b[33m\"\u001b[39;49;00m\u001b[33mPolygons \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n                                                               \u001b[33m\"\u001b[39;49;00m\u001b[33moverlap significantly\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31mE               AssertionError: Polygons overlap significantly\u001b[0m\r\n\u001b[1m\u001b[31mE               assert (137974.0 / 137975.0) < 0.001\u001b[0m\r\n\u001b[1m\u001b[31mE                +  where 137975.0 = <POLYGON ((0 0, 0 363, 1 364, 1 365, 2 366, 374 366, 375 367, 376 366, 377 3...>.area\u001b[0m\r\n\r\n\u001b[1m\u001b[31m/tests/test_outputs.py\u001b[0m:241: AssertionError\r\n\u001b[31m\u001b[1m__________________________________________________________________ test_coords_are_flat_lists __________________________________________________________________\u001b[0m\r\n\r\n"]
[582.038445, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_coords_are_flat_lists\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"\u001b[39;49;00m\r\n    \u001b[33m    Checks that 'coords_x' and 'coords_y' columns contain flat lists of numbers,\u001b[39;49;00m\r\n    \u001b[33m    allowing for them to be stored as strings.\u001b[39;49;00m\r\n    \u001b[33m    \"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        df = pd.read_csv(\u001b[33m\"\u001b[39;49;00m\u001b[33m/app/test_output.csv\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mfor\u001b[39;49;00m col \u001b[95min\u001b[39;49;00m [\u001b[33m'\u001b[39;49;00m\u001b[33mcoords_x\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m, \u001b[33m'\u001b[39;49;00m\u001b[33mcoords_y\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m]:\u001b[90m\u001b[39;49;00m\r\n            \u001b[94mfor\u001b[39;49;00m index, value \u001b[95min\u001b[39;49;00m df[col].items():\u001b[90m\u001b[39;49;00m\r\n                parsed_value = \u001b[94mNone\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n                \u001b[94mif\u001b[39;49;00m \u001b[96misinstance\u001b[39;49;00m(value, \u001b[96mstr\u001b[39;49;00m):\u001b[90m\u001b[39;49;00m\r\n                    \u001b[94mtry\u001b[39;49;00m:\u001b[90m\u001b[39;49;00m\r\n                        \u001b[90m# Use ast.literal_eval for safe evaluation of string\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n                        parsed_value = ast.literal_eval(value)\u001b[90m\u001b[39;49;00m\r\n"]
[582.038545, "o", "                    \u001b[94mexcept\u001b[39;49;00m (\u001b[96mValueError\u001b[39;49;00m, \u001b[96mSyntaxError\u001b[39;49;00m):\u001b[90m\u001b[39;49;00m\r\n                        \u001b[94massert\u001b[39;49;00m \u001b[94mFalse\u001b[39;49;00m, (\u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mRow \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mindex\u001b[33m}\u001b[39;49;00m\u001b[33m, column \u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33m{\u001b[39;49;00mcol\u001b[33m}\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33m: \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n                                       \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mcould not parse string.\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n                \u001b[94melif\u001b[39;49;00m \u001b[96misinstance\u001b[39;49;00m(value, (\u001b[96mlist\u001b[39;49;00m, np.ndarray)):\u001b[90m\u001b[39;49;00m\r\n                    parsed_value = value\u001b[90m\u001b[39;49;00m\r\n                \u001b[94melse\u001b[39;49;00m:\u001b[90m\u001b[39;49;00m\r\n                    \u001b[94massert\u001b[39;49;00m \u001b[94mFalse\u001b[39;49;00m, (\u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mRow \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mindex\u001b[33m}\u001b[39;49;00m\u001b[33m, column \u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33m{\u001b[39;49;00mcol\u001b[33m}\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33m: value is\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n                                   \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m not a list or string (got \u001b[39;49;00m\u001b[33m{\u001b[39;49;00m\u001b[96mtype\u001b[39;49;00m(value)\u001b[33m}\u001b[39;49;00m\u001b[33m).\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n>               \u001b[94massert\u001b[39;49;00m \u001b[96misinstance\u001b[39;49;00m(parsed_value, \u001b[96mlist\u001b[39;49;00m), \\\r\n                    (\u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mRow \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mindex\u001b[33m}\u001b[39;49;00m\u001b[33m, column \u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33m{\u001b[39;49;00mcol\u001b[33m}\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33m: parsed value is \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n                     \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mnot a list (got \u001b[39;49;00m\u001b[33m{\u001b[39;49;00m\u001b[96mtype\u001b[39;49;00m(parsed_value)\u001b[33m}\u001b[39;49;00m\u001b[33m).\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31mE               AssertionError: Row 0, column 'coords_x': parsed value is not a list (got <class 'tuple'>).\u001b[0m\r\n\u001b[1m\u001b[31mE               assert False\u001b[0m\r\n"]
