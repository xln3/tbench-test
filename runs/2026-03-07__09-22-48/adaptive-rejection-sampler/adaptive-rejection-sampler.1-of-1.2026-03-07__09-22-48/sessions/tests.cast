[45.850273, "o", "\u001b[36m\u001b[1m=================================================================== short test summary info ====================================================================\u001b[0m\r\n\u001b[32mPASSED\u001b[0m ../tests/test_outputs.py::\u001b[1mtest_ars_function_exists\u001b[0m\r\n\u001b[32mPASSED\u001b[0m ../tests/test_outputs.py::\u001b[1mtest_has_test_function\u001b[0m\r\n\u001b[32mPASSED\u001b[0m ../tests/test_outputs.py::\u001b[1mtest_formal_testing_with_known_truth\u001b[0m\r\n\u001b[32mPASSED\u001b[0m ../tests/test_outputs.py::\u001b[1mtest_implementation_is_modular\u001b[0m\r\n\u001b[32mPASSED\u001b[0m ../tests/test_outputs.py::\u001b[1mtest_implementation_handles_errors\u001b[0m\r\n"]
