[45.845873, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_can_generate_standard_distribution_samples\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"Test implementation can generate samples from standard distributions.\"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        app_dir = Path(\u001b[33m\"\u001b[39;49;00m\u001b[33m/app\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Test R implementation by sourcing ars.R and running tests\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        test_code_r = \u001b[33m\"\"\"\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33mlibrary(stats)\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m\u001b[39;49;00m\r\n    \u001b[33m# Source the required ars.R file\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33msource(\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mars.R\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m)\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n"]
[45.846021, "o", "    \u001b[33m\u001b[39;49;00m\r\n    \u001b[33m# Test normal distribution sampling\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33mnormal_density <- function(x) \u001b[39;49;00m\u001b[33m{\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m    dnorm(x, mean = 0, sd = 1)\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m}\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m\u001b[39;49;00m\r\n    \u001b[33m# Try to generate samples\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33mtryCatch(\u001b[39;49;00m\u001b[33m{\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m    samples <- ars(normal_density, c(-5, 5), n = 1000)\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m\u001b[39;49;00m\r\n    \u001b[33m    if (length(samples) >= 900) \u001b[39;49;00m\u001b[33m{\u001b[39;49;00m\u001b[33m  # Allow some tolerance\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n"]
[45.846128, "o", "    \u001b[33m        mean_val <- mean(samples)\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m        std_val <- sd(samples)\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m\u001b[39;49;00m\r\n    \u001b[33m        if (abs(mean_val) < 0.2 && std_val > 0.8 && std_val < 1.2) \u001b[39;49;00m\u001b[33m{\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m            cat(\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mPASS: Generated valid normal samples\u001b[39;49;00m\u001b[33m\\n\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m)\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m        } else \u001b[39;49;00m\u001b[33m{\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m            cat(\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mERROR: Mean or std out of range\u001b[39;49;00m\u001b[33m\\n\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m)\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m        }\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m    } else \u001b[39;49;00m\u001b[33m{\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m        cat(\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mERROR: Insufficient samples generated\u001b[39;49;00m\u001b[33m\\n\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m)\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m    }\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m}, error = function(e) \u001b[39;49;00m\u001b[33m{\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m    cat(\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mERROR: Failed to generate samples:\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m, conditionMessage(e), \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m\\n\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m)\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m})\u001b[39;49;00m\u001b[33m\u001b[39;49;00m\r\n    \u001b[33m\"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Run R test\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        test_file = app_dir / \u001b[33m\"\u001b[39;49;00m\u001b[33mtest_normal_sampler.R\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n"]
[45.846211, "o", "        test_file.write_text(test_code_r)\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mtry\u001b[39;49;00m:\u001b[90m\u001b[39;49;00m\r\n            result = subprocess.run(\u001b[90m\u001b[39;49;00m\r\n                [\u001b[33m\"\u001b[39;49;00m\u001b[33mRscript\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[96mstr\u001b[39;49;00m(test_file)],\u001b[90m\u001b[39;49;00m\r\n                capture_output=\u001b[94mTrue\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n                text=\u001b[94mTrue\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n                cwd=\u001b[96mstr\u001b[39;49;00m(app_dir),\u001b[90m\u001b[39;49;00m\r\n                timeout=\u001b[94m30\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n            )\u001b[90m\u001b[39;49;00m\r\n            output = result.stdout + result.stderr\u001b[90m\u001b[39;49;00m\r\n>           \u001b[94massert\u001b[39;49;00m \u001b[33m\"\u001b[39;49;00m\u001b[33mPASS\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m \u001b[95min\u001b[39;49;00m output, (\u001b[90m\u001b[39;49;00m\r\n                \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mFailed to generate valid normal samples. Output: \u001b[39;49;00m\u001b[33m{\u001b[39;49;00moutput\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            )\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31mE           AssertionError: Failed to generate valid normal samples. Output: ERROR: Mean or std out of range\u001b[0m\r\n\u001b[1m\u001b[31mE             \u001b[0m\r\n"]
[45.846287, "o", "\u001b[1m\u001b[31mE           assert 'PASS' in 'ERROR: Mean or std out of range\\n'\u001b[0m\r\n\r\n\u001b[1m\u001b[31m/tests/test_outputs.py\u001b[0m:81: AssertionError\r\n"]
[45.846377, "o", "\u001b[31m\u001b[1m_________________________________________________________________ test_sample_files_generated __________________________________________________________________\u001b[0m\r\n\r\n"]
[45.848578, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_sample_files_generated\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"Test that required sample files are generated.\"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        app_dir = Path(\u001b[33m\"\u001b[39;49;00m\u001b[33m/app\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Check for required sample files as specified in task\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        normal_file = app_dir / \u001b[33m\"\u001b[39;49;00m\u001b[33mnormal_samples.txt\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n"]
[45.84869, "o", "        exp_file = app_dir / \u001b[33m\"\u001b[39;49;00m\u001b[33mexponential_samples.txt\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[94massert\u001b[39;49;00m normal_file.exists() \u001b[95mor\u001b[39;49;00m exp_file.exists(), (\u001b[90m\u001b[39;49;00m\r\n            \u001b[33m\"\u001b[39;49;00m\u001b[33mAt least one sample file must be generated. Task requires generating \u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33mnormal_samples.txt\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33m \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            \u001b[33m\"\u001b[39;49;00m\u001b[33mor \u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33mexponential_samples.txt\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33m containing test samples\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        )\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Verify samples are valid if files exist\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mif\u001b[39;49;00m normal_file.exists():\u001b[90m\u001b[39;49;00m\r\n            samples = np.loadtxt(normal_file)\u001b[90m\u001b[39;49;00m\r\n            \u001b[94massert\u001b[39;49;00m \u001b[96mlen\u001b[39;49;00m(samples) >= \u001b[94m100\u001b[39;49;00m, (\u001b[90m\u001b[39;49;00m\r\n                \u001b[33m\"\u001b[39;49;00m\u001b[33mNormal samples file should contain at least 100 samples\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            )\u001b[90m\u001b[39;49;00m\r\n            mean = np.mean(samples)\u001b[90m\u001b[39;49;00m\r\n            std = np.std(samples)\u001b[90m\u001b[39;49;00m\r\n>           \u001b[94massert\u001b[39;49;00m \u001b[96mabs\u001b[39;49;00m(mean) < \u001b[94m0.5\u001b[39;49;00m \u001b[95mand\u001b[39;49;00m \u001b[94m0.5\u001b[39;49;00m < std < \u001b[94m1.5\u001b[39;49;00m, (\u001b[90m\u001b[39;49;00m\r\n"]
[45.848763, "o", "                \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mNormal samples don\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33mt match expected distribution \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n                \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m(mean=\u001b[39;49;00m\u001b[33m{\u001b[39;49;00mmean\u001b[33m:\u001b[39;49;00m\u001b[33m.3f\u001b[39;49;00m\u001b[33m}\u001b[39;49;00m\u001b[33m, std=\u001b[39;49;00m\u001b[33m{\u001b[39;49;00mstd\u001b[33m:\u001b[39;49;00m\u001b[33m.3f\u001b[39;49;00m\u001b[33m}\u001b[39;49;00m\u001b[33m)\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            )\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31mE           AssertionError: Normal samples don't match expected distribution (mean=0.037, std=1.928)\u001b[0m\r\n\u001b[1m\u001b[31mE           assert (np.float64(0.03660204758513913) < 0.5 and np.float64(1.9280837364529353) < 1.5)\u001b[0m\r\n\u001b[1m\u001b[31mE            +  where np.float64(0.03660204758513913) = abs(np.float64(0.03660204758513913))\u001b[0m\r\n"]
