[617.017337, "o", "\u001b[31m                                                                                                                          [100%]\u001b[0m"]
[617.023054, "o", "\r\n\r\n"]
[617.023115, "o", "=========================================================================== FAILURES ===========================================================================\r\n\u001b[31m\u001b[1m__________________________________________________________________ test_outputs_match_exactly __________________________________________________________________\u001b[0m\r\n"]
[617.023234, "o", "\r\n"]
[617.024837, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_outputs_match_exactly\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"Asserts the optimized query output matches the golden query EXACTLY:\u001b[39;49;00m\r\n    \u001b[33m    - same column names (case and order)\u001b[39;49;00m\r\n    \u001b[33m    - same number of rows\u001b[39;49;00m\r\n    \u001b[33m    - same row values in the same order\u001b[39;49;00m\r\n    \u001b[33m    \"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[94massert\u001b[39;49;00m DB_PATH.exists(), \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mDB not found at \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mDB_PATH\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[94massert\u001b[39;49;00m GOLDEN_SQL_PATH.exists(), \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mGolden SQL not found at \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mGOLDEN_SQL_PATH\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n"]
[617.024969, "o", "        \u001b[94massert\u001b[39;49;00m SOL_SQL_PATH.exists(), \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mSolution SQL not found at \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mSOL_SQL_PATH\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        q_golden = _read_sql(GOLDEN_SQL_PATH)\u001b[90m\u001b[39;49;00m\r\n        q_sol = _read_sql(SOL_SQL_PATH)\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        cols_g, rows_g = _execute_get_columns_and_rows(DB_PATH, q_golden)\u001b[90m\u001b[39;49;00m\r\n        cols_s, rows_s = _execute_get_columns_and_rows(DB_PATH, q_sol)\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Column names must match exactly (including case) and order\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n>       \u001b[94massert\u001b[39;49;00m cols_g == cols_s, (\u001b[90m\u001b[39;49;00m\r\n            \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mColumn names/order differ.\u001b[39;49;00m\u001b[33m\\n\u001b[39;49;00m\u001b[33mGolden:  \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mcols_g\u001b[33m}\u001b[39;49;00m\u001b[33m\\n\u001b[39;49;00m\u001b[33mSolution:\u001b[39;49;00m\u001b[33m{\u001b[39;49;00mcols_s\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        )\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31mE       AssertionError: Column names/order differ.\u001b[0m\r\n\u001b[1m\u001b[31mE         Golden:  ('word_id', 'word', 'total_synsets', 'total_senses', 'distinct_domains', 'distinct_posids', 'top_synsetid', 'top_synset_sense_count')\u001b[0m\r\n"]
[617.025322, "o", "\u001b[1m\u001b[31mE         Solution:('word_id', 'word', 'total_synsets', 'total_senses', 'distinct_domains', 'distinct_posids', 'top_synsetid', 'synset_sense_count')\u001b[0m\r\n\u001b[1m\u001b[31mE       assert ('word_id', '..._posids', ...) == ('word_id', '..._posids', ...)\u001b[0m\r\n\u001b[1m\u001b[31mE         \u001b[0m\r\n\u001b[1m\u001b[31mE         At index 7 diff: \u001b[0m\u001b[33m'\u001b[39;49;00m\u001b[33mtop_synset_sense_count\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[90m\u001b[39;49;00m != \u001b[0m\u001b[33m'\u001b[39;49;00m\u001b[33msynset_sense_count\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\u001b[0m\r\n\u001b[1m\u001b[31mE         Use -v to get more diff\u001b[0m\r\n\r\n\u001b[1m\u001b[31m/tests/test_outputs.py\u001b[0m:165: AssertionError\r\n============================================================================ PASSES ============================================================================\r\n\u001b[32m\u001b[1m___________________________________________________________ test_compare_golden_vs_solution_runtime ____________________________________________________________\u001b[0m\r\n--------------------------------------------------------------------- Captured stdout call ---------------------------------------------------------------------\r\nRunning iteration 0 of 5\r\n{'iterations': 5, 'golden': {'median_s': 0.8459162563085556, 'min_s': 0.8347112443298101, 'max_s': 0.9278030171990395}, 'solution': {'median_s': 0.8544302880764008, 'min_s': 0.8480912111699581, 'max_s': 1.2187259178608656}, 'speedup_solution_vs_golden': 0.9900354284174394}\r\n\u001b[32m\u001b[1m___________________________________________________________ test_solution_contains_single_sql_query ____________________________________________________________\u001b[0m\r\n--------------------------------------------------------------------- Captured stdout call ---------------------------------------------------------------------\r\n✓ Solution file contains exactly one valid SQL SELECT statement\r\n"]
[617.026234, "o", "\u001b[36m\u001b[1m=================================================================== short test summary info ====================================================================\u001b[0m\r\n\u001b[32mPASSED\u001b[0m ../tests/test_outputs.py::\u001b[1mtest_compare_golden_vs_my_sql_query_correctness\u001b[0m\r\n\u001b[32mPASSED\u001b[0m ../tests/test_outputs.py::\u001b[1mtest_check_for_db_modifications\u001b[0m\r\n\u001b[32mPASSED\u001b[0m ../tests/test_outputs.py::\u001b[1mtest_compare_golden_vs_solution_runtime\u001b[0m\r\n\u001b[32mPASSED\u001b[0m ../tests/test_outputs.py::\u001b[1mtest_solution_contains_single_sql_query\u001b[0m\r\n\u001b[32mPASSED\u001b[0m ../tests/test_outputs.py::\u001b[1mtest_solution_is_small\u001b[0m\r\n\u001b[31mFAILED\u001b[0m ../tests/test_outputs.py::\u001b[1mtest_outputs_match_exactly\u001b[0m - AssertionError: Column names/order differ.\r\n"]
