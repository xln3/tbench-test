[604.153514, "o", "\u001b[32m.\u001b[0m"]
[604.445744, "o", "\u001b[32m.\u001b[0m"]
[615.295497, "o", "\u001b[32m.\u001b[0m"]
[617.014201, "o", "\u001b[31mF\u001b[0m"]
[617.01626, "o", "\u001b[32m.\u001b[0m"]
