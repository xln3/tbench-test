[29.340187, "o", "    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"\u001b[39;49;00m\r\n    \u001b[33m    Compare two videos frame by frame using structural similarity index (SSIM).\u001b[39;49;00m\r\n    \u001b[33m\u001b[39;49;00m\r\n    \u001b[33m    Args:\u001b[39;49;00m\r\n    \u001b[33m        video1_path: Path to first video\u001b[39;49;00m\r\n    \u001b[33m        video2_path: Path to second video\u001b[39;49;00m\r\n    \u001b[33m        max_frames: Maximum number of frames to compare (None for all frames)\u001b[39;49;00m\r\n    \u001b[33m        similarity_threshold: Minimum SSIM score to consider frames similar\u001b[39;49;00m\r\n    \u001b[33m\u001b[39;49;00m\r\n    \u001b[33m    Returns:\u001b[39;49;00m\r\n    \u001b[33m        Tuple containing (is_similar, similarity_scores)\u001b[39;49;00m\r\n    \u001b[33m    \"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        cap1 = cv2.VideoCapture(\u001b[96mstr\u001b[39;49;00m(video1_path))\u001b[90m\u001b[39;49;00m\r\n        cap2 = cv2.VideoCapture(\u001b[96mstr\u001b[39;49;00m(video2_path))\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        similarity_scores: List[\u001b[96mfloat\u001b[39;49;00m] = []\u001b[90m\u001b[39;49;00m\r\n        frame_count = \u001b[94m0\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n   "]
[29.340303, "o", "     valid_comparisons = \u001b[94m0\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[94mwhile\u001b[39;49;00m \u001b[94mTrue\u001b[39;49;00m:\u001b[90m\u001b[39;49;00m\r\n            \u001b[94mif\u001b[39;49;00m max_frames \u001b[95mand\u001b[39;49;00m frame_count >= max_frames:\u001b[90m\u001b[39;49;00m\r\n                \u001b[94mbreak\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n            ret1, frame1 = cap1.read()\u001b[90m\u001b[39;49;00m\r\n            ret2, frame2 = cap2.read()\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n            \u001b[94mif\u001b[39;49;00m \u001b[95mnot\u001b[39;49;00m ret1 \u001b[95mor\u001b[39;49;00m \u001b[95mnot\u001b[39;49;00m ret2:\u001b[90m\u001b[39;49;00m\r\n                \u001b[94mbreak\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n            \u001b[94mtry\u001b[39;49;00m:\u001b[90m\u001b[39;49;00m\r\n                \u001b[90m# Convert frames to grayscale for comparison\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n                gray1 = cv2.cvtColor(frame1, cv2.COLOR_BGR2GRAY)\u001b[90m\u001b[39;49;00m\r\n                gray2 = cv2.cvtColor(frame2, cv2.COLOR_BGR2GRAY)\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n                \u001b[90m# Ensure f"]
[29.340426, "o", "rames are the same size\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n                \u001b[94mif\u001b[39;49;00m gray1.shape != gray2.shape:\u001b[90m\u001b[39;49;00m\r\n                    gray2 = cv2.resize(gray2, (gray1.shape[\u001b[94m1\u001b[39;49;00m], gray1.shape[\u001b[94m0\u001b[39;49;00m]))\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n                \u001b[90m# Calculate structural similarity index\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n                score = cv2.matchTemplate(gray1, gray2, cv2.TM_CCOEFF_NORMED)[\u001b[94m0\u001b[39;49;00m][\u001b[94m0\u001b[39;49;00m]\u001b[90m\u001b[39;49;00m\r\n                similarity_scores.append(score)\u001b[90m\u001b[39;49;00m\r\n                valid_comparisons += \u001b[94m1\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n            \u001b[94mexcept\u001b[39;49;00m cv2.error \u001b[94mas\u001b[39;49;00m e:\u001b[90m\u001b[39;49;00m\r\n                \u001b[96mprint\u001b[39;49;00m(\u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mWarning: Failed to compare frame \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mframe_count\u001b[33m}\u001b[39;49;00m\u001b[33m: \u001b[39;49;00m\u001b[33m{\u001b[39;49;00m\u001b[96mstr\u001b[39;49;00m(e)\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n"]
[29.340581, "o", "    \u001b[90m\u001b[39;49;00m\r\n            frame_count += \u001b[94m1\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        cap1.release()\u001b[90m\u001b[39;49;00m\r\n        cap2.release()\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[94mif\u001b[39;49;00m valid_comparisons == \u001b[94m0\u001b[39;49;00m:\u001b[90m\u001b[39;49;00m\r\n>           \u001b[94mraise\u001b[39;49;00m \u001b[96mValueError\u001b[39;49;00m(\u001b[33m\"\u001b[39;49;00m\u001b[33mNo valid frame comparisons were made\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31mE           ValueError: No valid frame comparisons were made\u001b[0m\r\n"]
