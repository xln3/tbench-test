[17.373825, "o", "    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Check for typical venv structure\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        python_bin = venv_path / \u001b[33m\"\u001b[39;49;00m\u001b[33mbin\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m / \u001b[33m\"\u001b[39;49;00m\u001b[33mpython\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[94massert\u001b[39;49;00m python_bin.exists(), \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mPython binary not found at \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mpython_bin\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Verify it's actually a virtual environment by checking it has spinup installed\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mtry\u001b[39;49;00m:\u001b[90m\u001b[39;49;00m\r\n            result = subprocess.run(\u001b[90m\u001b[39;49;00m\r\n                [\u001b[96mstr\u001b[39;49;00m(python_bin), \u001b[33m\"\u001b[39;49;00m\u001b[33m-c\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33mimport spinup; print(\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33mspinup found\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33m)\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m],\u001b[90m\u001b[39;49;00m\r\n                capture_output=\u001b[94mTrue\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n"]
[17.373864, "o", "                text=\u001b[94mTrue\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n                timeout=\u001b[94m60\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n            )\u001b[90m\u001b[39;49;00m\r\n>           \u001b[94massert\u001b[39;49;00m result.returncode == \u001b[94m0\u001b[39;49;00m, \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mspinup not found in venv at \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mvenv_path\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31mE           AssertionError: spinup not found in venv at /app/spinningup/.venv\u001b[0m\r\n\u001b[1m\u001b[31mE           assert 1 == 0\u001b[0m\r\n"]
[17.373902, "o", "\u001b[1m\u001b[31mE            +  where 1 = CompletedProcess(args=['/app/spinningup/.venv/bin/python', '-c', \"import spinup; print('spinup found')\"], returncode=1...k (most recent call last):\\n  File \"<string>\", line 1, in <module>\\nModuleNotFoundError: No module named \\'spinup\\'\\n').returncode\u001b[0m\r\n\r\n\u001b[1m\u001b[31m/tests/test_outputs.py\u001b[0m:176: AssertionError\r\n"]
