[17.860593, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92m_check_bucket\u001b[39;49;00m(bucket_idx: \u001b[96mint\u001b[39;49;00m, plan_name: \u001b[96mstr\u001b[39;49;00m) -> \u001b[94mNone\u001b[39;49;00m:\u001b[90m\u001b[39;49;00m\r\n        reqs = _load_requests(bucket_idx)\u001b[90m\u001b[39;49;00m\r\n        req_idx = {r[\u001b[33m\"\u001b[39;49;00m\u001b[33mrequest_id\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m]: r \u001b[94mfor\u001b[39;49;00m r \u001b[95min\u001b[39;49;00m reqs}\u001b[90m\u001b[39;49;00m\r\n"]
[17.860679, "o", "        plan = _load_plan(plan_name)\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Per-record feasibility and schema checks\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mfor\u001b[39;49;00m p \u001b[95min\u001b[39;49;00m plan:\u001b[90m\u001b[39;49;00m\r\n            rid = p[\u001b[33m\"\u001b[39;49;00m\u001b[33mrequest_id\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m]\u001b[90m\u001b[39;49;00m\r\n            \u001b[94massert\u001b[39;49;00m rid \u001b[95min\u001b[39;49;00m req_idx\u001b[90m\u001b[39;49;00m\r\n            r = req_idx[rid]\u001b[90m\u001b[39;49;00m\r\n            s_aligned = align(r[\u001b[33m\"\u001b[39;49;00m\u001b[33mprompt_len\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m], gran)\u001b[90m\u001b[39;49;00m\r\n"]
[17.860731, "o", "            sh = p[\u001b[33m\"\u001b[39;49;00m\u001b[33mshape\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m]\u001b[90m\u001b[39;49;00m\r\n            \u001b[94massert\u001b[39;49;00m sh[\u001b[33m\"\u001b[39;49;00m\u001b[33mseq_align\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m] % gran == \u001b[94m0\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            \u001b[94massert\u001b[39;49;00m sh[\u001b[33m\"\u001b[39;49;00m\u001b[33mheads_align\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m] == HEADS\u001b[90m\u001b[39;49;00m\r\n            \u001b[94massert\u001b[39;49;00m sh[\u001b[33m\"\u001b[39;49;00m\u001b[33mhidden_align\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m] == HIDDEN\u001b[90m\u001b[39;49;00m\r\n            \u001b[90m# Feasibility: assigned shape must cover the aligned prompt length\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n>           \u001b[94massert\u001b[39;49;00m sh[\u001b[33m\"\u001b[39;49;00m\u001b[33mseq_align\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m] >= s_aligned\u001b[90m\u001b[39;49;00m\r\n"]
[17.86078, "o", "\u001b[1m\u001b[31mE           assert 1728 >= 1984\u001b[0m\r\n\r\n"]
[17.860831, "o", "\u001b[1m\u001b[31m/tests/test_outputs.py\u001b[0m:242: AssertionError\r\n"]
[17.860929, "o", "\u001b[31m\u001b[1m_________________________________________________________________ test_performance_thresholds __________________________________________________________________\u001b[0m\r\n"]
[17.860977, "o", "\r\n"]
[17.863688, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_performance_thresholds\u001b[39;49;00m() -> \u001b[94mNone\u001b[39;49;00m:\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"Test solution meets performance thresholds described in task.yaml.\u001b[39;49;00m\r\n"]
[17.863719, "o", "    \u001b[33m\u001b[39;49;00m\r\n    \u001b[33m    **Performance Thresholds:**\u001b[39;49;00m\r\n"]
[17.86385, "o", "    \u001b[33m    - Bucket 1: cost ≤ 3.0e11, pad_ratio ≤ 0.055, p95_latency ≤ 2.1e6 ms,\u001b[39;49;00m\r\n    \u001b[33m      sequential_timecost ≤ 2.7e8 ms\u001b[39;49;00m\r\n    \u001b[33m    - Bucket 2: cost ≤ 4.8e10, pad_ratio ≤ 0.15, p95_latency ≤ 2.1e5 ms,\u001b[39;49;00m\r\n    \u001b[33m      sequential_timecost ≤ 3.2e7 ms\u001b[39;49;00m\r\n    \u001b[33m\u001b[39;49;00m\r\n    \u001b[33m    **Optimization Verification:**\u001b[39;49;00m\r\n"]
[17.863916, "o", "    \u001b[33m    - Global shape constraint: ≤ 8 unique shapes across all buckets\u001b[39;49;00m\r\n    \u001b[33m\u001b[39;49;00m\r\n    \u001b[33m    \"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        req1_path = \u001b[33m\"\u001b[39;49;00m\u001b[33m/app/task_file/input_data/requests_bucket_1.jsonl\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n"]
[17.863978, "o", "        plan1_path = \u001b[33m\"\u001b[39;49;00m\u001b[33m/app/task_file/output_data/plan_b1.jsonl\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        m_b1 = _plan_metrics(req1_path, plan1_path)\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        req2_path = \u001b[33m\"\u001b[39;49;00m\u001b[33m/app/task_file/input_data/requests_bucket_2.jsonl\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        plan2_path = \u001b[33m\"\u001b[39;49;00m\u001b[33m/app/task_file/output_data/plan_b2.jsonl\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n"]
[17.864024, "o", "        m_b2 = _plan_metrics(req2_path, plan2_path)\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Validate against tight absolute performance thresholds\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Bucket 1\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n"]
[17.864075, "o", ">       \u001b[94massert\u001b[39;49;00m m_b1[\u001b[33m\"\u001b[39;49;00m\u001b[33mcost\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m] <= \u001b[94m3.0e11\u001b[39;49;00m, \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mbucket1 cost \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mm_b1[\u001b[33m'\u001b[39;49;00m\u001b[33mcost\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m]\u001b[33m}\u001b[39;49;00m\u001b[33m > 3.0e11\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n"]
[17.864118, "o", "\u001b[1m\u001b[31mE       AssertionError: bucket1 cost 305566247408.0 > 3.0e11\u001b[0m\r\n\u001b[1m\u001b[31mE       assert 305566247408.0 <= 300000000000.0\u001b[0m\r\n\r\n"]
