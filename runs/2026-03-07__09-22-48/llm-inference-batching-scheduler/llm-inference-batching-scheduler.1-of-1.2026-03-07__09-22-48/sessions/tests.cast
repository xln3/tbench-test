[17.76419, "o", "=========================================================================== FAILURES ===========================================================================\r\n"]
[17.764269, "o", "\u001b[31m\u001b[1m____________________________________________________ test_solution_shape_feasibility_and_batch_consistency _____________________________________________________\u001b[0m\r\n\r\n"]
[17.855206, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_solution_shape_feasibility_and_batch_consistency\u001b[39;49;00m() -> \u001b[94mNone\u001b[39;49;00m:\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"Test that the solution produces feasible shapes and consistent batches.\u001b[39;49;00m\r\n    \u001b[33m\u001b[39;49;00m\r\n    \u001b[33m    This test validates the core correctness requirements for the batching scheduler:\u001b[39;49;00m\r\n    \u001b[33m\u001b[39;49;00m\r\n"]
[17.855294, "o", "    \u001b[33m    1. Shape Feasibility:\u001b[39;49;00m\r\n    \u001b[33m       - All shapes must be aligned to the specified granularity (64)\u001b[39;49;00m\r\n    \u001b[33m       - Assigned sequence length must be >= aligned prompt length\u001b[39;49;00m\r\n    \u001b[33m       - Head and hidden dimensions must match task.yaml constants.\u001b[39;49;00m\r\n    \u001b[33m\u001b[39;49;00m\r\n    \u001b[33m    2. Batch Consistency:\u001b[39;49;00m\r\n    \u001b[33m       - All requests within a batch must share identical shapes\u001b[39;49;00m\r\n    \u001b[33m       - The batch shape must accommodate the longest aligned prompt in the batch\u001b[39;49;00m\r\n    \u001b[33m\u001b[39;49;00m\r\n"]
[17.855418, "o", "    \u001b[33m    The test validates the output plans for\u001b[39;49;00m\r\n    \u001b[33m    both input buckets against these requirements.\u001b[39;49;00m\r\n    \u001b[33m    \"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n"]
[17.855497, "o", "        gran = \u001b[94m64\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92m_check_bucket\u001b[39;49;00m(bucket_idx: \u001b[96mint\u001b[39;49;00m, plan_name: \u001b[96mstr\u001b[39;49;00m) -> \u001b[94mNone\u001b[39;49;00m:\u001b[90m\u001b[39;49;00m\r\n            reqs = _load_requests(bucket_idx)\u001b[90m\u001b[39;49;00m\r\n            req_idx = {r[\u001b[33m\"\u001b[39;49;00m\u001b[33mrequest_id\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m]: r \u001b[94mfor\u001b[39;49;00m r \u001b[95min\u001b[39;49;00m reqs}\u001b[90m\u001b[39;49;00m\r\n            plan = _load_plan(plan_name)\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n            \u001b[90m# Per-record feasibility and schema checks\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            \u001b[94mfor\u001b[39;49;00m p \u001b[95min\u001b[39;49;00m plan:\u001b[90m\u001b[39;49;00m\r\n                rid = p[\u001b[33m\"\u001b[39;49;00m\u001b[33mrequest_id\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m]\u001b[90m\u001b[39;49;00m\r\n"]
[17.855611, "o", "                \u001b[94massert\u001b[39;49;00m rid \u001b[95min\u001b[39;49;00m req_idx\u001b[90m\u001b[39;49;00m\r\n                r = req_idx[rid]\u001b[90m\u001b[39;49;00m\r\n                s_aligned = align(r[\u001b[33m\"\u001b[39;49;00m\u001b[33mprompt_len\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m], gran)\u001b[90m\u001b[39;49;00m\r\n                sh = p[\u001b[33m\"\u001b[39;49;00m\u001b[33mshape\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m]\u001b[90m\u001b[39;49;00m\r\n                \u001b[94massert\u001b[39;49;00m sh[\u001b[33m\"\u001b[39;49;00m\u001b[33mseq_align\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m] % gran == \u001b[94m0\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n                \u001b[94massert\u001b[39;49;00m sh[\u001b[33m\"\u001b[39;49;00m\u001b[33mheads_align\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m] == HEADS\u001b[90m\u001b[39;49;00m\r\n                \u001b[94massert\u001b[39;49;00m sh[\u001b[33m\"\u001b[39;49;00m\u001b[33mhidden_align\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m] == HIDDEN\u001b[90m\u001b[39;49;00m\r\n"]
[17.855689, "o", "                \u001b[90m# Feasibility: assigned shape must cover the aligned prompt length\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n                \u001b[94massert\u001b[39;49;00m sh[\u001b[33m\"\u001b[39;49;00m\u001b[33mseq_align\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m] >= s_aligned\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n            \u001b[90m# Per-batch consistency: all entries share the same shape;\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            \u001b[90m# Feasibility: seq_align must be >= max aligned prompt_len within the batch\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            batches: \u001b[96mdict\u001b[39;49;00m[\u001b[96mstr\u001b[39;49;00m, \u001b[96mlist\u001b[39;49;00m[\u001b[96mdict\u001b[39;49;00m]] = {}\u001b[90m\u001b[39;49;00m\r\n            \u001b[94mfor\u001b[39;49;00m p \u001b[95min\u001b[39;49;00m plan:\u001b[90m\u001b[39;49;00m\r\n                batches.setdefault(p[\u001b[33m\"\u001b[39;49;00m\u001b[33mbatch_id\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m], []).append(p)\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n            \u001b[94mfor\u001b[39;49;00m bid, entries \u001b[95min\u001b[39;49;00m batches.items():\u001b[90m\u001b[39;49;00m\r\n"]
[17.855712, "o", "                sh0 = entries[\u001b[94m0\u001b[39;49;00m][\u001b[33m\"\u001b[39;49;00m\u001b[33mshape\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m]\u001b[90m\u001b[39;49;00m\r\n                \u001b[94mfor\u001b[39;49;00m p \u001b[95min\u001b[39;49;00m entries:\u001b[90m\u001b[39;49;00m\r\n                    \u001b[94massert\u001b[39;49;00m p[\u001b[33m\"\u001b[39;49;00m\u001b[33mshape\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m] == sh0\u001b[90m\u001b[39;49;00m\r\n                max_s = \u001b[96mmax\u001b[39;49;00m(\u001b[90m\u001b[39;49;00m\r\n                    align(req_idx[p[\u001b[33m\"\u001b[39;49;00m\u001b[33mrequest_id\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m]][\u001b[33m\"\u001b[39;49;00m\u001b[33mprompt_len\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m], gran) \u001b[94mfor\u001b[39;49;00m p \u001b[95min\u001b[39;49;00m entries\u001b[90m\u001b[39;49;00m\r\n                )\u001b[90m\u001b[39;49;00m\r\n"]
[17.855806, "o", "                \u001b[94massert\u001b[39;49;00m sh0[\u001b[33m\"\u001b[39;49;00m\u001b[33mseq_align\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m] >= max_s\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n"]
[17.85586, "o", ">       _check_bucket(\u001b[94m1\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33mplan_b1.jsonl\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n\r\n\u001b[1m\u001b[31m/tests/test_outputs.py\u001b[0m:259: \r\n"]
[17.855921, "o", "_ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ \r\n\r\n"]
