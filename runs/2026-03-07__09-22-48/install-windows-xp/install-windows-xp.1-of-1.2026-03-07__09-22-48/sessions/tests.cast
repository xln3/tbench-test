[29.066706, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_tb_admin_user_creation\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"\u001b[39;49;00m\r\n    \u001b[33m    Verify that the tb-admin user was created during Windows XP installation.\u001b[39;49;00m\r\n    \u001b[33m    Checks for user account picture which is created during unattended setup.\u001b[39;49;00m\r\n    \u001b[33m    \"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mimport\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[04m\u001b[96mtempfile\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        vhd_path = Path(\u001b[33m\"\u001b[39;49;00m\u001b[33m/app/isos/xp.img\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n"]
[29.06689, "o", "    \u001b[90m\u001b[39;49;00m\r\n        \u001b[94mwith\u001b[39;49;00m tempfile.TemporaryDirectory() \u001b[94mas\u001b[39;49;00m temp_dir:\u001b[90m\u001b[39;49;00m\r\n            extract_dir = temp_dir + \u001b[33m\"\u001b[39;49;00m\u001b[33m/xp_extract\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            os.makedirs(extract_dir)\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n            \u001b[90m# Extract VHD contents\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            subprocess.run(\u001b[90m\u001b[39;49;00m\r\n                [\u001b[33m\"\u001b[39;49;00m\u001b[33m7z\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33mx\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[96mstr\u001b[39;49;00m(vhd_path), \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m-o\u001b[39;49;00m\u001b[33m{\u001b[39;49;00mextract_dir\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33m-r\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m],\u001b[90m\u001b[39;49;00m\r\n                capture_output=\u001b[94mTrue\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n                text=\u001b[94mTrue\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n"]
[29.066973, "o", "            )\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n            \u001b[90m# Look for tb-admin.bmp (case-insensitive)\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            tb_admin_picture = \u001b[94mNone\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            \u001b[94mfor\u001b[39;49;00m root, dirs, files \u001b[95min\u001b[39;49;00m os.walk(extract_dir):\u001b[90m\u001b[39;49;00m\r\n                \u001b[94mfor\u001b[39;49;00m file \u001b[95min\u001b[39;49;00m files:\u001b[90m\u001b[39;49;00m\r\n                    \u001b[94mif\u001b[39;49;00m file.lower() == \u001b[33m\"\u001b[39;49;00m\u001b[33mtb-admin.bmp\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m:\u001b[90m\u001b[39;49;00m\r\n                        tb_admin_picture = Path(root) / file\u001b[90m\u001b[39;49;00m\r\n                        \u001b[94mbreak\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n                \u001b[94mif\u001b[39;49;00m tb_admin_picture:\u001b[90m\u001b[39;49;00m\r\n                    \u001b[94mbreak\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n>           \u001b[94massert\u001b[39;49;00m tb_admin_picture \u001b[95mand\u001b[39;49;00m tb_admin_picture.exists(), (\u001b[90m\u001b[39;49;00m\r\n                \u001b[33m\"\u001b[39;49;00m\u001b[33mtb-admin user was not created - account picture not found\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            )\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31mE           AssertionError: tb-admin user was not created - account picture not found\u001b[0m\r\n\u001b[1m\u001b[31mE           assert (None)\u001b[0m\r\n\r\n\u001b[1m\u001b[31m/tests/test_outputs.py\u001b[0m:332: AssertionError\r\n"]
