[29.052156, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_boot_sector_and_ntfs_formatting\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"Test boot sector signature and NTFS formatting\u001b[39;49;00m\r\n    \u001b[33m    exactly like monitor-vm.sh check_disk_initialization()\"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        vhd_path = Path(\u001b[33m\"\u001b[39;49;00m\u001b[33m/app/isos/xp.img\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n        \u001b[94massert\u001b[39;49;00m vhd_path.exists(), \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mWindows XP VHD file \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mvhd_path\u001b[33m}\u001b[39;49;00m\u001b[33m does not exist\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Check boot sector signature (read bytes directly)\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mwith\u001b[39;49;00m \u001b[96mopen\u001b[39;49;00m(vhd_path, \u001b[33m\"\u001b[39;49;00m\u001b[33mrb\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m) \u001b[94mas\u001b[39;49;00m f:\u001b[90m\u001b[39;49;00m\r\n            f.seek(\u001b[94m510\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n            signature = f.read(\u001b[94m2\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n        \u001b[94massert\u001b[39;49;00m signature == \u001b[33mb\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m\\x55\u001b[39;49;00m\u001b[33m\\xaa\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, (\u001b[90m\u001b[39;49;00m\r\n            \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mInvalid boot sector signature: \u001b[39;49;00m\u001b[33m{\u001b[39;49;00msignature.hex()\u001b[33m}\u001b[39;49;00m\u001b[33m (expected 55aa)\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        )\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Check NTFS partition (exactly like monitor-vm.sh line 39)\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mtry\u001b[39;49;00m:\u001b[90m\u001b[39;49;00m\r\n            parted_result = subprocess.run(\u001b[90m\u001b[39;49;00m\r\n                [\u001b[33m\"\u001b[39;49;00m\u001b[33mparted\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[96mstr\u001b[39;49;00m(vhd_path), \u001b[33m\"\u001b[39;49;00m\u001b[33mprint\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m],\u001b[90m\u001b[39;49;00m\r\n                capture_output=\u001b[94mTrue\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n                text=\u001b[94mTrue\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n                timeout=\u001b[94m10\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n"]
[29.052398, "o", "            )\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n            \u001b[90m# Look for primary NTFS bootable partition (same grep pattern as monitor-vm.sh)\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            ntfs_check = subprocess.run(\u001b[90m\u001b[39;49;00m\r\n                [\u001b[33m\"\u001b[39;49;00m\u001b[33mgrep\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33m-E\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33mprimary.*ntfs.*boot\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m],\u001b[90m\u001b[39;49;00m\r\n                \u001b[96minput\u001b[39;49;00m=parted_result.stdout,\u001b[90m\u001b[39;49;00m\r\n                text=\u001b[94mTrue\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n                capture_output=\u001b[94mTrue\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n            )\u001b[90m\u001b[39;49;00m\r\n>           \u001b[94massert\u001b[39;49;00m ntfs_check.returncode == \u001b[94m0\u001b[39;49;00m, (\u001b[90m\u001b[39;49;00m\r\n                \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mNo bootable NTFS partition found. Parted output: \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mparted_result.stdout\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            )\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31mE           AssertionError: No bootable NTFS partition found. Parted output: Model:  (file)\u001b[0m\r\n\u001b[1m\u001b[31mE             Disk /app/isos/xp.img: 10.7GB\u001b[0m\r\n\u001b[1m\u001b[31mE             Sector size (logical/physical): 512B/512B\u001b[0m\r\n\u001b[1m\u001b[31mE             Partition Table: msdos\u001b[0m\r\n\u001b[1m\u001b[31mE             Disk Flags: \u001b[0m\r\n\u001b[1m\u001b[31mE             \u001b[0m\r\n\u001b[1m\u001b[31mE             Number  Start  End  Size  Type  File system  Flags\u001b[0m\r\n\u001b[1m\u001b[31mE             \u001b[0m\r\n\u001b[1m\u001b[31mE             \u001b[0m\r\n\u001b[1m\u001b[31mE           assert 1 == 0\u001b[0m\r\n\u001b[1m\u001b[31mE            +  where 1 = CompletedProcess(args=['grep', '-E', 'primary.*ntfs.*boot'], returncode=1, stdout='', stderr='').returncode\u001b[0m\r\n\r\n\u001b[1m\u001b[31m/tests/test_outputs.py\u001b[0m:73: AssertionError\r\n"]
[29.052509, "o", "\u001b[31m\u001b[1m____________________________________________________________ test_login_screen_visual_verification _____________________________________________________________\u001b[0m\r\n\r\n"]
[29.056129, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_login_screen_visual_verification\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"\u001b[39;49;00m\r\n    \u001b[33m    Test Windows XP interface against multiple reference screenshots.\u001b[39;49;00m\r\n    \u001b[33m    Passes if current screenshot matches any reference with ≥85% similarity.\u001b[39;49;00m\r\n    \u001b[33m    \"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mimport\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[04m\u001b[96mcv2\u001b[39;49;00m  \u001b[90m# type: ignore\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mfrom\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[04m\u001b[96mskimage\u001b[39;49;00m\u001b[04m\u001b[96m.\u001b[39;49;00m\u001b[04m\u001b[96mmetrics\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[94mimport\u001b[39;49;00m structural_similarity \u001b[94mas\u001b[39;49;00m ssim  \u001b[90m# type: ignore\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Take current screenshot\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        subprocess.run(\u001b[90m\u001b[39;49;00m\r\n            [\u001b[33m\"\u001b[39;49;00m\u001b[33mvncsnapshot\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33m-allowblank\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33mlocalhost:1\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33mcurrent_screenshot.png\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m],\u001b[90m\u001b[39;49;00m\r\n            capture_output=\u001b[94mTrue\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n            timeout=\u001b[94m15\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n        )\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Load current screenshot\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        current_img = cv2.imread(\u001b[33m\"\u001b[39;49;00m\u001b[33mcurrent_screenshot.png\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, cv2.IMREAD_GRAYSCALE)\u001b[90m\u001b[39;49;00m\r\n        current_img = cv2.resize(current_img, (\u001b[94m256\u001b[39;49;00m, \u001b[94m256\u001b[39;49;00m)) / \u001b[94m255.0\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n"]
[29.056302, "o", "        \u001b[90m# Check against reference screenshots 1-6\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        best_score = \u001b[94m0\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mfor\u001b[39;49;00m i \u001b[95min\u001b[39;49;00m \u001b[96mrange\u001b[39;49;00m(\u001b[94m1\u001b[39;49;00m, \u001b[94m7\u001b[39;49;00m):\u001b[90m\u001b[39;49;00m\r\n            ref_path = \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m../tests/reference_screenshot\u001b[39;49;00m\u001b[33m{\u001b[39;49;00mi\u001b[33m}\u001b[39;49;00m\u001b[33m.png\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            \u001b[94mif\u001b[39;49;00m os.path.exists(ref_path):\u001b[90m\u001b[39;49;00m\r\n                ref_img = cv2.imread(ref_path, cv2.IMREAD_GRAYSCALE)\u001b[90m\u001b[39;49;00m\r\n                ref_img = cv2.resize(ref_img, (\u001b[94m256\u001b[39;49;00m, \u001b[94m256\u001b[39;49;00m)) / \u001b[94m255.0\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n                score, _ = ssim(current_img, ref_img, data_range=\u001b[94m1.0\u001b[39;49;00m, full=\u001b[94mTrue\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n                best_score = \u001b[96mmax\u001b[39;49;00m(best_score, score)\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n                \u001b[94mif\u001b[39;49;00m score >= \u001b[94m0.85\u001b[39;49;00m:\u001b[90m\u001b[39;49;00m\r\n                    \u001b[96mprint\u001b[39;49;00m(\u001b[90m\u001b[39;49;00m\r\n                        \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m✅ Screenshot matched reference_screenshot\u001b[39;49;00m\u001b[33m{\u001b[39;49;00mi\u001b[33m}\u001b[39;49;00m\u001b[33m.png \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n                        \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m(\u001b[39;49;00m\u001b[33m{\u001b[39;49;00mscore\u001b[33m:\u001b[39;49;00m\u001b[33m.1%\u001b[39;49;00m\u001b[33m}\u001b[39;49;00m\u001b[33m similarity)\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n                    )\u001b[90m\u001b[39;49;00m\r\n                    \u001b[94mreturn\u001b[39;49;00m  \u001b[90m# Pass immediately if any match found\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n>       \u001b[94massert\u001b[39;49;00m \u001b[94mFalse\u001b[39;49;00m, \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mNo reference screenshot matched ≥85% (best: \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mbest_score\u001b[33m:\u001b[39;49;00m\u001b[33m.1%\u001b[39;49;00m\u001b[33m}\u001b[39;49;00m\u001b[33m)\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n"]
[29.056407, "o", "\u001b[1m\u001b[31mE       AssertionError: No reference screenshot matched ≥85% (best: 29.8%)\u001b[0m\r\n\u001b[1m\u001b[31mE       assert False\u001b[0m\r\n\r\n\u001b[1m\u001b[31m/tests/test_outputs.py\u001b[0m:220: AssertionError\r\n"]
[29.056503, "o", "\u001b[31m\u001b[1m_____________________________________________________ test_windows_xp_installation_filesystem_verification _____________________________________________________\u001b[0m\r\n\r\n"]
[29.06353, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_windows_xp_installation_filesystem_verification\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"\u001b[39;49;00m\r\n    \u001b[33m    Verify Windows XP installation by checking file existence and hashes.\u001b[39;49;00m\r\n    \u001b[33m    Passes if 50% of expected files exist with correct MD5 hashes.\u001b[39;49;00m\r\n    \u001b[33m    \"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mimport\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[04m\u001b[96mhashlib\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mimport\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[04m\u001b[96mtempfile\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        expected_file_hashes = {\u001b[90m\u001b[39;49;00m\r\n            \u001b[33m\"\u001b[39;49;00m\u001b[33mWINDOWS/Debug/PASSWD.LOG\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m: \u001b[33m\"\u001b[39;49;00m\u001b[33md41d8cd98f00b204e9800998ecf8427e\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n            \u001b[33m\"\u001b[39;49;00m\u001b[33mWINDOWS/0.log\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m: \u001b[33m\"\u001b[39;49;00m\u001b[33md41d8cd98f00b204e9800998ecf8427e\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n"]
[29.06374, "o", "            \u001b[33m\"\u001b[39;49;00m\u001b[33mWINDOWS/system32/ntoskrnl.exe\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m: \u001b[33m\"\u001b[39;49;00m\u001b[33m0c89243c7c3ee199b96fcc16990e0679\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n            \u001b[33m\"\u001b[39;49;00m\u001b[33mWINDOWS/system32/kernel32.dll\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m: \u001b[33m\"\u001b[39;49;00m\u001b[33mc24b983d211c34da8fcc1ac38477971d\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n            \u001b[33m\"\u001b[39;49;00m\u001b[33mWINDOWS/system32/user32.dll\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m: \u001b[33m\"\u001b[39;49;00m\u001b[33mb26b135ff1b9f60c9388b4a7d16f600b\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n            \u001b[33m\"\u001b[39;49;00m\u001b[33mWINDOWS/system32/gdi32.dll\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m: \u001b[33m\"\u001b[39;49;00m\u001b[33mb015b9134dad7e29e7d2d6b5f5c8c2fc\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n            \u001b[33m\"\u001b[39;49;00m\u001b[33mWINDOWS/system32/shell32.dll\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m: \u001b[33m\"\u001b[39;49;00m\u001b[33m0cf50b1f45dab08430c1dbb79fe2ca5b\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n            \u001b[33m\"\u001b[39;49;00m\u001b[33mWINDOWS/system32/advapi32.dll\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m: \u001b[33m\"\u001b[39;49;00m\u001b[33mbab489a5fe26f2d0c910cf7af7e4cf92\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n            \u001b[33m\"\u001b[39;49;00m\u001b[33mWINDOWS/explorer.exe\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m: \u001b[33m\"\u001b[39;49;00m\u001b[33m12896823fb95bfb3dc9b46bcaedc9923\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n            \u001b[33m\"\u001b[39;49;00m\u001b[33mntldr\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m: \u001b[33m\"\u001b[39;49;00m\u001b[33mc1b29b4e6eea9510610db2ec4d6db160\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n            \u001b[33m\"\u001b[39;49;00m\u001b[33mNTDETECT.COM\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m: \u001b[33m\"\u001b[39;49;00m\u001b[33mb2de3452de03674c6cec68b8c8ce7c78\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n            \u001b[33m\"\u001b[39;49;00m\u001b[33mProgram Files/Outlook Express/msimn.exe\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m: \u001b[33m\"\u001b[39;49;00m\u001b[33m1eeae496a51f017d04dd41322935d2b9\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n        }\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Kill QEMU if running\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        qemu_result = subprocess.run(\u001b[90m\u001b[39;49;00m\r\n            [\u001b[33m\"\u001b[39;49;00m\u001b[33mpgrep\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33mqemu-system\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m], capture_output=\u001b[94mTrue\u001b[39;49;00m, text=\u001b[94mTrue\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        )\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mif\u001b[39;49;00m qemu_result.returncode == \u001b[94m0\u001b[39;49;00m:\u001b[90m\u001b[39;49;00m\r\n            subprocess.run([\u001b[33m\"\u001b[39;49;00m\u001b[33mkill\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33m-9\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, qemu_result.stdout.strip()], capture_output=\u001b[94mTrue\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        vhd_path = Path(\u001b[33m\"\u001b[39;49;00m\u001b[33m/app/isos/xp.img\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[94mwith\u001b[39;49;00m tempfile.TemporaryDirectory() \u001b[94mas\u001b[39;49;00m temp_dir:\u001b[90m\u001b[39;49;00m\r\n            extract_dir = temp_dir + \u001b[33m\"\u001b[39;49;00m\u001b[33m/xp_extract\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            os.makedirs(extract_dir)\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n            \u001b[90m# Extract VHD contents\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            subprocess.run(\u001b[90m\u001b[39;49;00m\r\n                [\u001b[33m\"\u001b[39;49;00m\u001b[33m7z\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33mx\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[96mstr\u001b[39;49;00m(vhd_path), \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m-o\u001b[39;49;00m\u001b[33m{\u001b[39;49;00mextract_dir\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33m-r\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m],\u001b[90m\u001b[39;49;00m\r\n                capture_output=\u001b[94mTrue\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n"]
[29.063924, "o", "                text=\u001b[94mTrue\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n            )\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n            \u001b[90m# Case-insensitive file finder\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            \u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mfind_file\u001b[39;49;00m(base_path, relative_path):\u001b[90m\u001b[39;49;00m\r\n                current_path = Path(base_path)\u001b[90m\u001b[39;49;00m\r\n                \u001b[94mfor\u001b[39;49;00m part \u001b[95min\u001b[39;49;00m relative_path.split(\u001b[33m\"\u001b[39;49;00m\u001b[33m/\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m):\u001b[90m\u001b[39;49;00m\r\n                    found = \u001b[94mFalse\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n                    \u001b[94mif\u001b[39;49;00m current_path.exists():\u001b[90m\u001b[39;49;00m\r\n                        \u001b[94mfor\u001b[39;49;00m child \u001b[95min\u001b[39;49;00m current_path.iterdir():\u001b[90m\u001b[39;49;00m\r\n                            \u001b[94mif\u001b[39;49;00m child.name.lower() == part.lower():\u001b[90m\u001b[39;49;00m\r\n                                current_path = child\u001b[90m\u001b[39;49;00m\r\n                                found = \u001b[94mTrue\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n                                \u001b[94mbreak\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n                    \u001b[94mif\u001b[39;49;00m \u001b[95mnot\u001b[39;49;00m found:\u001b[90m\u001b[39;49;00m\r\n                        \u001b[94mreturn\u001b[39;49;00m \u001b[94mNone\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n                \u001b[94mreturn\u001b[39;49;00m current_path \u001b[94mif\u001b[39;49;00m current_path.exists() \u001b[94melse\u001b[39;49;00m \u001b[94mNone\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n            \u001b[90m# Verify files and hashes\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            correct_files = \u001b[94m0\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            \u001b[94mfor\u001b[39;49;00m expected_file, expected_hash \u001b[95min\u001b[39;49;00m expected_file_hashes.items():\u001b[90m\u001b[39;49;00m\r\n                file_path = find_file(extract_dir, expected_file)\u001b[90m\u001b[39;49;00m\r\n                \u001b[94mif\u001b[39;49;00m file_path:\u001b[90m\u001b[39;49;00m\r\n                    \u001b[90m# Calculate MD5 hash\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n                    hasher = hashlib.md5()\u001b[90m\u001b[39;49;00m\r\n"]
[29.064026, "o", "                    \u001b[94mwith\u001b[39;49;00m \u001b[96mopen\u001b[39;49;00m(file_path, \u001b[33m\"\u001b[39;49;00m\u001b[33mrb\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m) \u001b[94mas\u001b[39;49;00m f:\u001b[90m\u001b[39;49;00m\r\n                        \u001b[94mfor\u001b[39;49;00m chunk \u001b[95min\u001b[39;49;00m \u001b[96miter\u001b[39;49;00m(\u001b[94mlambda\u001b[39;49;00m: f.read(\u001b[94m4096\u001b[39;49;00m), \u001b[33mb\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m):\u001b[90m\u001b[39;49;00m\r\n                            hasher.update(chunk)\u001b[90m\u001b[39;49;00m\r\n                    actual_hash = hasher.hexdigest()\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n                    \u001b[94mif\u001b[39;49;00m actual_hash == expected_hash:\u001b[90m\u001b[39;49;00m\r\n                        correct_files += \u001b[94m1\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n            \u001b[90m# Check if ≥50% of files are correct\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            success_rate = (correct_files / \u001b[96mlen\u001b[39;49;00m(expected_file_hashes)) * \u001b[94m100\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            success_rate_result = \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mOnly \u001b[39;49;00m\u001b[33m{\u001b[39;49;00msuccess_rate\u001b[33m:\u001b[39;49;00m\u001b[33m.1f\u001b[39;49;00m\u001b[33m}\u001b[39;49;00m\u001b[33m% of files correct (need ≥50%)\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n>           \u001b[94massert\u001b[39;49;00m success_rate >= \u001b[94m50.0\u001b[39;49;00m, success_rate_result\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31mE           AssertionError: Only 0.0% of files correct (need ≥50%)\u001b[0m\r\n\u001b[1m\u001b[31mE           assert 0.0 >= 50.0\u001b[0m\r\n"]
[29.06409, "o", "\r\n\u001b[1m\u001b[31m/tests/test_outputs.py\u001b[0m:299: AssertionError\r\n"]
