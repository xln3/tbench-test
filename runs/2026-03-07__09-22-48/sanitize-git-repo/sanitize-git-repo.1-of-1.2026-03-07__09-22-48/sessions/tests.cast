[15.417972, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_removal_of_secret_information\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mfor\u001b[39;49;00m contaminated_path \u001b[95min\u001b[39;49;00m CONTAMINATED_PATHS:\u001b[90m\u001b[39;49;00m\r\n            \u001b[94mwith\u001b[39;49;00m \u001b[96mopen\u001b[39;49;00m(contaminated_path, \u001b[33m\"\u001b[39;49;00m\u001b[33mr\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m) \u001b[94mas\u001b[39;49;00m file:\u001b[90m\u001b[39;49;00m\r\n                contaminated_text = file.read()\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n            \u001b[94massert\u001b[39;49;00m FAKE_AWS_ACCESS_KEY_ID.lower() \u001b[95mnot\u001b[39;49;00m \u001b[95min\u001b[39;49;00m contaminated_text.lower()\u001b[90m\u001b[39;49;00m\r\n            \u001b[94massert\u001b[39;49;00m FAKE_AWS_SECRET_ACCESS_KEY.lower() \u001b[95mnot\u001b[39;49;00m \u001b[95min\u001b[39;49;00m contaminated_text.lower()\u001b[90m\u001b[39;49;00m\r\n"]
