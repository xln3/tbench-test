[62.175962, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_proofs_compile_without_warnings\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"Test that all .lean files compile successfully without any warnings.\"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        lean_files = get_lean_files()\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[94mfor\u001b[39;49;00m filename \u001b[95min\u001b[39;49;00m lean_files:\u001b[90m\u001b[39;49;00m\r\n            compilation = get_compilation_result(filename)\u001b[90m\u001b[39;49;00m\r\n            full_output = compilation[\u001b[33m'\u001b[39;49;00m\u001b[33mfull_output\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m]\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n            \u001b[90m# Check for sorry warnings\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n"]
[62.176139, "o", "            sorry_patterns = [\u001b[90m\u001b[39;49;00m\r\n                \u001b[33m\"\u001b[39;49;00m\u001b[33mdeclaration uses \u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33msorry\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n                \u001b[33m\"\u001b[39;49;00m\u001b[33munsolved goals\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n                \u001b[33m\"\u001b[39;49;00m\u001b[33m`sorry` is not a tactic\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            ]\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n            \u001b[90m# Check for other warning patterns that should cause test failure\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            warning_patterns = [\u001b[90m\u001b[39;49;00m\r\n                \u001b[33m\"\u001b[39;49;00m\u001b[33mwarning: unused variable\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n                \u001b[33m\"\u001b[39;49;00m\u001b[33mwarning: this tactic is never executed\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n                \u001b[33m\"\u001b[39;49;00m\u001b[33mwarning: \u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33momega\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33m tactic does nothing\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n                \u001b[33m\"\u001b[39;49;00m\u001b[33mTry this:\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n                \u001b[33m\"\u001b[39;49;00m\u001b[33mwarning: Used `tac1 <;> tac2` where `(tac1; tac2)` would suffice\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n                \u001b[33m\"\u001b[39;49;00m\u001b[33mnotation is deprecated\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            ]\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n            \u001b[90m# Check for syntax/import errors\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            error_patterns = [\u001b[90m\u001b[39;49;00m\r\n                \u001b[33m\"\u001b[39;49;00m\u001b[33mparse error\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n                \u001b[33m\"\u001b[39;49;00m\u001b[33munknown identifier\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n                \u001b[33m\"\u001b[39;49;00m\u001b[33mfailed to resolve\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n                \u001b[33m\"\u001b[39;49;00m\u001b[33munknown module\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n"]
[62.176233, "o", "                \u001b[33m\"\u001b[39;49;00m\u001b[33mimport failed\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            ]\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n            has_sorry_warning = \u001b[96many\u001b[39;49;00m(pattern \u001b[95min\u001b[39;49;00m full_output \u001b[94mfor\u001b[39;49;00m pattern \u001b[95min\u001b[39;49;00m sorry_patterns)\u001b[90m\u001b[39;49;00m\r\n            has_warning = \u001b[96many\u001b[39;49;00m(pattern \u001b[95min\u001b[39;49;00m full_output \u001b[94mfor\u001b[39;49;00m pattern \u001b[95min\u001b[39;49;00m warning_patterns)\u001b[90m\u001b[39;49;00m\r\n            has_error = \u001b[96many\u001b[39;49;00m(pattern \u001b[95min\u001b[39;49;00m full_output \u001b[94mfor\u001b[39;49;00m pattern \u001b[95min\u001b[39;49;00m error_patterns)\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n            \u001b[94mif\u001b[39;49;00m has_error:\u001b[90m\u001b[39;49;00m\r\n                \u001b[94massert\u001b[39;49;00m \u001b[94mFalse\u001b[39;49;00m, \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mCompilation error in \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mfilename\u001b[33m}\u001b[39;49;00m\u001b[33m: \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mfull_output\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            \u001b[94melif\u001b[39;49;00m has_sorry_warning:\u001b[90m\u001b[39;49;00m\r\n                \u001b[94massert\u001b[39;49;00m \u001b[94mFalse\u001b[39;49;00m, (\u001b[90m\u001b[39;49;00m\r\n                    \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mProof in \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mfilename\u001b[33m}\u001b[39;49;00m\u001b[33m is incomplete (contains \u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33msorry\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m\u001b[33m): \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mfull_output\u001b[33m}\u001