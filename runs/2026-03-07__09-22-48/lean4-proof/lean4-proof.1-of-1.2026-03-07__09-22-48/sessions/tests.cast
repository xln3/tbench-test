[62.17627, "o", "                )\u001b[90m\u001b[39;49;00m\r\n            \u001b[94melif\u001b[39;49;00m has_warning:\u001b[90m\u001b[39;49;00m\r\n                \u001b[94massert\u001b[39;49;00m \u001b[94mFalse\u001b[39;49;00m, (\u001b[90m\u001b[39;49;00m\r\n                    \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mProof in \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mfilename\u001b[33m}\u001b[39;49;00m\u001b[33m contains warnings that must be fixed: \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n"]
[62.176304, "o", "                    \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m{\u001b[39;49;00mfull_output\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n                )\u001b[90m\u001b[39;49;00m\r\n            \u001b[94melif\u001b[39;49;00m compilation[\u001b[33m'\u001b[39;49;00m\u001b[33mreturncode\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m] != \u001b[94m0\u001b[39;49;00m:\u001b[90m\u001b[39;49;00m\r\n>               \u001b[94massert\u001b[39;49;00m \u001b[94mFalse\u001b[39;49;00m, \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mLean compilation failed for \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mfilename\u001b[33m}\u001b[39;49;00m\u001b[33m: \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mfull_output\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n"]
