[84.354808, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_vm_execution\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"Test that vm.js starts and displays the DOOM initialization text.\"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Create a temporary file to capture stdout\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mwith\u001b[39;49;00m tempfile.NamedTemporaryFile(mode=\u001b[33m\"\u001b[39;49;00m\u001b[33mw+\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, delete=\u001b[94mFalse\u001b[39;49;00m) \u001b[94mas\u001b[39;49;00m tmp_stdout:\u001b[90m\u001b[39;49;00m\r\n            \u001b[90m# Start vm.js in a subprocess\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n"]
[84.355013, "o", "            process = subprocess.Popen(\u001b[90m\u001b[39;49;00m\r\n                [\u001b[33m\"\u001b[39;49;00m\u001b[33mnode\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33m/app/vm.js\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m],\u001b[90m\u001b[39;49;00m\r\n                stdout=tmp_stdout,\u001b[90m\u001b[39;49;00m\r\n                stderr=subprocess.STDOUT,\u001b[90m\u001b[39;49;00m\r\n                text=\u001b[94mTrue\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n            )\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n            \u001b[90m# Wait for the frame.bmp file to be created\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n"]
[84.35515, "o", "            frame_path = Path(\u001b[33m\"\u001b[39;49;00m\u001b[33m/tmp/frame.bmp\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n            timeout = \u001b[94m30\u001b[39;49;00m  \u001b[90m# 30 seconds timeout\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            start_time = time.time()\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n            \u001b[94mwhile\u001b[39;49;00m \u001b[95mnot\u001b[39;49;00m frame_path.exists():\u001b[90m\u001b[39;49;00m\r\n                \u001b[94mif\u001b[39;49;00m time.time() - start_time > timeout:\u001b[90m\u001b[39;49;00m\r\n                    process.kill()\u001b[90m\u001b[39;49;00m\r\n>                   \u001b[94mraise\u001b[39;49;00m \u001b[96mTimeoutError\u001b[39;49;00m(\u001b[33m\"\u001b[39;49;00m\u001b[33mTimeout waiting for frame.bmp to be created\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31mE                   TimeoutError: Timeout waiting for frame.bmp to be created\u001b[0m\r\n"]
[84.355234, "o", "\r\n\u001b[1m\u001b[31m/tests/test_outputs.py\u001b[0m:32: TimeoutError\r\n"]
[84.35534, "o", "\u001b[31m\u001b[1m____________________________________________________________________ test_frame_bmp_exists _____________________________________________________________________\u001b[0m\r\n\r\n"]
[84.35642, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_frame_bmp_exists\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"Test that frame.bmp file was created.\"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        frame_path = Path(\u001b[33m\"\u001b[39;49;00m\u001b[33m/tmp/frame.bmp\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n"]
[84.356455, "o", ">       \u001b[94massert\u001b[39;49;00m frame_path.exists(), \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mFile \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mframe_path\u001b[33m}\u001b[39;49;00m\u001b[33m does not exist\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31mE       AssertionError: File /tmp/frame.bmp does not exist\u001b[0m\r\n"]
[84.356616, "o", "\u001b[1m\u001b[31mE       assert False\u001b[0m\r\n"]
[84.356719, "o", "\u001b[1m\u001b[31mE        +  where False = exists()\u001b[0m\r\n\u001b[1m\u001b[31mE        +    where exists = PosixPath('/tmp/frame.bmp').exists\u001b[0m\r\n\r\n\u001b[1m\u001b[31m/tests/test_outputs.py\u001b[0m:64: AssertionError\r\n\u001b[31m\u001b[1m_____________________________________________________________ test_frame_bmp_similar_to_reference ______________________________________________________________\u001b[0m\r\n\r\n"]
[84.359042, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_frame_bmp_similar_to_reference\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"Test that frame.bmp is similar to the reference.jpg file using L2 similarity.\"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n"]
[84.35913, "o", "        frame_path = Path(\u001b[33m\"\u001b[39;49;00m\u001b[33m/tmp/frame.bmp\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n        reference_path = Path(\u001b[33m\"\u001b[39;49;00m\u001b[33m/tests/reference.jpg\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n"]
[84.359182, "o", "        \u001b[94massert\u001b[39;49;00m reference_path.exists(), \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mReference file \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mreference_path\u001b[33m}\u001b[39;49;00m\u001b[33m does not exist\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Load images\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n>       frame_img = Image.open(frame_path).convert(\u001b[33m\"\u001b[39;49;00m\u001b[33mRGB\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n                    ^^^^^^^^^^^^^^^^^^^^^^\u001b[90m\u001b[39;49;00m\r\n"]
[84.359239, "o", "\r\n\u001b[1m\u001b[31m/tests/test_outputs.py\u001b[0m:76: \r\n"]
[84.359292, "o", "_ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ \r\n"]
[84.359342, "o", "\r\n"]
[84.359389, "o", "fp = PosixPath('/tmp/frame.bmp'), mode = 'r', formats = []\r\n\r\n"]
[84.366565, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mopen\u001b[39;49;00m(\u001b[90m\u001b[39;49;00m\r\n        fp: StrOrBytesPath | IO[\u001b[96mbytes\u001b[39;49;00m],\u001b[90m\u001b[39;49;00m\r\n        mode: Literal[\u001b[33m\"\u001b[39;49;00m\u001b[33mr\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m] = \u001b[33m\"\u001b[39;49;00m\u001b[33mr\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n"]
[84.366594, "o", "        formats: \u001b[96mlist\u001b[39;49;00m[\u001b[96mstr\u001b[39;49;00m] | \u001b[96mtuple\u001b[39;49;00m[\u001b[96mstr\u001b[39;49;00m, ...] | \u001b[94mNone\u001b[39;49;00m = \u001b[94mNone\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n    ) -> ImageFile.ImageFile:\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"\u001b[39;49;00m\r\n"]
[84.366629, "o", "    \u001b[33m    Opens and identifies the given image file.\u001b[39;49;00m\r\n    \u001b[33m\u001b[39;49;00m\r\n"]
[84.366804, "o", "    \u001b[33m    This is a lazy operation; this function identifies the file, but\u001b[39;49;00m\r\n    \u001b[33m    the file remains open and the actual image data is not read from\u001b[39;49;00m\r\n    \u001b[33m    the file until you try to process the data (or call the\u001b[39;49;00m\r\n    \u001b[33m    :py:meth:`~PIL.Image.Image.load` method).  See\u001b[39;49;00m\r\n    \u001b[33m    :py:func:`~PIL.Image.new`. See :ref:`file-handling`.\u001b[39;49;00m\r\n    \u001b[33m\u001b[39;49;00m\r\n    \u001b[33m    :param fp: A filename (string), os.PathLike object or a file object.\u001b[39;49;00m\r\n    \u001b[33m       The file object must implement ``file.read``,\u001b[39;49;00m\r\n    \u001b[33m       ``file.seek``, and ``file.tell`` methods,\u001b[39;49;00m\r\n    \u001b[33m       and be opened in binary mode. The file object will also seek to zero\u001b[39;49;00m\r\n    \u001b[33m       before reading.\u001b[39;49;00m\r\n    \u001b[33m    :param mode: The mode.  If given, this argument must be \"r\".\u001b[39;49;00m\r\n    \u001b[33m    :param formats: A list or tuple of formats to attempt to load the file in.\u001b[39;49;00m\r\n    \u001b[33m       This can b"]
[84.366895, "o", "e used to restrict the set of formats checked.\u001b[39;49;00m\r\n    \u001b[33m       Pass ``None`` to try all supported formats. You can print the set of\u001b[39;49;00m\r\n    \u001b[33m       available formats by running ``python3 -m PIL`` or using\u001b[39;49;00m\r\n"]
[84.366966, "o", "    \u001b[33m       the :py:func:`PIL.features.pilinfo` function.\u001b[39;49;00m\r\n    \u001b[33m    :returns: An :py:class:`~PIL.Image.Image` object.\u001b[39;49;00m\r\n    \u001b[33m    :exception FileNotFoundError: If the file cannot be found.\u001b[39;49;00m\r\n    \u001b[33m    :exception PIL.UnidentifiedImageError: If the image cannot be opened and\u001b[39;49;00m\r\n    \u001b[33m       identified.\u001b[39;49;00m\r\n    \u001b[33m    :exception ValueError: If the ``mode`` is not \"r\", or if a ``StringIO``\u001b[39;49;00m\r\n    \u001b[33m       instance is used for ``fp``.\u001b[39;49;00m\r\n    \u001b[33m    :exception TypeError: If ``formats`` is not ``None``, a list or a tuple.\u001b[39;49;00m\r\n"]
[84.36702, "o", "    \u001b[33m    \"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[94mif\u001b[39;49;00m mode != \u001b[33m\"\u001b[39;49;00m\u001b[33mr\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m:\u001b[90m\u001b[39;49;00m\r\n            msg = \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mbad mode \u001b[39;49;00m\u001b[33m{\u001b[39;49;00m\u001b[96mrepr\u001b[39;49;00m(mode)\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m  \u001b[90m# type: ignore[unreachable]\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            \u001b[94mraise\u001b[39;49;00m \u001b[96mValueError\u001b[39;49;00m(msg)\u001b[90m\u001b[39;49;00m\r\n        \u001b[94melif\u001b[39;49;00m \u001b[96misinstance\u001b[39;49;00m(fp, io.StringIO):\u001b[90m\u001b[39;49;00m\r\n"]
[84.367093, "o", "            msg = (  \u001b[90m# type: ignore[unreachable]\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n                \u001b[33m\"\u001b[39;49;00m\u001b[33mStringIO cannot be used to open an image. \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n                \u001b[33m\"\u001b[39;49;00m\u001b[33mBinary data must be used instead.\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            )\u001b[90m\u001b[39;49;00m\r\n"]
[84.367162, "o", "            \u001b[94mraise\u001b[39;49;00m \u001b[96mValueError\u001b[39;49;00m(msg)\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[94mif\u001b[39;49;00m formats \u001b[95mis\u001b[39;49;00m \u001b[94mNone\u001b[39;49;00m:\u001b[90m\u001b[39;49;00m\r\n            formats = ID\u001b[90m\u001b[39;49;00m\r\n        \u001b[94melif\u001b[39;49;00m \u001b[95mnot\u001b[39;49;00m \u001b[96misinstance\u001b[39;49;00m(formats, (\u001b[96mlist\u001b[39;49;00m, \u001b[96mtuple\u001b[39;49;00m)):\u001b[90m\u001b[39;49;00m\r\n            msg = \u001b[33m\"\u001b[39;49;00m\u001b[33mformats must be a list or tuple\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m  \u001b[90m# type: ignore[unreachable]\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            \u001b[94mraise\u001b[39;49;00m \u001b[96mTypeError\u001b[39;49;00m(msg)\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n"]
[84.367226, "o", "        exclusive_fp = \u001b[94mFalse\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        filename: \u001b[96mstr\u001b[39;49;00m | \u001b[96mbytes\u001b[39;49;00m = \u001b[33m\"\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mif\u001b[39;49;00m is_path(fp):\u001b[90m\u001b[39;49;00m\r\n            filename = os.fspath(fp)\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n"]
[84.367294, "o", "        \u001b[94mif\u001b[39;49;00m filename:\u001b[90m\u001b[39;49;00m\r\n>           fp = builtins.open(filename, \u001b[33m\"\u001b[39;49;00m\u001b[33mrb\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n                 ^^^^^^^^^^^^^^^^^^^^^^^^^^^^^\u001b[90m\u001b[39;49;00m\r\n"]
[84.367371, "o", "\u001b[1m\u001b[31mE           FileNotFoundError: [Errno 2] No such file or directory: '/tmp/frame.bmp'\u001b[0m\r\n\r\n\u001b[1m\u001b[31m.tbench-testing/lib/python3.13/site-packages/PIL/Image.py\u001b[0m:3505: FileNotFoundError\r\n"]
