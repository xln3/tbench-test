[141.048612, "o", "\r\n=========================================================================== FAILURES ===========================================================================\r\n\u001b[31m\u001b[1m____________________________________________________________ test_performance_and_scalability[8000] ____________________________________________________________\u001b[0m\r\n\r\n"]
[141.048702, "o", "n = 8000\r\n\r\n"]
[141.090468, "o", "    \u001b[0m\u001b[37m@pytest\u001b[39;49;00m.mark.parametrize(\u001b[33m\"\u001b[39;49;00m\u001b[33mn\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, [\u001b[94m5000\u001b[39;49;00m, \u001b[94m6000\u001b[39;49;00m, \u001b[94m8000\u001b[39;49;00m])\u001b[90m\u001b[39;49;00m\r\n    \u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_performance_and_scalability\u001b[39;49;00m(n):\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"Test performance and scalability requirements for large portfolios\"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        sys.path.append(\u001b[33m'\u001b[39;49;00m\u001b[33m/app\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mfrom\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[04m\u001b[96mportfolio_optimized\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[94mimport\u001b[39;49;00m portfolio_return_c, portfolio_risk_c\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        weights, cov, returns = generate_test_data(n)\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Test correctness first using protected baseline\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n"]
[141.090622, "o", "        risk_python = portfolio_risk_python(weights, cov)\u001b[90m\u001b[39;49;00m\r\n        return_python = portfolio_return_python(weights, returns)\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        risk_c = portfolio_risk_c(weights, cov)\u001b[90m\u001b[39;49;00m\r\n        return_c = portfolio_return_c(weights, returns)\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[94massert\u001b[39;49;00m \u001b[96mabs\u001b[39;49;00m(risk_python - risk_c) < \u001b[94m1e-10\u001b[39;49;00m, \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mRisk mismatch at N=\u001b[39;49;00m\u001b[33m{\u001b[39;49;00mn\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[94massert\u001b[39;49;00m \u001b[96mabs\u001b[39;49;00m(return_python - return_c) < \u001b[94m1e-10\u001b[39;49;00m, \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mReturn mismatch at N=\u001b[39;49;00m\u001b[33m{\u001b[39;49;00mn\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Test performance against protected baseline\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        python_time, _ = time_function(portfolio_risk_python, weights, cov)\u001b[90m\u001b[39;49;00m\r\n  "]
[141.090732, "o", "      c_time, _ = time_function(portfolio_risk_c, weights, cov)\u001b[90m\u001b[39;49;00m\r\n        speedup = python_time / c_time\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        required_speedup = \u001b[94m1.2\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n>       \u001b[94massert\u001b[39;49;00m speedup >= required_speedup, (\u001b[90m\u001b[39;49;00m\r\n            \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mPerformance requirement not met: \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mspeedup\u001b[33m:\u001b[39;49;00m\u001b[33m.2f\u001b[39;49;00m\u001b[33m}\u001b[39;49;00m\u001b[33mx < \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mrequired_speedup\u001b[33m}\u001b[39;49;00m\u001b[33mx \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mfor N=\u001b[39;49;00m\u001b[33m{\u001b[39;49;00mn\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        )\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31mE       AssertionError: Performance requirement not met: 1.20x < 1.2x for N=8000\u001b[0m\r\n\u001b[1m\u001b[31mE       assert 1.1970144919647243 >= 1.2\u001b[0m\r\n"]
