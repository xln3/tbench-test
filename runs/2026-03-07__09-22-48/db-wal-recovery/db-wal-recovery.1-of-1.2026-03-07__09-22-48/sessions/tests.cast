[45.480069, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_recovered_json_exists\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"Test that the recovered.json file exists.\"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n>       \u001b[94massert\u001b[39;49;00m os.path.exists(\u001b[33m\"\u001b[39;49;00m\u001b[33m/app/recovered.json\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m), \u001b[33m\"\u001b[39;49;00m\u001b[33mrecovered.json file does not exist\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31mE       AssertionError: recovered.json file does not exist\u001b[0m\r\n\u001b[1m\u001b[31mE       assert False\u001b[0m\r\n\u001b[1m\u001b[31mE        +  where False = <function exists at 0x7f170c213600>('/app/recovered.json')\u001b[0m\r\n\u001b[1m\u001b[31mE        +    where <function exists at 0x7f170c213600> = <module 'posixpath' (frozen)>.exists\u001b[0m\r\n\u001b[1m\u001b[31mE        +      where <module 'posixpath' (frozen)> = os.path\u001b[0m\r\n"]
