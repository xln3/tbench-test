[4.503096, "o", "\u001b[?2004h> "]
[4.503237, "o", "The JSON report MUST be structured with the following fields:\r\n\u001b[?2004l\r\u001b[?2004h"]
[4.503381, "o", "> "]
[4.503461, "o", "- `pdf_file`: The name of the PDF file that was analyzed\r\n\u001b[?2004l\r\u001b[?2004h> "]
[4.503553, "o", "- `mapped_fields`: A dictionary where:\r\n\u001b[?2004l\r"]
[4.503617, "o", "\u001b[?2004h> "]
[4.50369, "o", "    - Keys are field IDs from the PDF form\r\n\u001b[?2004l\r"]
[4.503766, "o", "\u001b[?2004h> "]
[4.503829, "o", "    - Values are objects containing:\r\n\u001b[?2004l\r\u001b[?2004h> "]
[4.503949, "o", "        - `field_name`: Name of the field\r\n\u001b[?2004l\r\u001b[?2004h> "]
[4.504097, "o", "        - `value`: Extracted value for the field\r\n\u001b[?2004l\r\u001b[?2004h> "]
[4.504395, "o", "        - `source`: Source document name (one of \"sample_personal_info\", \"sample_resume\", or \"sample_application\")\r\n\u001b[?2004l\r"]
[4.504471, "o", "\u001b[?2004h> "]
[4.504641, "o", "- `unmapped_fields`: A list of field IDs that could not be mapped\r\n\u001b[?2004l\r\u001b[?2004h> "]
[4.504795, "o", "- `total_mapped`: Number of successfully mapped fields (integer)\r\n\u001b[?2004l\r"]
[4.50485, "o", "\u001b[?2004h> "]
[4.504996, "o", "- `total_unmapped`: Number of unmapped fields (integer)\r\n\u001b[?2004l\r\u001b[?2004h"]
[4.505069, "o", "> "]
[4.505203, "o", "- `rag_stats`: An object containing statistics about the RAG process\r\n\u001b[?2004l\r"]
[4.505266, "o", "\u001b[?2004h> \r\n\u001b[?2004l\r\u001b[?2004h> "]
