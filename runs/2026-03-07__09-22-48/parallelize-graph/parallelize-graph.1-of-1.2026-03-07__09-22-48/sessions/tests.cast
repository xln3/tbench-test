[27.524037, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_parallel_executable_exists\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"Check that the parallel UPC executable was compiled successfully.\"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        pgen_path = Path(\u001b[33m\"\u001b[39;49;00m\u001b[33m/app/pgen\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n>       \u001b[94massert\u001b[39;49;00m pgen_path.exists(), \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mParallel executable \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mpgen_path\u001b[33m}\u001b[39;49;00m\u001b[33m does not exist\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31mE       AssertionError: Parallel executable /app/pgen does not exist\u001b[0m\r\n\u001b[1m\u001b[31mE       assert False\u001b[0m\r\n\u001b[1m\u001b[31mE        +  where False = exists()\u001b[0m\r\n\u001b[1m\u001b[31mE        +    where exists = PosixPath('/app/pgen').exists\u001b[0m\r\n\r\n\u001b[1m\u001b[31m/tests/test_outputs.py\u001b[0m:23: AssertionError\r\n"]
[27.524249, "o", "\u001b[31m\u001b[1m_________________________________________________________________ test_parallel_output_exists __________________________________________________________________\u001b[0m\r\n\r\n"]
[27.524937, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_parallel_output_exists\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"Check that parallel version produced output files starting with pgen.\u001b[39;49;00m\r\n    \u001b[33m\u001b[39;49;00m\r\n    \u001b[33m    Output files should end with .out (e.g., pgen_0.out, pgen_1.out).\u001b[39;49;00m\r\n    \u001b[33m    \"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n"]
[27.524997, "o", "        \u001b[90m# Check for individual pgen_*.out files\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        pgen_files = \u001b[96mlist\u001b[39;49;00m(Path(\u001b[33m\"\u001b[39;49;00m\u001b[33m/app\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m).glob(\u001b[33m\"\u001b[39;49;00m\u001b[33mpgen*.out\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m))\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n>       \u001b[94massert\u001b[39;49;00m \u001b[96mlen\u001b[39;49;00m(pgen_files) > \u001b[94m0\u001b[39;49;00m, (\u001b[90m\u001b[39;49;00m\r\n            \u001b[33m\"\u001b[39;49;00m\u001b[33mNo parallel output files found matching pattern pgen*.out\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        )\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31mE       AssertionError: No parallel output files found matching pattern pgen*.out\u001b[0m\r\n"]
