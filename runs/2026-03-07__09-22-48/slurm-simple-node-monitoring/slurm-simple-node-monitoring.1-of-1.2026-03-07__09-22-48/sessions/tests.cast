[15.652387, "o", "    \u001b[33m    Test that the output log file has the correct format.\u001b[39;49;00m\r\n    \u001b[33m    Example of output:\u001b[39;49;00m\r\n"]
[15.652438, "o", "    \u001b[33m    timestamp,total,idle,fraction\u001b[39;49;00m\r\n    \u001b[33m    2025-05-31 02:29:36,32,26,0.8125\u001b[39;49;00m\r\n    \u001b[33m    \"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        total_nodes = get_total_nodes()\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mglobal\u001b[39;49;00m TOTAL_NODES\u001b[90m\u001b[39;49;00m\r\n        TOTAL_NODES = total_nodes\u001b[90m\u001b[39;49;00m\r\n        out_log_path = Path(\u001b[33m\"\u001b[39;49;00m\u001b[33m/app/protocol_idle.log\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n>       \u001b[94mwith\u001b[39;49;00m \u001b[96mopen\u001b[39;49;00m(out_log_path, \u001b[33m\"\u001b[39;49;00m\u001b[33mr\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m) \u001b[94mas\u001b[39;49;00m f:\u001b[90m\u001b[39;49;00m\r\n             ^^^^^^^^^^^^^^^^^^^^^^^\u001b[90m\u001b[39;49;00m\r\n"]
