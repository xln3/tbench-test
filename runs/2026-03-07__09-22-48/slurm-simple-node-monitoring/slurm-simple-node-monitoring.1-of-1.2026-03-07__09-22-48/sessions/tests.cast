[15.653775, "o", "    \u001b[33m    Test that the output log file has the correct fraction of idle nodes.\u001b[39;49;00m\r\n    \u001b[33m    dummy log file format:\u001b[39;49;00m\r\n    \u001b[33m    Current time: <timestamp>, Idle nodes: <num_current_idle_nodes>\u001b[39;49;00m\r\n    \u001b[33m    \"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        out_log_path = Path(\u001b[33m\"\u001b[39;49;00m\u001b[33m/app/protocol_idle.log\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n        dummy_log_path = Path(\u001b[33m\"\u001b[39;49;00m\u001b[33m/logs/submit_dummy_jobs.log\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n>       \u001b[94mwith\u001b[39;49;00m \u001b[96mopen\u001b[39;49;00m(out_log_path, \u001b[33m\"\u001b[39;49;00m\u001b[33mr\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m) \u001b[94mas\u001b[39;49;00m f:\u001b[90m\u001b[39;49;00m\r\n"]
[15.653822, "o", "             ^^^^^^^^^^^^^^^^^^^^^^^\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31mE       FileNotFoundError: [Errno 2] No such file or directory: '/app/protocol_idle.log'\u001b[0m\r\n\r\n"]
