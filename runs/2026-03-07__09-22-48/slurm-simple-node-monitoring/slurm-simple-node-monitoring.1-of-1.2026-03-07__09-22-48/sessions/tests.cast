[15.646395, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_out_log_exists\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"\u001b[39;49;00m\r\n    \u001b[33m    Test that the output log file exists.\u001b[39;49;00m\r\n    \u001b[33m    \"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        out_log_path = Path(\u001b[33m\"\u001b[39;49;00m\u001b[33m/app/protocol_idle.log\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n>       \u001b[94massert\u001b[39;49;00m out_log_path.exists(), \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mOutput log file \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mout_log_path\u001b[33m}\u001b[39;49;00m\u001b[33m does not exist.\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n"]
[15.646677, "o", "\u001b[1m\u001b[31mE       AssertionError: Output log file /app/protocol_idle.log does not exist.\u001b[0m\r\n\u001b[1m\u001b[31mE       assert False\u001b[0m\r\n\u001b[1m\u001b[31mE        +  where False = exists()\u001b[0m\r\n\u001b[1m\u001b[31mE        +    where exists = PosixPath('/app/protocol_idle.log').exists\u001b[0m\r\n\r\n\u001b[1m\u001b[31m/tests/test_outputs.py\u001b[0m:32: AssertionError\r\n\u001b[31m\u001b[1m____________________________________________________________________ test_out_log_not_empty ____________________________________________________________________\u001b[0m\r\n\r\n"]
[15.6478, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_out_log_not_empty\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"\u001b[39;49;00m\r\n    \u001b[33m    Test that the output log file is not empty.\u001b[39;49;00m\r\n    \u001b[33m    \"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        out_log_path = Path(\u001b[33m\"\u001b[39;49;00m\u001b[33m/app/protocol_idle.log\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n>       \u001b[94massert\u001b[39;49;00m out_log_path.stat().st_size > \u001b[94m0\u001b[39;49;00m, \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mOutput log file \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mout_log_path\u001b[33m}\u001b[39;49;00m\u001b[33m is empty.\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n               ^^^^^^^^^^^^^^^^^^^\u001b[90m\u001b[39;49;00m\r\n"]
