[12.882288, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_server_file_creation\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"\u001b[39;49;00m\r\n    \u001b[33m    Test that the server.py file was created by the agent.\u001b[39;49;00m\r\n    \u001b[33m    This verifies the agent implemented the gRPC server as required.\u001b[39;49;00m\r\n    \u001b[33m    \"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n"]
[12.882362, "o", "        server_py_path = Path(\u001b[33m\"\u001b[39;49;00m\u001b[33m/app/server.py\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n        \u001b[94massert\u001b[39;49;00m server_py_path.exists(), \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mServer file \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mserver_py_path\u001b[33m}\u001b[39;49;00m\u001b[33m was not created\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[90m# Verify the server file contains the expected implementation\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mwith\u001b[39;49;00m \u001b[96mopen\u001b[39;49;00m(server_py_path, \u001b[33m\"\u001b[39;49;00m\u001b[33mr\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m) \u001b[94mas\u001b[39;49;00m f:\u001b[90m\u001b[39;49;00m\r\n            content = f.read()\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n"]
[12.882376, "o", "        \u001b[90m# Check for required server components\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n"]
[12.882386, "o", ">       \u001b[94massert\u001b[39;49;00m \u001b[33m\"\u001b[39;49;00m\u001b[33mclass Server\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m \u001b[95min\u001b[39;49;00m content, \u001b[33m\"\u001b[39;49;00m\u001b[33mServer file must define Server class\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n"]
