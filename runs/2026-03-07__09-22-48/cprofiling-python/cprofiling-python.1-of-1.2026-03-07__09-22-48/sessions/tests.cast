[20.156801, "o", "\u001b[31m\u001b[1m____________________________________________________________________ test_speed_comparison _____________________________________________________________________\u001b[0m\r\n\r\n"]
[20.204432, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_speed_comparison\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"\u001b[39;49;00m\r\n    \u001b[33m    Test that the fastest.py script is at least 2x faster than fast.py but not more\u001b[39;49;00m\r\n    \u001b[33m    than 10x faster.\u001b[39;49;00m\r\n    \u001b[33m\u001b[39;49;00m\r\n    \u001b[33m    This test loads profiling data from fast.prof and fastest.prof files and compares\u001b[39;49;00m\r\n    \u001b[33m    their total execution times to ensure the performance optimization is within the\u001b[39;49;00m\r\n    \u001b[33m    expected range.\u001b[39;49;00m\r\n"]
[20.204609, "o", "    \u001b[33m    \"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n>       \u001b[94mwith\u001b[39;49;00m \u001b[96mopen\u001b[39;49;00m(\u001b[33m\"\u001b[39;49;00m\u001b[33m/app/python.txt\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33mr\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m) \u001b[94mas\u001b[39;49;00m f:\u001b[90m\u001b[39;49;00m\r\n             ^^^^^^^^^^^^^^^^^^^^^^^^^^^^\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31mE       FileNotFoundError: [Errno 2] No such file or directory: '/app/python.txt'\u001b[0m\r\n\r\n\u001b[1m\u001b[31m/tests/test_outputs.py\u001b[0m:22: FileNotFoundError\r\n"]
[20.204654, "o", "\u001b[31m\u001b[1m_____________________________________________________________________ test_image_download ______________________________________________________________________\u001b[0m\r\n\r\n"]
[20.208511, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_image_download\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"\u001b[39;49;00m\r\n    \u001b[33m    Test that the downloaded images are correct by computing their hashes.\u001b[39;49;00m\r\n    \u001b[33m\u001b[39;49;00m\r\n"]
[20.208633, "o", "    \u001b[33m    This test processes all image files in both downloaded_images_fast and\u001b[39;49;00m\r\n    \u001b[33m    downloaded_images_fastest directories, computes average hashes\u001b[39;49;00m\r\n    \u001b[33m    for each image, and verifies that the combined hash matches the expected value.\u001b[39;49;00m\r\n    \u001b[33m    This ensures that both fast.py and fastest.py downloaded the correct images.\u001b[39;49;00m\r\n    \u001b[33m    \"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        image_dirs = [\u001b[90m\u001b[39;49;00m\r\n            Path(\u001b[33m\"\u001b[39;49;00m\u001b[33m/app/downloaded_images_fast\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m),\u001b[90m\u001b[39;49;00m\r\n            Path(\u001b[33m\"\u001b[39;49;00m\u001b[33m/app/downloaded_images_fastest\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m),\u001b[90m\u001b[39;49;00m\r\n        ]\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[94mfor\u001b[39;49;00m image_dir \u001b[95min\u001b[39;49;00m image_dirs:\u001b[90m\u001b[39;49;00m\r\n            hash_values = []\u001b[90m\u001b[39;49;00m\r\n            \u001b[94mfor\u001b[39;49;00m file \u001b[95min\u001b[39;49;00m \u001b[96msorted\u001b[39;49;00m(image_dir.glob(\u001b[33m\"\u001b[39;49;00m\u001b[33m*\u001b[39;49;00m\u001b[33m\"\u001b["]
[20.208669, "o", "39;49;00m)):\u001b[90m\u001b[39;49;00m\r\n                \u001b[94mif\u001b[39;49;00m file.suffix.lower() \u001b[95min\u001b[39;49;00m [\u001b[90m\u001b[39;49;00m\r\n                    \u001b[33m\"\u001b[39;49;00m\u001b[33m.bmp\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n                    \u001b[33m\"\u001b[39;49;00m\u001b[33m.gif\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n                    \u001b[33m\"\u001b[39;49;00m\u001b[33m.jpg\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n                    \u001b[33m\"\u001b[39;49;00m\u001b[33m.jpeg\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n                    \u001b[33m\"\u001b[39;49;00m\u001b[33m.png\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n                    \u001b[33m\"\u001b[39;49;00m\u001b[33m.webp\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n"]
[20.208684, "o", "                ]:\u001b[90m\u001b[39;49;00m\r\n                    \u001b[94mtry\u001b[39;49;00m:\u001b[90m\u001b[39;49;00m\r\n"]
[20.20884, "o", "                        img = Image.open(file)\u001b[90m\u001b[39;49;00m\r\n                        hash_value = imagehash.average_hash(img)\u001b[90m\u001b[39;49;00m\r\n                        hash_values.append(hash_value)\u001b[90m\u001b[39;49;00m\r\n"]
[20.209038, "o", "                        \u001b[96mprint\u001b[39;49;00m(\u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m{\u001b[39;49;00mhash_value\u001b[33m}\u001b[39;49;00m\u001b[33m  \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mfile.name\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n                    \u001b[94mexcept\u001b[39;49;00m \u001b[96mException\u001b[39;49;00m \u001b[94mas\u001b[39;49;00m e:\u001b[90m\u001b[39;49;00m\r\n                        \u001b[96mprint\u001b[39;49;00m(\u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mError with \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mfile.name\u001b[33m}\u001b[39;49;00m\u001b[33m: \u001b[39;49;00m\u001b[33m{\u001b[39;49;00me\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, file=sys.stderr)\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n            \u001b[90m# Calculate a combined hash of all image hashes\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            combined_hash = \u001b[96mint\u001b[39;49;00m(\u001b[90m\u001b[39;49;00m\r\n                hashlib.sha1(\u001b[96mstr\u001b[39;49;00m(\u001b[96mtuple\u001b[39;49;00m(\u001b[96mstr\u001b[39;49;00m(h) \u001b[94mfor\u001b[39;49;00m h \u001b[95min\u001b[39;49;00m hash_values)).encode()).hexdigest()[\u001b[90m\u001b[39;49;00m\r\n                    :\u001b[94m16\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            "]
[20.209183, "o", "    ],\u001b[90m\u001b[39;49;00m\r\n                \u001b[94m16\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n            )\u001b[90m\u001b[39;49;00m\r\n>           \u001b[94massert\u001b[39;49;00m combined_hash == \u001b[94m536601250958665318\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n\u001b[1m\u001b[31mE           assert 17944134937117937889 == 536601250958665318\u001b[0m\r\n\r\n\u001b[1m\u001b[31m/tests/test_outputs.py\u001b[0m:83: AssertionError\r\n"]
