[50.679742, "o", "            \u001b[94mraise\u001b[39;49;00m \u001b[96mAttributeError\u001b[39;49;00m(\u001b[33m\"\u001b[39;49;00m\u001b[33m`numpy.array_api` is not available from \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n                                 \u001b[33m\"\u001b[39;49;00m\u001b[33mnumpy 2.0 onwards\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, name=\u001b[94mNone\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n        \u001b[94melif\u001b[39;49;00m attr == \u001b[33m\"\u001b[39;49;00m\u001b[33mcore\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m:\u001b[90m\u001b[39;49;00m\r\n            \u001b[94mimport\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[04m\u001b[96mnumpy\u001b[39;49;00m\u001b[04m\u001b[96m.\u001b[39;49;00m\u001b[04m\u001b[96mcore\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[94mas\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[04m\u001b[96mcore\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            \u001b[94mreturn\u001b[39;49;00m core\u001b[90m\u001b[39;49;00m\r\n        \u001b[94melif\u001b[39;49;00m attr == \u001b[33m\"\u001b[39;49;00m\u001b[33mstrings\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m:\u001b[90m\u001b[39;49;00m\r\n"]
[50.679789, "o", "            \u001b[94mimport\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[04m\u001b[96mnumpy\u001b[39;49;00m\u001b[04m\u001b[96m.\u001b[39;49;00m\u001b[04m\u001b[96mstrings\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[94mas\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[04m\u001b[96mstrings\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            \u001b[94mreturn\u001b[39;49;00m strings\u001b[90m\u001b[39;49;00m\r\n        \u001b[94melif\u001b[39;49;00m attr == \u001b[33m\"\u001b[39;49;00m\u001b[33mdistutils\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m:\u001b[90m\u001b[39;49;00m\r\n            \u001b[94mif\u001b[39;49;00m \u001b[33m'\u001b[39;49;00m\u001b[33mdistutils\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m \u001b[95min\u001b[39;49;00m __numpy_submodules__:\u001b[90m\u001b[39;49;00m\r\n                \u001b[94mimport\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[04m\u001b[96mnumpy\u001b[39;49;00m\u001b[04m\u001b[96m.\u001b[39;49;00m\u001b[04m\u001b[96mdistutils\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[94mas\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[04m\u001b[96mdistutils\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n                \u001b[94mreturn\u001b[39;49;00m distutils\u001b[90m\u001b[39;49;00m\r\n            \u001b[94melse\u001b[39;49;00m:\u001b[90m\u001b[39;49;00m\r\n                \u001b[94mraise\u001b[39;49;00m \u001b[96mAttributeError\u001b[39;49;00m(\u001b[33m\"\u001b[39;49;00m\u001b[33m`numpy.distutils` is not available"]
[50.679834, "o", " from \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n                                     \u001b[33m\"\u001b[39;49;00m\u001b[33mPython 3.12 onwards\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, name=\u001b[94mNone\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[94mif\u001b[39;49;00m attr \u001b[95min\u001b[39;49;00m __future_scalars__:\u001b[90m\u001b[39;49;00m\r\n            \u001b[90m# And future warnings for those that will change, but also give\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            \u001b[90m# the AttributeError\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            warnings.warn(\u001b[90m\u001b[39;49;00m\r\n                \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mIn the future `np.\u001b[39;49;00m\u001b[33m{\u001b[39;49;00mattr\u001b[33m}\u001b[39;49;00m\u001b[33m` will be defined as the \u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n                \u001b[33m\"\u001b[39;49;00m\u001b[33mcorresponding NumPy scalar.\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[96mFutureWarning\u001b[39;49;00m, stacklevel=\u001b[94m2\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[94mif\u001b[39;49;00m attr \u001b[95min\u001b[39;49;00m __former_attrs__:\u001b[90m\u001b[39;49;00m\r\n"]
[50.679871, "o", ">           \u001b[94mraise\u001b[39;49;00m \u001b[96mAttributeError\u001b[39;49;00m(__former_attrs__[attr], name=\u001b[94mNone\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n"]
[50.67991, "o", "\u001b[1m\u001b[31mE           AttributeError: module 'numpy' has no attribute 'int'.\u001b[0m\r\n"]
[50.679949, "o", "\u001b[1m\u001b[31mE           `np.int` was a deprecated alias for the builtin `int`. To avoid this error in existing code, use `int` by itself. Doing this will not modify any behavior and is safe. When replacing `np.int`, you may wish to use e.g. `np.int64` or `np.int32` to specify the precision. If you wish to review your current use, check the release note link for additional information.\u001b[0m\r\n\u001b[1m\u001b[31mE           The aliases was originally deprecated in NumPy 1.20; for more details and guidance see the original release note at:\u001b[0m\r\n\u001b[1m\u001b[31mE               https://numpy.org/devdocs/release/1.20.0-notes.html#deprecations\u001b[0m\r\n"]
