[48.100801, "o", "\u001b[31m\u001b[1m________________________________________________________________ test_join_announce_leave_flow _________________________________________________________________\u001b[0m\r\n\r\n"]
[48.174091, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92mtest_join_announce_leave_flow\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"Full flow of user joining, announcing, and leaving the mailing list.\"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        subject = \u001b[33m\"\u001b[39;49;00m\u001b[33mSecret Announcement\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        user = \u001b[33m\"\u001b[39;49;00m\u001b[33malicegray\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        add_user(user)\u001b[90m\u001b[39;49;00m\r\n        mbox_path = \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m/var/mail/\u001b[39;49;00m\u001b[33m{\u001b[39;49;00muser\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n"]
[48.174249, "o", "        \u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92m_assert_mailbox_exists\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n            \u001b[94massert\u001b[39;49;00m os.path.exists(mbox_path), \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mMailbox not found: \u001b[39;49;00m\u001b[33m{\u001b[39;49;00mmbox_path\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92m_assert_not_member\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n            mlist = get_mlist()\u001b[90m\u001b[39;49;00m\r\n            user_member = mlist.members.get_member(\u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m{\u001b[39;49;00muser\u001b[33m}\u001b[39;49;00m\u001b[33m@\u001b[39;49;00m\u001b[33m{\u001b[39;49;00mDOMAIN_NAME\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n            \u001b[94massert\u001b[39;49;00m user_member \u001b[95mis\u001b[39;49;00m \u001b[94mNone\u001b[39;49;00m, \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m{\u001b[39;49;00muser\u001b[33m}\u001b[39;49;00m\u001b[33m is a member: \u001b[39;49;00m\u001b[33m{\u001b[39;49;00muser_member\u001b[33m=}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92m_assert_member\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n"]
[48.174333, "o", "            mlist = get_mlist()\u001b[90m\u001b[39;49;00m\r\n            user_member = mlist.members.get_member(\u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m{\u001b[39;49;00muser\u001b[33m}\u001b[39;49;00m\u001b[33m@\u001b[39;49;00m\u001b[33m{\u001b[39;49;00mDOMAIN_NAME\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n            \u001b[94massert\u001b[39;49;00m user_member, \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m{\u001b[39;49;00muser\u001b[33m}\u001b[39;49;00m\u001b[33m is not a member: \u001b[39;49;00m\u001b[33m{\u001b[39;49;00muser_member\u001b[33m=}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n        \u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92m_assert_announcement\u001b[39;49;00m():\u001b[90m\u001b[39;49;00m\r\n            mbox = mailbox.mbox(mbox_path)\u001b[90m\u001b[39;49;00m\r\n            announce_msgs = [msg \u001b[94mfor\u001b[39;49;00m msg \u001b[95min\u001b[39;49;00m mbox \u001b[94mif\u001b[39;49;00m subject \u001b[95min\u001b[39;49;00m msg.get(\u001b[33m\"\u001b[39;49;00m\u001b[33mSubject\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m, \u001b[33m\"\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m)]\u001b[90m\u001b[39;49;00m\r\n            \u001b[94massert\u001b[39;49;00m \u001b[96mlen\u001b[39;49;00m(announce_msgs) == \u001b[94m1\u001b[39;49;00m, (\u001b[90m\u001b[39;49;00m\r\n                \u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33mExpected 1 announcement, found \u001b[39;49;00m\u001b[33m{\u001b[39;49;00m\u001b[96mlen\u001b[39;49;00m(announce_msgs)\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            )\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m\u001b[39;49;00m\r\n>       send_email(\u001b[90m\u001b[39;49;00m\r\n            body=\u001b[33m\"\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n            subject=\u001b[33m\"\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n            from_addr=\u001b[33mf\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m\u001b[33m{\u001b[39;49;00muser\u001b[33m}\u001b[39;49;00m\u001b[33m@\u001b[39;49;00m\u001b[33m{\u001b[39;49;00mDOMAIN_NAME\u001b[33m}\u001b[39;49;00m\u001b[33m\"\u001b[39;49;00m,\u001b[90m\u001b[39;49;00m\r\n            to_addr=JOIN_LIST,\u001b[90m\u001b[39;49;00m\r\n        )\u001b[90m\u001b[39;49;00m\r\n"]
[48.174396, "o", "\r\n\u001b[1m\u001b[31m/tests/test_outputs.py\u001b[0m:197: \r\n"]
[48.174464, "o", "_ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ \r\n"]
[48.174495, "o", "\u001b[1m\u001b[31m/tests/test_outputs.py\u001b[0m:90: in send_email\r\n"]
[48.174861, "o", "    \u001b[0mserver.send_message(msg)\u001b[90m\u001b[39;49;00m\r\n"]
[48.174889, "o", "\u001b[1m\u001b[31m/usr/lib/python3.12/smtplib.py\u001b[0m:975: in send_message\r\n"]
[48.175378, "o", "    \u001b[0m\u001b[94mreturn\u001b[39;49;00m \u001b[96mself\u001b[39;49;00m.sendmail(from_addr, to_addrs, flatmsg, mail_options,\u001b[90m\u001b[39;49;00m\r\n"]
[48.175441, "o", "_ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ _ \r\n\r\n"]
[48.175497, "o", "self = <smtplib.SMTP object at 0x7fbdcb28c650>, from_addr = 'alicegray@local.edu', to_addrs = ['reading-group-join@local.edu']\r\n"]
[48.175525, "o", "msg = b'Content-Type: text/plain; charset=\"us-ascii\"\\r\\nMIME-Version: 1.0\\r\\nContent-Transfer-Encoding: 7bit\\r\\nSubject: \\r\\nFrom: alicegray@local.edu\\r\\nTo: reading-group-join@local.edu\\r\\n\\r\\n'\r\n"]
[48.175552, "o", "mail_options = (), rcpt_options = ()\r\n\r\n"]
[48.182977, "o", "    \u001b[0m\u001b[94mdef\u001b[39;49;00m\u001b[90m \u001b[39;49;00m\u001b[92msendmail\u001b[39;49;00m(\u001b[96mself\u001b[39;49;00m, from_addr, to_addrs, msg, mail_options=(),\u001b[90m\u001b[39;49;00m\r\n                 rcpt_options=()):\u001b[90m\u001b[39;49;00m\r\n    \u001b[90m    \u001b[39;49;00m\u001b[33m\"\"\"This command performs an entire mail transaction.\u001b[39;49;00m\r\n    \u001b[33m\u001b[39;49;00m\r\n    \u001b[33m    The arguments are:\u001b[39;49;00m\r\n    \u001b[33m        - from_addr    : The address sending this mail.\u001b[39;49;00m\r\n    \u001b[33m        - to_addrs     : A list of addresses to send this mail to.  A bare\u001b[39;49;00m\r\n"]
[48.183092, "o", "    \u001b[33m                         string will be treated as a list with 1 address.\u001b[39;49;00m\r\n    \u001b[33m        - msg          : The message to send.\u001b[39;49;00m\r\n    \u001b[33m        - mail_options : List of ESMTP options (such as 8bitmime) for the\u001b[39;49;00m\r\n    \u001b[33m                         mail command.\u001b[39;49;00m\r\n    \u001b[33m        - rcpt_options : List of ESMTP options (such as DSN commands) for\u001b[39;49;00m\r\n    \u001b[33m                         all the rcpt commands.\u001b[39;49;00m\r\n    \u001b[33m\u001b[39;49;00m\r\n    \u001b[33m    msg may be a string containing characters in the ASCII range, or a byte\u001b[39;49;00m\r\n    \u001b[33m    string.  A string is encoded to bytes using the ascii codec, and lone\u001b[39;49;00m\r\n    \u001b[33m    \\\\r and \\\\n characters are converted to \\\\r\\\\n characters.\u001b[39;49;00m\r\n    \u001b[33m\u001b[39;49;00m\r\n    \u001b[33m    If there has been no previous EHLO or HELO command this session, this\u001b[39;49;00m\r\n    \u001b[33m    method tries ESMTP EHLO first.  If the server does ESMTP, message size\u001b[39;49;00m\r\n    \u001b[33m    and each of the specified options will be passed to it.  If EHLO\u001b[39;49;00m\r\n"]
[48.183119, "o", "    \u001b[33m    fails, HELO will be tried and ESMTP options suppressed.\u001b[39;49;00m\r\n    \u001b[33m\u001b[39;49;00m\r\n    \u001b[33m    This method will return normally if the mail is accepted for at least\u001b[39;49;00m\r\n    \u001b[33m    one recipient.  It returns a dictionary, with one entry for each\u001b[39;49;00m\r\n"]
[48.183146, "o", "    \u001b[33m    recipient that was refused.  Each entry contains a tuple of the SMTP\u001b[39;49;00m\r\n    \u001b[33m    error code and the accompanying error message sent by the server.\u001b[39;49;00m\r\n    \u001b[33m\u001b[39;49;00m\r\n"]
[48.183174, "o", "    \u001b[33m    This method may raise the following exceptions:\u001b[39;49;00m\r\n    \u001b[33m\u001b[39;49;00m\r\n    \u001b[33m     SMTPHeloError          The server didn't reply properly to\u001b[39;49;00m\r\n"]
[48.183199, "o", "    \u001b[33m                            the helo greeting.\u001b[39;49;00m\r\n    \u001b[33m     SMTPRecipientsRefused  The server rejected ALL recipients\u001b[39;49;00m\r\n    \u001b[33m                            (no mail was sent).\u001b[39;49;00m\r\n"]
[48.18323, "o", "    \u001b[33m     SMTPSenderRefused      The server didn't accept the from_addr.\u001b[39;49;00m\r\n    \u001b[33m     SMTPDataError          The server replied with an unexpected\u001b[39;49;00m\r\n"]
[48.183255, "o", "    \u001b[33m                            error code (other than a refusal of\u001b[39;49;00m\r\n    \u001b[33m                            a recipient).\u001b[39;49;00m\r\n    \u001b[33m     SMTPNotSupportedError  The mail_options parameter includes 'SMTPUTF8'\u001b[39;49;00m\r\n"]
[48.18328, "o", "    \u001b[33m                            but the SMTPUTF8 extension is not supported by\u001b[39;49;00m\r\n    \u001b[33m                            the server.\u001b[39;49;00m\r\n    \u001b[33m\u001b[39;49;00m\r\n"]
[48.183305, "o", "    \u001b[33m    Note: the connection will be open even after an exception is raised.\u001b[39;49;00m\r\n    \u001b[33m\u001b[39;49;00m\r\n    \u001b[33m    Example:\u001b[39;49;00m\r\n"]
[48.18333, "o", "    \u001b[33m\u001b[39;49;00m\r\n    \u001b[33m     >>> import smtplib\u001b[39;49;00m\r\n"]
[48.183356, "o", "    \u001b[33m     >>> s=smtplib.SMTP(\"localhost\")\u001b[39;49;00m\r\n    \u001b[33m     >>> tolist=[\"one@one.org\",\"two@two.org\",\"three@three.org\",\"four@four.org\"]\u001b[39;49;00m\r\n"]
[48.183382, "o", "    \u001b[33m     >>> msg = '''\\\\\u001b[39;49;00m\r\n    \u001b[33m     ... From: Me@my.org\u001b[39;49;00m\r\n    \u001b[33m     ... Subject: testin'...\u001b[39;49;00m\r\n"]
[48.183407, "o", "    \u001b[33m     ...\u001b[39;49;00m\r\n    \u001b[33m     ... This is a test '''\u001b[39;49;00m\r\n    \u001b[33m     >>> s.sendmail(\"me@my.org\",tolist,msg)\u001b[39;49;00m\r\n"]
[48.183431, "o", "    \u001b[33m     { \"three@three.org\" : ( 550 ,\"User unknown\" ) }\u001b[39;49;00m\r\n    \u001b[33m     >>> s.quit()\u001b[39;49;00m\r\n    \u001b[33m\u001b[39;49;00m\r\n"]
[48.183455, "o", "    \u001b[33m    In the above example, the message was accepted for delivery to three\u001b[39;49;00m\r\n    \u001b[33m    of the four addresses, and one was rejected, with the error code\u001b[39;49;00m\r\n"]
[48.18348, "o", "    \u001b[33m    550.  If all addresses are accepted, then the method will return an\u001b[39;49;00m\r\n    \u001b[33m    empty dictionary.\u001b[39;49;00m\r\n    \u001b[33m\u001b[39;49;00m\r\n"]
[48.183506, "o", "    \u001b[33m    \"\"\"\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n        \u001b[96mself\u001b[39;49;00m.ehlo_or_helo_if_needed()\u001b[90m\u001b[39;49;00m\r\n"]
[48.183531, "o", "        esmtp_opts = []\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mif\u001b[39;49;00m \u001b[96misinstance\u001b[39;49;00m(msg, \u001b[96mstr\u001b[39;49;00m):\u001b[90m\u001b[39;49;00m\r\n            msg = _fix_eols(msg).encode(\u001b[33m'\u001b[39;49;00m\u001b[33mascii\u001b[39;49;00m\u001b[33m'\u001b[39;49;00m)\u001b[90m\u001b[39;49;00m\r\n"]
