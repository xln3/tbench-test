[48.183759, "o", "                \u001b[96mself\u001b[39;49;00m.close()\u001b[90m\u001b[39;49;00m\r\n                \u001b[94mraise\u001b[39;49;00m SMTPRecipientsRefused(senderrs)\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mif\u001b[39;49;00m \u001b[96mlen\u001b[39;49;00m(senderrs) == \u001b[96mlen\u001b[39;49;00m(to_addrs):\u001b[90m\u001b[39;49;00m\r\n"]
[48.183785, "o", "            \u001b[90m# the server refused all our recipients\u001b[39;49;00m\u001b[90m\u001b[39;49;00m\r\n            \u001b[96mself\u001b[39;49;00m._rset()\u001b[90m\u001b[39;49;00m\r\n"]
