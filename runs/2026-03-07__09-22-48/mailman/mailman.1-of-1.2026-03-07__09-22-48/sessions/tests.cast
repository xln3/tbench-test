[48.183683, "o", "        senderrs = {}\u001b[90m\u001b[39;49;00m\r\n        \u001b[94mif\u001b[39;49;00m \u001b[96misinstance\u001b[39;49;00m(to_addrs, \u001b[96mstr\u001b[39;49;00m):\u001b[90m\u001b[39;49;00m\r\n            to_addrs = [to_addrs]\u001b[90m\u001b[39;49;00m\r\n"]
[48.183709, "o", "        \u001b[94mfor\u001b[39;49;00m each \u001b[95min\u001b[39;49;00m to_addrs:\u001b[90m\u001b[39;49;00m\r\n            (code, resp) = \u001b[96mself\u001b[39;49;00m.rcpt(each, rcpt_options)\u001b[90m\u001b[39;49;00m\r\n"]
