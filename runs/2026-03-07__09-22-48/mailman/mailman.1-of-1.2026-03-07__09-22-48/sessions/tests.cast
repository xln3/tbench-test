[48.1836, "o", "            \u001b[94mfor\u001b[39;49;00m option \u001b[95min\u001b[39;49;00m mail_options:\u001b[90m\u001b[39;49;00m\r\n                esmtp_opts.append(option)\u001b[90m\u001b[39;49;00m\r\n        (code, resp) = \u001b[96mself\u001b[39;49;00m.mail(from_addr, esmtp_opts)\u001b[90m\u001b[39;49;00m\r\n"]
[48.183627, "o", "        \u001b[94mif\u001b[39;49;00m code != \u001b[94m250\u001b[39;49;00m:\u001b[90m\u001b[39;49;00m\r\n            \u001b[94mif\u001b[39;49;00m code == \u001b[94m421\u001b[39;49;00m:\u001b[90m\u001b[39;49;00m\r\n                \u001b[96mself\u001b[39;49;00m.close()\u001b[90m\u001b[39;49;00m\r\n            \u001b[94melse\u001b[39;49;00m:\u001b[90m\u001b[39;49;00m\r\n"]
